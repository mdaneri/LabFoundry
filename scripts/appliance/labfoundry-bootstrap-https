#!/usr/bin/env python3
"""Prepare first-boot CA-managed HTTPS material for Photon appliances."""

from __future__ import annotations

from pathlib import Path
import shlex
import shutil
import subprocess

from sqlalchemy import select

from labfoundry.app.database import SessionLocal, init_db
from labfoundry.app.models import ApplianceSettings, CaCertificate, CaSettings
from labfoundry.app.seed import seed_initial_data
from labfoundry.app.services.ca import CA_STAGED_CONFIG_PATH, render_ca_apply_payload
from labfoundry.app.services.networking import sync_host_physical_interfaces
from labfoundry.app.ui import ca_managed_certificate_paths, ensure_ca_state


ENV_PATH = Path("/var/lib/labfoundry/apply/ca/first-boot-management.env")
MARKER_PATH = Path("/var/lib/labfoundry/first-boot-https.applied")
HELPER_PATH = Path("/opt/labfoundry/bin/labfoundry-helper")
NGINX_CONF_INCLUDE_PATH = Path("/etc/nginx/conf.d/labfoundry.conf")
NGINX_MAIN_CONFIG_PATH = Path("/etc/nginx/nginx.conf")
NGINX_MANAGEMENT_PATH = Path("/etc/labfoundry/nginx/sites.d/management.conf")


def run(command: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, check=False, text=True, capture_output=True)


def ensure_nginx_main_config_includes_labfoundry() -> None:
    if not NGINX_MAIN_CONFIG_PATH.exists():
        return
    text = NGINX_MAIN_CONFIG_PATH.read_text(encoding="utf-8")
    if "/etc/nginx/conf.d/labfoundry.conf" in text or "include /etc/nginx/conf.d/*.conf;" in text:
        return
    start = text.find("http")
    brace = text.find("{", start)
    if start < 0 or brace < 0:
        return
    depth = 1
    index = brace + 1
    while index < len(text):
        char = text[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                include = "\n    # Managed by LabFoundry. Local changes may be overwritten.\n    include /etc/nginx/conf.d/labfoundry.conf;\n"
                NGINX_MAIN_CONFIG_PATH.write_text(text[:index].rstrip() + include + text[index:], encoding="utf-8")
                return
        index += 1


def write_nginx_management_config(*, fqdn: str, cert_path: str, key_path: str) -> None:
    NGINX_CONF_INCLUDE_PATH.parent.mkdir(parents=True, exist_ok=True)
    NGINX_MANAGEMENT_PATH.parent.mkdir(parents=True, exist_ok=True)
    for default_path in (Path("/etc/nginx/conf.d/default.conf"), Path("/etc/nginx/conf.d/default_server.conf")):
        default_path.unlink(missing_ok=True)
    NGINX_CONF_INCLUDE_PATH.write_text(
        "# Managed by LabFoundry. Local changes may be overwritten.\ninclude /etc/labfoundry/nginx/sites.d/*.conf;\n",
        encoding="utf-8",
    )
    NGINX_CONF_INCLUDE_PATH.chmod(0o644)
    NGINX_MANAGEMENT_PATH.write_text(
        f"""# Managed by LabFoundry. Local changes may be overwritten.
server {{
  listen 80 default_server;
  server_name _;
  return 308 https://$host$request_uri;
}}

server {{
  listen 443 ssl default_server;
  server_name {fqdn} _;
  ssl_certificate {cert_path};
  ssl_certificate_key {key_path};
  client_max_body_size 1g;
  location / {{
    proxy_pass http://127.0.0.1:8000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }}
}}
""",
        encoding="utf-8",
    )
    NGINX_MANAGEMENT_PATH.chmod(0o644)
    ensure_nginx_main_config_includes_labfoundry()


def apply_ca_files() -> int:
    for action in ("validate", "apply"):
        result = run([str(HELPER_PATH), "ca", action, str(CA_STAGED_CONFIG_PATH), "--real"])
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="")
        if result.returncode != 0:
            return result.returncode
    return 0


def fix_state_permissions() -> None:
    state_path = Path("/var/lib/labfoundry")
    for db_file in state_path.glob("labfoundry.db*"):
        if not db_file.exists():
            continue
        try:
            shutil.chown(db_file, user="labfoundry", group="labfoundry")
        except (LookupError, PermissionError):
            pass
        db_file.chmod(0o640)

    ca_apply_path = Path(CA_STAGED_CONFIG_PATH).parent
    if ca_apply_path.exists():
        for path in [ca_apply_path, *ca_apply_path.rglob("*")]:
            try:
                shutil.chown(path, user="labfoundry", group="labfoundry")
            except (LookupError, PermissionError):
                pass
            path.chmod(0o750 if path.is_dir() else 0o600)


def main() -> int:
    if MARKER_PATH.exists():
        return 0

    init_db()
    with SessionLocal() as db:
        seed_initial_data(db, include_examples=False, appliance_mode=True)
        sync_host_physical_interfaces(db)
        appliance_settings = db.execute(select(ApplianceSettings)).scalar_one()
        ca_settings = db.execute(select(CaSettings)).scalar_one()
        appliance_settings.management_https_enabled = True
        ca_settings.enabled = True
        db.commit()

        errors = ensure_ca_state(db)
        if errors:
            for error in errors:
                print(error)
            return 2

        ca_settings = db.execute(select(CaSettings)).scalar_one()
        certificates = db.execute(select(CaCertificate).order_by(CaCertificate.common_name)).scalars().all()
        config_path = Path(CA_STAGED_CONFIG_PATH)
        config_path.parent.mkdir(parents=True, exist_ok=True)
        config_path.write_text(render_ca_apply_payload(ca_settings, certificates, include_private_keys=True), encoding="utf-8")
        config_path.chmod(0o600)

        cert_path, key_path, _chain_path = ca_managed_certificate_paths(db, "appliance:https")
        if not cert_path or not key_path:
            print("managed appliance HTTPS certificate was not issued")
            return 2
        fqdn = appliance_settings.fqdn

        ENV_PATH.parent.mkdir(parents=True, exist_ok=True)
        ENV_PATH.write_text(
            "\n".join(
                [
                    f"LABFOUNDRY_FIRST_BOOT_FQDN={shlex.quote(appliance_settings.fqdn)}",
                    f"LABFOUNDRY_FIRST_BOOT_CERT_PATH={shlex.quote(cert_path)}",
                    f"LABFOUNDRY_FIRST_BOOT_KEY_PATH={shlex.quote(key_path)}",
                    "",
                ]
            ),
            encoding="utf-8",
        )
        ENV_PATH.chmod(0o600)

    result = apply_ca_files()
    if result != 0:
        return result

    key = Path(key_path)
    if key.exists():
        try:
            shutil.chown(key, user="root", group="labfoundry")
        except (LookupError, PermissionError):
            pass
        key.chmod(0o640)

    write_nginx_management_config(fqdn=fqdn, cert_path=cert_path, key_path=key_path)
    nginx = shutil.which("nginx")
    if nginx:
        validation = run([nginx, "-t"])
        if validation.stdout:
            print(validation.stdout, end="")
        if validation.stderr:
            print(validation.stderr, end="")
        if validation.returncode != 0:
            return validation.returncode

    fix_state_permissions()
    MARKER_PATH.write_text("LabFoundry first-boot HTTPS bootstrap completed.\n", encoding="utf-8")
    MARKER_PATH.chmod(0o640)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
