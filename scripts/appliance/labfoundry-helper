def _handle_kms(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"kms {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_kms_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _kms_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    enabled = _kms_config_enabled(config_path)
    if action == "validate":
        print(json.dumps({"kms": "validation ok", "enabled": enabled, "scope": "PyKMIP lab KMIP server"}, sort_keys=True))
        return 0

    KMS_STATE_DIR.mkdir(parents=True, exist_ok=True)
    KMS_LOG_DIR.mkdir(parents=True, exist_ok=True)
    KMS_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    KMS_POLICY_DIR.mkdir(parents=True, exist_ok=True)
    PYKMIP_CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    if not enabled:
        disable = _run(["systemctl", "disable", "--now", "labfoundry-kms.service"])
        print(disable.stdout, end="")
        print(disable.stderr, end="", file=sys.stderr)
        if disable.returncode not in {0, 1}:
            return disable.returncode
        print(json.dumps({"kms": "apply complete", "enabled": False, "database_path": str(KMS_STATE_DIR / "pykmip.db")}, sort_keys=True))
        return 0

    shutil.copy2(config_path, KMS_CONFIG_PATH)
    shutil.copy2(config_path, PYKMIP_CONFIG_PATH)
    os.chmod(KMS_CONFIG_PATH, 0o644)
    os.chmod(PYKMIP_CONFIG_PATH, 0o644)
    _install_kms_service(KMS_CONFIG_PATH)
    daemon_reload = _run(["systemctl", "daemon-reload"])
    print(daemon_reload.stdout, end="")
    print(daemon_reload.stderr, end="", file=sys.stderr)
    if daemon_reload.returncode != 0:
        return daemon_reload.returncode
    enable = _run(["systemctl", "enable", "labfoundry-kms.service"])
    print(enable.stdout, end="")
    print(enable.stderr, end="", file=sys.stderr)
    if enable.returncode != 0:
        return enable.returncode
    restart = _run(["systemctl", "restart", "labfoundry-kms.service"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    if restart.returncode != 0:
        return restart.returncode
    print(
        json.dumps(
            {
                "kms": "apply complete",
                "enabled": True,
                "config_path": str(KMS_CONFIG_PATH),
                "database_path": str(KMS_STATE_DIR / "pykmip.db"),
                "service": "labfoundry-kms.service",
            },
            sort_keys=True,
        )
    )
    return 0


def _ntpd_config_enabled(path: Path) -> bool:
    for line in path.read_text(encoding="utf-8").splitlines():
        stripped = line.strip().lower()
        if stripped.startswith("# labfoundry ntp enabled:"):
            return stripped.split(":", 1)[1].strip() == "true"
    return False


def _parse_ntpd_server(value: str) -> tuple[str, int | None, bool]:
    source = str(value or "").strip()
    if not source:
        raise ValueError("source is empty")
    host = source
    port: int | None = None
    bracketed = BRACKETED_NTP_SOURCE_PATTERN.fullmatch(source)
    if bracketed:
        host = bracketed.group(1)
        port = int(bracketed.group(2)) if bracketed.group(2) else None
        try:
            if ip_address(host).version != 6:
                raise ValueError
        except ValueError as exc:
            raise ValueError("bracketed source must contain a valid IPv6 address") from exc
    else:
        try:
            parsed_address = ip_address(source)
        except ValueError:
            parsed_address = None
            if source.count(":") == 1:
                possible_host, possible_port = source.rsplit(":", 1)
                if possible_port.isdigit():
                    host = possible_host
                    port = int(possible_port)
            try:
                parsed_address = ip_address(host)
            except ValueError:
                parsed_address = None
        if parsed_address is not None:
            host = str(parsed_address)
    if port is not None and not 1 <= port <= 65535:
        raise ValueError("port must be between 1 and 65535")
    try:
        parsed_host = ip_address(host)
    except ValueError:
        normalized_host = host.strip().strip(".").lower()
        if not HOSTNAME_PATTERN.fullmatch(normalized_host):
            raise ValueError("host must be an IPv4 address, IPv6 address, or fully qualified DNS name")
        return normalized_host, port, False
    return str(parsed_host), port, True


def _ntpd_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    servers: list[str] = []
    listen_addresses: list[str] = []
    allow_entries: list[str] = []
    nts_server_cert = ""
    nts_server_key = ""
    nts_cookie_dir = ""
    nts_requested = False
    restrict_lines: list[list[str]] = []
    enabled = _ntpd_config_enabled(path)

    def add_allow_entry(value: str) -> None:
        normalized = value.strip().lower()
        if normalized and normalized not in allow_entries:
            allow_entries.append(normalized)

    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line:
            continue
        lower = line.lower()
        if lower.startswith("server "):
            parts = line.split()
            if len(parts) < 2:
                errors.append("ntpd server lines must include a server.")
            else:
                servers.append(parts[1])
                nts_requested = nts_requested or "nts" in {part.lower() for part in parts[2:]}
        elif lower.startswith("interface listen "):
            parts = line.split()
            if len(parts) != 3:
                errors.append("ntpd interface listen lines must include one address.")
            else:
                listen_addresses.append(parts[2])
        elif lower.startswith("nts cert "):
            parts = line.split(maxsplit=1)
            nts_server_cert = line.split(maxsplit=2)[2].strip() if len(line.split(maxsplit=2)) == 3 else ""
            nts_requested = True
        elif lower.startswith("nts key "):
            nts_server_key = line.split(maxsplit=2)[2].strip() if len(line.split(maxsplit=2)) == 3 else ""
            nts_requested = True
        elif lower.startswith("nts cookie "):
            nts_cookie_dir = line.split(maxsplit=2)[2].strip() if len(line.split(maxsplit=2)) == 3 else ""
            nts_requested = True
        elif lower.startswith("restrict "):
            restrict_lines.append(lower.split())
        elif lower.startswith("# labfoundry ntp client allow list:"):
            for item in line.split(":", 1)[1].replace(",", "\n").splitlines():
                add_allow_entry(item)
    if enabled and not servers:
        errors.append("ntpd config must include at least one server line.")
    if enabled:
        for raw_line in path.read_text(encoding="utf-8").splitlines():
            parts = raw_line.strip().split()
            if len(parts) < 2 or parts[0].lower() != "server":
                continue
            server = parts[1]
            try:
                _host, _port, is_ip = _parse_ntpd_server(server)
            except ValueError:
                errors.append(
                    f"ntpd server {server} must be an IPv4 address, IPv6 address, or fully qualified DNS name with an optional port."
                )
                continue
            if is_ip and "nts" in {part.lower() for part in parts[2:]}:
                errors.append(f"NTS server {server} must use a certificate-valid DNS hostname, not an IP address.")
    if enabled and not listen_addresses:
        errors.append("enabled ntpd config must include at least one interface listen address.")
    if enabled and "interface ignore wildcard" not in path.read_text(encoding="utf-8").lower():
        errors.append("enabled ntpd config must ignore all interfaces before explicit listeners.")
    for address in listen_addresses:
        try:
            ip_address(address)
        except ValueError:
            errors.append(f"ntpd interface listen address {address} must be a valid IP address.")
    if nts_server_cert or nts_server_key:
        if not nts_server_cert:
            errors.append("ntpd NTS server config must include nts cert.")
        if not nts_server_key:
            errors.append("ntpd NTS server config must include nts key.")
        for label, value in {"certificate": nts_server_cert, "key": nts_server_key}.items():
            if value and not Path(value).is_absolute():
                errors.append(f"ntpd NTS server {label} path must be absolute.")
            elif value and not Path(value).is_file():
                errors.append(f"ntpd NTS server {label} does not exist: {value}")
    if nts_server_cert or nts_server_key:
        if not nts_cookie_dir:
            errors.append("ntpd NTS server config must include nts cookie storage.")
        elif not nts_cookie_dir.startswith("/"):
            errors.append("ntpd NTS cookie storage path must be absolute.")
    if enabled and nts_requested and not _ntpd_supports_nts():
        errors.append("installed ntpd is not the required NTPsec implementation with NTS support.")
    if allow_entries:
        if "any" in allow_entries and len(allow_entries) > 1:
            errors.append("ntpd client allow list can use 'any' only by itself.")
        for entry in allow_entries:
            if entry == "any":
                continue
            try:
                ip_network(entry, strict=False)
            except ValueError:
                errors.append(f"ntpd client allow entry {entry} must be 'any' or a valid IPv4/IPv6 CIDR.")
    if enabled:
        default_restrictions = [tokens for tokens in restrict_lines if len(tokens) >= 2 and tokens[1] == "default"]
        if not default_restrictions:
            errors.append("enabled ntpd config must include a default access restriction.")
        elif "any" in allow_entries:
            flags = set(default_restrictions[-1][2:])
            if not {"nomodify", "noquery"}.issubset(flags) or {"ignore", "noserve"} & flags:
                errors.append("ntpd default access restriction must permit time while denying remote modification and queries.")
        else:
            flags = set(default_restrictions[-1][2:])
            if "ignore" not in flags:
                errors.append("ntpd default access restriction must ignore clients outside the allow list.")
            rendered_restrictions = [" ".join(tokens) for tokens in restrict_lines]
            for entry in allow_entries:
                network = ip_network(entry, strict=False)
                matching = [line for line in rendered_restrictions if str(network.network_address) in line]
                if not matching or not any("nomodify" in line and "noquery" in line and "noserve" not in line for line in matching):
                    errors.append(f"ntpd client allow entry {entry} must permit time while denying modification and queries.")
        source_restrictions = [tokens for tokens in restrict_lines if len(tokens) >= 2 and tokens[1] == "source"]
        if not source_restrictions or not {"nomodify", "noquery"}.issubset(set(source_restrictions[-1][2:])):
            errors.append("enabled ntpd config must permit dynamic upstream replies while denying source modification and queries.")
    return errors


def _ntpd_supports_nts() -> bool:
    ntpd = shutil.which("ntpd")
    if ntpd is None:
        return False
    try:
        result = _run([ntpd, "--version"], timeout=2)
    except (OSError, subprocess.TimeoutExpired):
        return False
    version_text = f"{result.stdout}\n{result.stderr}".lower()
    return result.returncode == 0 and "ntpsec" in version_text


def _ntpd_runtime_identity_errors() -> list[str]:
    errors: list[str] = []
    rpm = shutil.which("rpm")
    if rpm is None:
        errors.append("rpm command not found; cannot verify the Photon ntpsec package.")
    else:
        try:
            package = _run([rpm, "-q", "ntpsec"], timeout=2)
        except (OSError, subprocess.TimeoutExpired):
            package = None
        if package is None or package.returncode != 0:
            errors.append("Photon ntpsec package is required.")
        try:
            python_bindings = _run([rpm, "-q", "python3-ntp"], timeout=2)
        except (OSError, subprocess.TimeoutExpired):
            python_bindings = None
        if python_bindings is None or python_bindings.returncode != 0:
            errors.append("Photon python3-ntp package is required for ntpq.")
    ntpd = shutil.which("ntpd")
    if ntpd is None:
        errors.append("ntpd command not found.")
    else:
        try:
            version = _run([ntpd, "--version"], timeout=2)
        except (OSError, subprocess.TimeoutExpired):
            version = None
        version_text = f"{version.stdout}\n{version.stderr}".lower() if version is not None else ""
        if version is None or version.returncode != 0 or "ntpsec" not in version_text:
            errors.append("installed ntpd is not Photon NTPsec.")
    return errors


def _install_ntpd_config(config_path: Path) -> None:
    NTP_CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    NTP_STATE_DIR.mkdir(parents=True, exist_ok=True)
    try:
        ntp_user = pwd.getpwnam("ntp")
        ntp_group = grp.getgrnam("ntp")
    except KeyError as exc:
        raise RuntimeError("ntp user/group not found; Photon ntpsec package ownership is unavailable") from exc
    os.chown(NTP_STATE_DIR, ntp_user.pw_uid, ntp_group.gr_gid)
    os.chmod(NTP_STATE_DIR, 0o750)
    if NTP_NTS_COOKIE_PATH.is_dir():
        try:
            NTP_NTS_COOKIE_PATH.rmdir()
        except OSError as exc:
            raise RuntimeError(f"NTPsec cookie path is an unexpected non-empty directory: {NTP_NTS_COOKIE_PATH}") from exc
    if not NTP_DRIFT_PATH.exists() or NTP_DRIFT_PATH.stat().st_size == 0:
        NTP_DRIFT_PATH.write_text("0.0\n", encoding="utf-8")
    os.chown(NTP_DRIFT_PATH, ntp_user.pw_uid, ntp_group.gr_gid)
    os.chmod(NTP_DRIFT_PATH, 0o644)
    tmp_target = NTP_CONFIG_PATH.with_suffix(".conf.tmp")
    shutil.copy2(config_path, tmp_target)
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(NTP_CONFIG_PATH)


def _ntpd_nts_server_key_path(config_path: Path) -> Path | None:
    for raw_line in config_path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if line.lower().startswith("nts key "):
            parts = line.split(maxsplit=2)
            if len(parts) == 3 and parts[2].strip():
                return Path(parts[2].strip())
    return None


def _grant_ntpd_nts_server_key_read(config_path: Path) -> Path | None:
    key_path = _ntpd_nts_server_key_path(config_path)
    if key_path is None or not key_path.exists():
        return key_path
    try:
        ntp_group = grp.getgrnam("ntp")
    except KeyError as exc:
        raise RuntimeError("ntp group not found; cannot grant ntpd access to NTS server key") from exc
    os.chown(key_path, 0, ntp_group.gr_gid)
    os.chmod(key_path, 0o640)
    return key_path


def _ntpd_status() -> int:
    ntpq = shutil.which("ntpq")
    if ntpq is None:
        print(json.dumps({"error": "ntpq command not found"}, sort_keys=True))
        return 0
    payload = {}
    for key, command in {
        "peers": [ntpq, "-pn"],
        "variables": [ntpq, "-c", "rv"],
        "nts": [ntpq, "-c", "ntsinfo"],
    }.items():
        try:
            result = _run(command, timeout=1.5)
            payload[key] = {
                "returncode": result.returncode,
                "stdout": result.stdout,
                "stderr": result.stderr,
            }
        except subprocess.TimeoutExpired:
            payload[key] = {
                "returncode": 124,
                "stdout": "",
                "stderr": "ntpq status command timed out after 1.5 seconds",
            }
    print(json.dumps(payload, sort_keys=True))
    return 0


def _ntpd_logs() -> int:
    return _systemd_unit_logs("ntpd.service")


def _handle_nginx(action: str, args: list[str]) -> int:
    if action not in {"logs", "access-logs", "error-logs"}:
        print(f"unsupported nginx action: {action}", file=sys.stderr)
        return 2
    if args:
        print(f"nginx {action} does not accept a path", file=sys.stderr)
        return 2
    if action == "logs":
        return _systemd_unit_logs("nginx.service")
    log_path = NGINX_ACCESS_LOG_PATH if action == "access-logs" else NGINX_ERROR_LOG_PATH
    if not log_path.is_file():
        print(f"nginx log file is unavailable: {log_path}", file=sys.stderr)
        return 1
    try:
        size = log_path.stat().st_size
        with log_path.open("rb") as handle:
            if size > 512 * 1024:
                handle.seek(size - 512 * 1024)
            text = handle.read(512 * 1024).decode("utf-8", errors="replace")
    except OSError as exc:
        print(f"unable to read nginx log file {log_path}: {exc}", file=sys.stderr)
        return 1
    lines = text.splitlines()[-500:]
    if lines:
        print("\n".join(lines))
    return 0


def _ntpd_capabilities() -> int:
    ntpd = shutil.which("ntpd")
    if ntpd is None:
        print(json.dumps({"nts": False, "error": "ntpd command not found"}, sort_keys=True))
        return 0
    try:
        result = _run([ntpd, "--version"], timeout=2)
    except (OSError, subprocess.TimeoutExpired) as exc:
        print(json.dumps({"nts": False, "error": str(exc)}, sort_keys=True))
        return 0
    version_text = f"{result.stdout}\n{result.stderr}".strip()
    identity_errors = _ntpd_runtime_identity_errors()
    print(json.dumps({"nts": result.returncode == 0 and "ntpsec" in version_text.lower() and not identity_errors, "version": version_text, "errors": identity_errors}, sort_keys=True))
    return 0


def _handle_ntpd(action: str, args: list[str]) -> int:
    if action == "capabilities":
        if args:
            print("ntpd capabilities does not accept a path", file=sys.stderr)
            return 2
        return _ntpd_capabilities()
    if action == "logs":
        if args:
            print("ntpd logs does not accept a path", file=sys.stderr)
            return 2
        return _ntpd_logs()
    if action == "status":
        if args:
            print("ntpd status does not accept a path", file=sys.stderr)
            return 2
        return _ntpd_status()
    if len(args) != 1:
        print(f"ntpd {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_ntpd_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _ntpd_config_errors(config_path)
    enabled = _ntpd_config_enabled(config_path)
    if enabled:
        errors.extend(_ntpd_runtime_identity_errors())
    if action == "validate":
        if errors:
            for error in errors:
                print(error, file=sys.stderr)
            return 2
        print(json.dumps({"ntpd": "validation ok", "enabled": enabled, "service": "ntpd.service"}, sort_keys=True))
        return 0
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    if not enabled:
        disable = _run(["systemctl", "disable", "--now", "ntpd.service"])
        print(disable.stdout, end="")
        print(disable.stderr, end="", file=sys.stderr)
        if disable.returncode != 0:
            return disable.returncode
        print(json.dumps({"ntpd": "apply complete", "enabled": False, "service": "ntpd.service"}, sort_keys=True))
        return 0
    try:
        _install_ntpd_config(config_path)
        _grant_ntpd_nts_server_key_read(config_path)
    except (OSError, RuntimeError) as exc:
        print(f"ntpd config installation failed: {exc}", file=sys.stderr)
        return 2
    for command in [
        ["systemctl", "disable", "--now", "chronyd.service"],
        ["systemctl", "disable", "--now", "systemd-timesyncd"],
        ["systemctl", "enable", "ntpd.service"],
        ["systemctl", "restart", "ntpd.service"],
    ]:
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0 and command[:3] != ["systemctl", "disable", "--now"]:
            return result.returncode
    print(json.dumps({"ntpd": "apply complete", "enabled": True, "config_path": str(NTP_CONFIG_PATH), "service": "ntpd.service"}, sort_keys=True))
    return 0


def _validate_appliance_settings_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".json":
        raise ValueError("appliance settings config path must end with .json")
    if not path.is_relative_to(APPLIANCE_SETTINGS_APPLY_DIR):
        raise ValueError(f"appliance settings config must be staged under {APPLIANCE_SETTINGS_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"appliance settings config does not exist: {path}")
    return path


def _load_appliance_settings_config(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    if not isinstance(payload, dict):
        raise ValueError("appliance settings config must be a JSON object")
    return payload


def _appliance_settings_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        payload = _load_appliance_settings_config(path)
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        return [str(exc)]

    fqdn = str(payload.get("fqdn") or "").strip().strip(".").lower()
    if not fqdn or not HOSTNAME_PATTERN.fullmatch(fqdn):
        errors.append("fqdn must be a valid fully qualified DNS name.")

    resolver_mode = str(payload.get("resolver_mode") or "")
    local_dns_enabled = bool(payload.get("local_dns_enabled"))
    resolver_servers = [str(server).strip() for server in payload.get("resolver_servers") or [] if str(server).strip()]
    if resolver_mode not in {"local_dns", "external", "dhcp"}:
        errors.append("resolver_mode must be local_dns, external, or dhcp.")
    if resolver_mode == "local_dns":
        if not local_dns_enabled:
            errors.append("local_dns mode requires local_dns_enabled=true.")
        if resolver_servers != ["127.0.0.1"]:
            errors.append("local_dns mode must use resolver server 127.0.0.1.")
    if resolver_mode == "external" and not resolver_servers:
        errors.append("external resolver mode requires at least one resolver server.")
    if resolver_mode == "dhcp":
        if local_dns_enabled:
            errors.append("dhcp resolver mode requires local_dns_enabled=false.")
        if resolver_servers:
            errors.append("dhcp resolver mode must not include static resolver servers.")
    for server in resolver_servers:
        try:
            ip_interface(f"{server}/32" if ":" not in server else f"{server}/128")
        except ValueError:
            errors.append(f"resolver server {server} must be an IP address.")


    management_interface = str(payload.get("management_interface") or "").strip()
    if not _valid_network_interface_name(management_interface):
        errors.append("management_interface must be a valid interface name.")
    management_ip = str(payload.get("management_ip") or "").strip()
    if not management_ip:
        errors.append("management_ip is required.")
    else:
        try:
            ip_interface(f"{management_ip}/32" if ":" not in management_ip else f"{management_ip}/128")
        except ValueError:
            errors.append("management_ip must be a valid IP address.")

    management_http_port = payload.get("management_http_port", 8000)
    try:
        management_http_port = int(management_http_port)
    except (TypeError, ValueError):
        errors.append("management_http_port must be an integer.")
        management_http_port = 0
    if management_http_port < 1 or management_http_port > 65535:
        errors.append("management_http_port must be between 1 and 65535.")
    for field_name in ["management_public_http_port", "management_public_https_port", "management_upstream_port"]:
        value = payload.get(field_name, 80 if field_name.endswith("http_port") else 443 if field_name.endswith("https_port") else management_http_port)
        try:
            port_value = int(value)
        except (TypeError, ValueError):
            errors.append(f"{field_name} must be an integer.")
            continue
        if port_value < 1 or port_value > 65535:
            errors.append(f"{field_name} must be between 1 and 65535.")
    upstream_host = str(payload.get("management_upstream_host") or "127.0.0.1").strip()
    try:
        ip_interface(f"{upstream_host}/32" if ":" not in upstream_host else f"{upstream_host}/128")
    except ValueError:
        errors.append("management_upstream_host must be an IP address.")
    if not isinstance(payload.get("root_ssh_enabled", False), bool):
        errors.append("root_ssh_enabled must be a boolean.")
    if not isinstance(payload.get("web_terminal_enabled", False), bool):
        errors.append("web_terminal_enabled must be a boolean.")
    terminal_interfaces = payload.get("web_terminal_interfaces") or []
    terminal_addresses = payload.get("web_terminal_addresses") or []
    if not isinstance(terminal_interfaces, list) or not all(_valid_network_interface_name(str(item)) for item in terminal_interfaces):
        errors.append("web_terminal_interfaces must contain valid interface names.")
    if not isinstance(terminal_addresses, list):
        errors.append("web_terminal_addresses must be a list.")
    else:
        for address in terminal_addresses:
            try:
                ip_address(str(address))
            except ValueError:
                errors.append(f"web terminal address {address} must be an IP address.")
    if bool(payload.get("web_terminal_enabled")):
        if not bool(payload.get("management_https_enabled")):
            errors.append("web terminal requires management HTTPS.")
        if management_interface not in terminal_interfaces:
            errors.append("web terminal interfaces must include the management interface.")
        if management_ip not in terminal_addresses:
            errors.append("web terminal addresses must include the management IP.")

    if bool(payload.get("management_https_enabled")):
        cert_path_value = str(payload.get("management_https_cert_path") or "")
        key_path_value = str(payload.get("management_https_key_path") or "")
        if not cert_path_value:
            errors.append("management_https_cert_path is required when management HTTPS is enabled.")
        if not key_path_value:
            errors.append("management_https_key_path is required when management HTTPS is enabled.")
        if cert_path_value:
            try:
                cert_path = _ca_managed_path(cert_path_value, "management_https_cert_path")
                if not cert_path.is_file():
                    errors.append(f"management HTTPS certificate does not exist: {cert_path}")
                else:
                    cert_pem = cert_path.read_text(encoding="utf-8")
                    errors.extend(_pem_errors(cert_pem, "management HTTPS certificate"))
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
        if key_path_value:
            try:
                key_path = _ca_managed_path(key_path_value, "management_https_key_path")
                if not key_path.is_file():
                    errors.append(f"management HTTPS private key does not exist: {key_path}")
                else:
                    key_pem = key_path.read_text(encoding="utf-8")
                    errors.extend(_pem_errors(key_pem, "management HTTPS private key", private_key=True))
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
        if cert_path_value and key_path_value:
            try:
                cert_path = _ca_managed_path(cert_path_value, "management_https_cert_path")
                key_path = _ca_managed_path(key_path_value, "management_https_key_path")
                if cert_path.is_file() and key_path.is_file():
                    matches = _ca_key_matches_certificate(cert_path.read_text(encoding="utf-8"), key_path.read_text(encoding="utf-8"))
                    if matches is False:
                        errors.append("management HTTPS private key does not match the certificate public key.")
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
    return errors


def _labfoundry_service_loopback_dropin(host: str, port: int) -> str:
    return "\n".join(
        [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            "[Service]",
            "ExecStart=",
            f"ExecStart={LABFOUNDRY_UVICORN_COMMAND.format(host=host, port=port)}",
            "",
        ]
    )


def _grant_labfoundry_service_key_read(key_path: Path) -> None:
    os.chmod(key_path, 0o640)
    try:
        shutil.chown(key_path, user="root", group="labfoundry")
    except (LookupError, OSError):
        if os.name != "nt":
            raise


def _run_checked_commands(commands: list[list[str]]) -> int:
    for command in commands:
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0:
            return result.returncode
    return 0


def _disable_legacy_http_redirect() -> int:
    commands: list[list[str]] = []
    if LABFOUNDRY_HTTP_REDIRECT_SERVICE_PATH.exists():
        commands.extend([["systemctl", "disable", "--now", "labfoundry-http-redirect.service"], ["systemctl", "daemon-reload"]])
    if LABFOUNDRY_HTTP_REDIRECT_SERVICE_PATH.exists():
        LABFOUNDRY_HTTP_REDIRECT_SERVICE_PATH.unlink()
    if LABFOUNDRY_HTTP_REDIRECT_SCRIPT_PATH.exists():
        LABFOUNDRY_HTTP_REDIRECT_SCRIPT_PATH.unlink()
    return _run_checked_commands(commands)


def _nginx_binary() -> str | None:
    return shutil.which("nginx") or ("/usr/sbin/nginx" if Path("/usr/sbin/nginx").exists() else None)


def _install_nginx_include() -> None:
    NGINX_SITES_DIR.mkdir(parents=True, exist_ok=True)
    NGINX_CONF_INCLUDE_PATH.parent.mkdir(parents=True, exist_ok=True)
    include_text = "\n".join(
        [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            f"include {NGINX_SITES_DIR}/*.conf;",
            "",
        ]
    )
    current = NGINX_CONF_INCLUDE_PATH.read_text(encoding="utf-8") if NGINX_CONF_INCLUDE_PATH.exists() else ""
    if current != include_text:
        NGINX_CONF_INCLUDE_PATH.write_text(include_text, encoding="utf-8")
        os.chmod(NGINX_CONF_INCLUDE_PATH, 0o644)
    _ensure_nginx_main_config_includes_labfoundry()


def _http_block_end_offset(text: str) -> int:
    match = re.search(r"(?m)^http\s*\{", text)
    if not match:
        return -1
    depth = 1
    index = match.end()
    while index < len(text):
        char = text[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return index
        index += 1
    return -1


def _ensure_nginx_main_config_includes_labfoundry() -> None:
    if not NGINX_MAIN_CONFIG_PATH.exists():
        return
    text = NGINX_MAIN_CONFIG_PATH.read_text(encoding="utf-8")
    include_line = f"    include {NGINX_CONF_INCLUDE_PATH};"
    if str(NGINX_CONF_INCLUDE_PATH) in text:
        return
    end_offset = _http_block_end_offset(text)
    if end_offset < 0:
        return
    prefix = text[:end_offset].rstrip()
    suffix = text[end_offset:]
    next_text = f"{prefix}\n\n    # Managed by LabFoundry. Local changes may be overwritten.\n{include_line}\n{suffix}"
    tmp_target = NGINX_MAIN_CONFIG_PATH.with_suffix(".conf.tmp")
    tmp_target.write_text(next_text, encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(NGINX_MAIN_CONFIG_PATH)


def _nginx_test_command() -> subprocess.CompletedProcess[str]:
    nginx = _nginx_binary()
    if nginx is None:
        return subprocess.CompletedProcess(["nginx", "-t"], 127, "", "nginx command not found\n")
    return _run([nginx, "-t"])


def _reload_nginx() -> int:
    commands = [["systemctl", "enable", "--now", "nginx"]]
    reload_result = _run(["systemctl", "reload", "nginx"])
    if reload_result.returncode == 0:
        print(reload_result.stdout, end="")
        print(reload_result.stderr, end="", file=sys.stderr)
        return _run_checked_commands(commands)
    commands.append(["systemctl", "restart", "nginx"])
    return _run_checked_commands(commands)


def _nginx_site_metadata(text: str) -> list[tuple[str, set[str]]]:
    metadata: list[tuple[str, set[str]]] = []
    for block in re.findall(r"server\s*\{(?P<body>.*?)\n\}", text, flags=re.DOTALL):
        names: set[str] = set()
        listens: set[str] = set()
        for raw in block.splitlines():
            line = raw.strip().rstrip(";")
            if not line or line.startswith("#"):
                continue
            if line.startswith("server_name "):
                names.update(item for item in line.split()[1:] if item != "_")
            elif line.startswith("listen "):
                value = " ".join(part for part in line.split()[1:] if part not in {"ssl", "http2", "default_server"})
                listens.add(value)
        for name in names:
            metadata.append((name, listens))
    return metadata


def _nginx_site_conflict(site_path: Path, text: str) -> str:
    if not NGINX_SITES_DIR.exists():
        return ""
    candidate = _nginx_site_metadata(text)
    for other_path in NGINX_SITES_DIR.glob("*.conf"):
        if other_path.resolve() == site_path.resolve() or not other_path.is_file():
            continue
        for name, listens in _nginx_site_metadata(other_path.read_text(encoding="utf-8")):
            for candidate_name, candidate_listens in candidate:
                if name == candidate_name and listens.intersection(candidate_listens):
                    return f"nginx site {site_path.name} duplicates server_name {name} on {', '.join(sorted(listens.intersection(candidate_listens)))}."
    return ""


def _install_nginx_site(site_path: Path, text: str) -> int:
    nginx = _nginx_binary()
    if nginx is None:
        print("nginx command not found", file=sys.stderr)
        return 127
    _install_nginx_include()
    conflict = _nginx_site_conflict(site_path, text)
    if conflict:
        print(conflict, file=sys.stderr)
        return 2
    previous = site_path.read_text(encoding="utf-8") if site_path.exists() else None
    site_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_target = site_path.with_suffix(".conf.tmp")
    tmp_target.write_text(text, encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(site_path)
    validation = _nginx_test_command()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        if previous is None:
            site_path.unlink(missing_ok=True)
        else:
            site_path.write_text(previous, encoding="utf-8")
            os.chmod(site_path, 0o644)
        return validation.returncode
    return _reload_nginx()


def _remove_nginx_site(site_path: Path) -> int:
    if not site_path.exists():
        return 0
    _install_nginx_include()
    site_path.unlink()
    validation = _nginx_test_command()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        return validation.returncode
    return _reload_nginx()


def _validate_public_services_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("Public services nginx config path must end with .conf")
    if not path.is_relative_to(PUBLIC_SERVICES_APPLY_DIR):
        raise ValueError(f"Public services nginx config must be staged under {PUBLIC_SERVICES_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"Public services nginx config does not exist: {path}")
    return path


def _public_services_config_errors(path: Path) -> list[str]:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return [str(exc)]
    errors: list[str] = []
    if "IP-scoped public service front door" not in text:
        errors.append("Public services nginx config must be generated by LabFoundry.")
    if _nginx_directive(text, "root"):
        errors.append("Public services nginx config must not expose a broad server root.")
    if "/registry" in text:
        errors.append("Public services nginx config must not add registry proxy locations.")
    if "location = /terminal/ws {" in text:
        for required in [
            "location = /login {",
            "location = /logout {",
            "location = /terminal {",
            "location = /terminal/tickets {",
            "location = /terminal/ws {",
            "location ^~ /static/ {",
            "proxy_set_header X-LabFoundry-Listener-Address $server_addr;",
            "proxy_set_header Upgrade $http_upgrade;",
            'proxy_set_header Connection "upgrade";',
        ]:
            if required not in text:
                errors.append(f"Public services web terminal config must include {required}.")
        if "location / { return 404; }" not in text and "location / {\n    return 404;" not in text:
            errors.append("Public services web terminal config must keep the catch-all route closed.")
        for forbidden in ["location = /dashboard", "location ^~ /api", "location /api", "location = /settings"]:
            if forbidden in text:
                errors.append(f"Public services web terminal config must not expose {forbidden}.")
    if "/PROD/" in text or "location = /PROD" in text or "location ~ ^/PROD/" in text:
        if "IP-scoped HTTPS public services front door." not in text:
            errors.append("Public services nginx config may expose VCF Offline Depot paths only in the IP-scoped HTTPS front door.")
        aliases = _nginx_directive(text, "alias")
        prod_alias = next((alias for alias in aliases if _public_services_prod_alias_path(alias) == VCF_DEPOT_PROD_PATH), "")
        if not prod_alias:
            errors.append(f"Public services VCF Offline Depot alias must point at {VCF_DEPOT_PROD_PATH}.")
        for required in [
            "location = /PROD",
            "return 301 /PROD/;",
            "location = /PROD/login",
            "location = /PROD/logout",
            "location = /PROD/",
            "location ~ ^/PROD/.*/$",
            "location ~ ^/PROD/(?!login$|logout$|auth-check$)(.+[^/])$",
        ]:
            if required not in text:
                errors.append(f"Public services VCF Offline Depot config must include {required}.")
        if _vcf_depot_auth_required(text) and "proxy_pass http://127.0.0.1:8000/PROD/auth-failure;" not in text:
            errors.append("Authenticated public services VCF Offline Depot config must return 401 to non-browser clients.")
    for forbidden in [
        "location = /favicon.ico",
        "location = /manifest.webmanifest",
        "location = /service-worker.js",
        "location = /requests/login",
        "location = /requests/logout",
        "location = /ca",
        "location ^~ /ca/",
        "location = /requests",
        "location ^~ /requests/",
    ]:
        if forbidden in text and "CA portal HTTPS front door." not in text:
            errors.append("Public services HTTP config may serve only ESXi PXE paths.")
            break
    esxi_http_alias = ESXI_PXE_HTTP_BASE.as_posix().rstrip("/")
    if "location /pxe/esxi/" in text and f"alias {esxi_http_alias}/;" not in text:
        errors.append(f"Public services ESXi PXE location must alias {ESXI_PXE_HTTP_BASE}.")
    if "location /pxe/esxi/ks/" in text and "proxy_pass http://127.0.0.1:8000;" not in text:
        errors.append("Public services ESXi Kickstart location must proxy to LabFoundry.")
    if "CA portal HTTPS front door." in text:
        for required in [
            "location = / {",
            "location = /ca",
            "location ^~ /ca/",
            "location = /requests",
            "location ^~ /requests/",
            "location ^~ /static/",
            "location = /favicon.ico",
            "location = /manifest.webmanifest",
            "location = /service-worker.js",
            "proxy_set_header X-Forwarded-Proto https;",
        ]:
            if required not in text:
                errors.append(f"Public services CA HTTPS config must include {required}.")
        server_names = _nginx_directive(text, "server_name")
        for server_name in server_names:
            for name in server_name.split():
                normalized = name.strip().strip(".").lower()
                if normalized == "_":
                    continue
                try:
                    ip_interface(f"{normalized}/32" if ":" not in normalized else f"{normalized}/128")
                    continue
                except ValueError:
                    pass
                if not HOSTNAME_PATTERN.fullmatch(normalized):
                    errors.append(f"Public services server_name {name} must be a valid DNS name or address.")
    for directive, label, private in [
        ("ssl_certificate", "Public services certificate", False),
        ("ssl_certificate_key", "Public services private key", True),
    ]:
        for value in _nginx_directive(text, directive):
            try:
                cert_path = _ca_managed_path(value, directive)
                if not cert_path.is_file():
                    errors.append(f"{label} does not exist: {cert_path}")
                else:
                    errors.extend(_pem_errors(cert_path.read_text(encoding="utf-8"), label, private_key=private))
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
    return errors


def _public_services_prod_alias_path(alias: str) -> Path:
    normalized = alias.strip().rstrip("/")
    if normalized.endswith("/$1"):
        normalized = normalized[:-3]
    return Path(normalized)


def _handle_public_services(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"public-services {action} requires exactly one staged nginx config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_public_services_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _public_services_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    if action == "validate":
        print(json.dumps({"public_services": "validation ok", "config_path": str(config_path)}, sort_keys=True))
        return 0
    if action == "apply":
        text = config_path.read_text(encoding="utf-8")
        if "server {" not in text:
            result = _remove_nginx_site(NGINX_PUBLIC_SERVICES_SITE_PATH)
        else:
            if _vcf_depot_auth_required(text) and _write_vcf_depot_htpasswd(_vcf_depot_auth_username(text)) != 0:
                return 2
            result = _install_nginx_site(NGINX_PUBLIC_SERVICES_SITE_PATH, text)
        if result != 0:
            return result
        print(json.dumps({"public_services": "apply complete", "site_path": str(NGINX_PUBLIC_SERVICES_SITE_PATH)}, sort_keys=True))
        return 0
    print(f"unsupported public-services action: {action}", file=sys.stderr)
    return 2


def _management_proxy_location(upstream_host: str, upstream_port: int, forwarded_proto: str) -> list[str]:
    return [
        "  client_max_body_size 1g;",
        "  location / {",
        f"    proxy_pass http://{upstream_host}:{upstream_port};",
        "    proxy_http_version 1.1;",
        "    proxy_set_header Host $host;",
        "    proxy_set_header X-Real-IP $remote_addr;",
        "    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;",
        f"    proxy_set_header X-Forwarded-Proto {forwarded_proto};",
        "    proxy_set_header X-LabFoundry-Listener-Address $server_addr;",
        '    proxy_set_header X-LabFoundry-Depot-Basic-User "";',
        "    proxy_set_header Upgrade $http_upgrade;",
        '    proxy_set_header Connection "upgrade";',
        "  }",
    ]


def _management_ca_download_locations(upstream_host: str, upstream_port: int) -> list[str]:
    lines: list[str] = []
    for path in ("/ca/downloads/root-ca.pem", "/ca/downloads/ca-bundle.pem"):
        lines.extend(
            [
                f"  location = {path} {{",
                f"    proxy_pass http://{upstream_host}:{upstream_port};",
                "    proxy_http_version 1.1;",
                "    proxy_set_header Host $host;",
                "    proxy_set_header X-Real-IP $remote_addr;",
                "    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;",
                "    proxy_set_header X-Forwarded-Proto http;",
                "  }",
            ]
        )
    return lines


def _management_nginx_config(payload: dict, cert_path: Path | None = None, key_path: Path | None = None) -> str:
    fqdn = str(payload["fqdn"])
    https_enabled = bool(payload.get("management_https_enabled"))
    public_http_port = int(payload.get("management_public_http_port") or 80)
    public_https_port = int(payload.get("management_public_https_port") or 443)
    upstream_host = str(payload.get("management_upstream_host") or "127.0.0.1")
    upstream_port = int(payload.get("management_upstream_port") or payload.get("management_http_port") or 8000)
    lines = ["# Managed by LabFoundry. Local changes may be overwritten."]
    if not https_enabled:
        lines.extend(
            [
                "server {",
                f"  listen {public_http_port} default_server;",
                f"  server_name {fqdn} _;",
                *_management_proxy_location(upstream_host, upstream_port, "http"),
                "}",
                "",
            ]
        )
        return "\n".join(lines)
    lines.extend(
        [
            "server {",
            f"  listen {public_http_port} default_server;",
            "  server_name _;",
            *_management_ca_download_locations(upstream_host, upstream_port),
            "  location / {",
            "    return 308 https://$host$request_uri;",
            "  }",
            "}",
            "",
            "server {",
            f"  listen {public_https_port} ssl default_server;",
            f"  server_name {fqdn};",
            f"  ssl_certificate {cert_path};",
            f"  ssl_certificate_key {key_path};",
            *_management_proxy_location(upstream_host, upstream_port, "https"),
            "}",
            "",
        ]
    )
    return "\n".join(lines)


def _configure_labfoundry_management_https(payload: dict) -> int:
    enabled = bool(payload.get("management_https_enabled"))
    changed = False
    port = int(payload.get("management_upstream_port") or payload.get("management_http_port") or 8000)
    upstream_host = str(payload.get("management_upstream_host") or "127.0.0.1")
    legacy_redirect = _disable_legacy_http_redirect()
    if legacy_redirect != 0:
        return legacy_redirect
    cert_path: Path | None = None
    key_path: Path | None = None
    if enabled:
        cert_path = _ca_managed_path(str(payload["management_https_cert_path"]), "management_https_cert_path")
        key_path = _ca_managed_path(str(payload["management_https_key_path"]), "management_https_key_path")
        _grant_labfoundry_service_key_read(key_path)
    site_apply = _install_nginx_site(NGINX_MANAGEMENT_SITE_PATH, _management_nginx_config(payload, cert_path, key_path))
    if site_apply != 0:
        return site_apply
    next_text = _labfoundry_service_loopback_dropin(upstream_host, port)
    LABFOUNDRY_SERVICE_DROPIN_DIR.mkdir(parents=True, exist_ok=True)
    current_text = LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH.read_text(encoding="utf-8") if LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH.exists() else ""
    if current_text != next_text:
        tmp_target = LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH.with_suffix(".conf.tmp")
        tmp_target.write_text(next_text, encoding="utf-8")
        os.chmod(tmp_target, 0o644)
        tmp_target.replace(LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH)
        changed = True
    if not changed:
        return 0

    daemon_reload = _run(["systemctl", "daemon-reload"])
    print(daemon_reload.stdout, end="")
    print(daemon_reload.stderr, end="", file=sys.stderr)
    if daemon_reload.returncode != 0:
        return daemon_reload.returncode

    restart_command = ["systemctl", "restart", "labfoundry.service"]
    systemd_run = shutil.which("systemd-run")
    if systemd_run is not None:
        command = [
            systemd_run,
            "--quiet",
            "--collect",
            "--on-active=3",
            "--unit=labfoundry-management-ui-restart",
            *restart_command,
        ]
    else:
        command = restart_command
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _root_ssh_config(enabled: bool) -> str:
    lines = [
        "# Managed by LabFoundry. Local changes may be overwritten.",
        f"PermitRootLogin {'yes' if enabled else 'no'}",
    ]
    if enabled:
        lines.extend(["PasswordAuthentication yes", "KbdInteractiveAuthentication yes"])
    lines.append("")
    return "\n".join(lines)


def _ensure_sshd_dropin_include(*, unset_global_options: set[str] | None = None) -> int:
    include_line = "Include /etc/ssh/sshd_config.d/*.conf"
    unset_options = {option.lower() for option in (unset_global_options or set())}
    try:
        lines = SSHD_MAIN_CONFIG_PATH.read_text(encoding="utf-8").splitlines()
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2

    next_lines: list[str] = []
    include_seen = False
    in_match_block = False
    for line in lines:
        stripped = line.strip()
        lower = stripped.lower()
        if lower == include_line.lower():
            include_seen = True
            continue
        if lower.startswith("match "):
            in_match_block = True
        option = lower.split(None, 1)[0] if lower and not lower.startswith("#") else ""
        if not in_match_block and option in unset_options:
            next_lines.append(f"# LabFoundry manages this directive through {SSHD_ROOT_LOGIN_CONFIG_PATH.name}: {line}")
            continue
        next_lines.append(line)

    insert_at = next((index for index, line in enumerate(next_lines) if line.strip().lower().startswith("match ")), len(next_lines))
    next_lines.insert(insert_at, include_line)
    next_text = "\n".join(next_lines).rstrip() + "\n"
    current_text = SSHD_MAIN_CONFIG_PATH.read_text(encoding="utf-8")
    if include_seen and current_text == next_text:
        return 0
    SSHD_MAIN_CONFIG_PATH.write_text(next_text, encoding="utf-8")
    os.chmod(SSHD_MAIN_CONFIG_PATH, 0o644)
    return 0


def _configure_root_ssh(enabled: bool) -> int:
    SSHD_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    include_result = _ensure_sshd_dropin_include(
        unset_global_options={"PermitRootLogin", "PasswordAuthentication", "KbdInteractiveAuthentication"}
    )
    if include_result != 0:
        return include_result
    previous = SSHD_ROOT_LOGIN_CONFIG_PATH.read_text(encoding="utf-8") if SSHD_ROOT_LOGIN_CONFIG_PATH.exists() else None
    tmp_target = SSHD_ROOT_LOGIN_CONFIG_PATH.with_suffix(".conf.tmp")
    tmp_target.write_text(_root_ssh_config(enabled), encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(SSHD_ROOT_LOGIN_CONFIG_PATH)
    validation = _validate_sshd_config()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        if previous is None:
            SSHD_ROOT_LOGIN_CONFIG_PATH.unlink(missing_ok=True)
        else:
            SSHD_ROOT_LOGIN_CONFIG_PATH.write_text(previous, encoding="utf-8")
            os.chmod(SSHD_ROOT_LOGIN_CONFIG_PATH, 0o644)
        return validation.returncode
    restart = _run(["systemctl", "restart", "sshd"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    return restart.returncode


def _configure_web_terminal(enabled: bool) -> int:
    SSHD_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    include_result = _ensure_sshd_dropin_include()
    if include_result != 0:
        return include_result
    previous = SSHD_WEB_TERMINAL_CONFIG_PATH.read_text(encoding="utf-8") if SSHD_WEB_TERMINAL_CONFIG_PATH.exists() else None
    if enabled:
        WEB_TERMINAL_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        os.chmod(WEB_TERMINAL_CONFIG_DIR, 0o755)
        ssh_keygen = shutil.which("ssh-keygen")
        if ssh_keygen is None:
            print("ssh-keygen command not found", file=sys.stderr)
            return 127
        if not WEB_TERMINAL_CA_KEY_PATH.exists():
            generated = _run([ssh_keygen, "-q", "-t", "ed25519", "-N", "", "-C", "LabFoundry web terminal CA", "-f", str(WEB_TERMINAL_CA_KEY_PATH)])
            if generated.returncode != 0:
                print(generated.stderr or generated.stdout, end="", file=sys.stderr)
                return generated.returncode
        os.chmod(WEB_TERMINAL_CA_KEY_PATH, 0o600)
        os.chmod(WEB_TERMINAL_CA_PUBLIC_KEY_PATH, 0o644)
        SSHD_WEB_TERMINAL_CONFIG_PATH.write_text(
            "# Managed by LabFoundry. Passwordless browser terminal certificates.\n"
            f"TrustedUserCAKeys {WEB_TERMINAL_CA_PUBLIC_KEY_PATH}\n",
            encoding="utf-8",
        )
        os.chmod(SSHD_WEB_TERMINAL_CONFIG_PATH, 0o644)
        WEB_TERMINAL_REQUEST_DIR.mkdir(parents=True, exist_ok=True)
        service_account = pwd.getpwnam(LABFOUNDRY_SERVICE_USER)
        _chown_path(WEB_TERMINAL_RUNTIME_DIR, service_account.pw_uid, service_account.pw_gid)
        _chown_path(WEB_TERMINAL_REQUEST_DIR, service_account.pw_uid, service_account.pw_gid)
        os.chmod(WEB_TERMINAL_RUNTIME_DIR, 0o750)
        os.chmod(WEB_TERMINAL_REQUEST_DIR, 0o750)
    else:
        SSHD_WEB_TERMINAL_CONFIG_PATH.unlink(missing_ok=True)
    validation = _validate_sshd_config()
    if validation.returncode != 0:
        if previous is None:
            SSHD_WEB_TERMINAL_CONFIG_PATH.unlink(missing_ok=True)
        else:
            SSHD_WEB_TERMINAL_CONFIG_PATH.write_text(previous, encoding="utf-8")
            os.chmod(SSHD_WEB_TERMINAL_CONFIG_PATH, 0o644)
        print(validation.stderr or validation.stdout, end="", file=sys.stderr)
        return validation.returncode
    restart = _run(["systemctl", "restart", "sshd"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    return restart.returncode


def _validate_web_terminal_request_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".json" or not path.is_relative_to(WEB_TERMINAL_REQUEST_DIR):
        raise ValueError(f"web terminal request must be JSON staged under {WEB_TERMINAL_REQUEST_DIR}")
    if not path.is_file():
        raise ValueError(f"web terminal request does not exist: {path}")
    return path


def _handle_web_terminal(action: str, args: list[str]) -> int:
    if action == "status":
        if args:
            return 2
        print(json.dumps({"enabled": SSHD_WEB_TERMINAL_CONFIG_PATH.is_file() and WEB_TERMINAL_CA_KEY_PATH.is_file()}, sort_keys=True))
        return 0
    if action != "sign" or len(args) != 1:
        print("web-terminal sign requires one staged request path", file=sys.stderr)
        return 2
    if not SSHD_WEB_TERMINAL_CONFIG_PATH.is_file() or not WEB_TERMINAL_CA_KEY_PATH.is_file():
        print("web terminal is not applied", file=sys.stderr)
        return 2
    try:
        request_path = _validate_web_terminal_request_path(args[0])
        payload = json.loads(request_path.read_text(encoding="utf-8"))
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    username = str(payload.get("username") or "").strip().lower()
    session_id = str(payload.get("session_id") or "").strip()
    public_key = str(payload.get("public_key") or "").strip()
    if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username) or username in LOCAL_USERS_RESERVED_USERNAMES:
        print("web terminal username is not allowed", file=sys.stderr)
        return 2
    if not re.fullmatch(r"ssh-ed25519 [A-Za-z0-9+/=]+(?: [^\r\n]+)?", public_key):
        print("web terminal public key must be an OpenSSH Ed25519 key", file=sys.stderr)
        return 2
    if not re.fullmatch(r"[A-Za-z0-9_-]{8,80}", session_id):
        print("web terminal session id is invalid", file=sys.stderr)
        return 2
    try:
        account = pwd.getpwnam(username)
    except KeyError:
        print("web terminal user must exist", file=sys.stderr)
        return 2
    if account.pw_shell not in LOCAL_USERS_ALLOWED_SHELLS - {"/sbin/nologin"}:
        print("web terminal user must have an interactive shell", file=sys.stderr)
        return 2
    ssh_keygen = shutil.which("ssh-keygen")
    if ssh_keygen is None:
        print("ssh-keygen command not found", file=sys.stderr)
        return 127
    with tempfile.TemporaryDirectory(prefix="labfoundry-web-terminal-") as temp_dir:
        public_path = Path(temp_dir) / "session.pub"
        public_path.write_text(public_key + "\n", encoding="utf-8")
        result = _run(
            [
                ssh_keygen, "-q", "-s", str(WEB_TERMINAL_CA_KEY_PATH), "-I", f"labfoundry-{session_id}",
                "-n", username, "-V", "-5s:+60s", "-O", "source-address=127.0.0.1/32",
                "-O", "no-port-forwarding", "-O", "no-agent-forwarding", "-O", "no-x11-forwarding",
                "-O", "no-user-rc", str(public_path),
            ]
        )
        certificate_path = Path(temp_dir) / "session-cert.pub"
        if result.returncode != 0 or not certificate_path.is_file():
            print(result.stderr or result.stdout or "ssh-keygen did not issue a certificate", end="", file=sys.stderr)
            return result.returncode or 2
        print(certificate_path.read_text(encoding="utf-8").strip())
    request_path.unlink(missing_ok=True)
    return 0


def _apply_hostname(fqdn: str) -> int:
    hostnamectl = shutil.which("hostnamectl")
    if hostnamectl is not None:
        result = _run([hostnamectl, "set-hostname", fqdn])
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        return result.returncode

    hostname_path = Path("/etc/hostname")
    hostname_path.write_text(f"{fqdn}\n", encoding="utf-8")
    os.chmod(hostname_path, 0o644)
    hostname = shutil.which("hostname")
    if hostname is None:
        print("hostnamectl and hostname commands not found", file=sys.stderr)
        return 127
    result = _run([hostname, fqdn])
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _handle_appliance_settings(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"appliance-settings {action} requires exactly one staged JSON config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_appliance_settings_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _appliance_settings_config_errors(config_path)
    if action == "validate":
        if errors:
            for error in errors:
                print(error, file=sys.stderr)
            return 2
        payload = _load_appliance_settings_config(config_path)
        print(
            json.dumps(
                {
                    "appliance_settings": "validation ok",
                    "resolver_mode": payload["resolver_mode"],
                    "management_https_enabled": bool(payload.get("management_https_enabled")),
                    "web_terminal_enabled": bool(payload.get("web_terminal_enabled")),
                    "root_ssh_enabled": bool(payload.get("root_ssh_enabled")),
                    "management_interface": payload["management_interface"],
                    "scope": "systemd-resolved, LabFoundry management UI, root SSH login, and web terminal trust",
                },
                sort_keys=True,
            )
        )
        return 0
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2

    payload = _load_appliance_settings_config(config_path)
    fqdn = str(payload["fqdn"])
    management_interface = str(payload["management_interface"])
    resolver_mode = str(payload["resolver_mode"])
    resolver_servers = [str(server) for server in payload["resolver_servers"]]
    domains = ["~."] if resolver_mode == "local_dns" else []
    hostname = _apply_hostname(fqdn)
    if hostname != 0:
        return hostname
    resolver = _configure_dhcp_resolver(management_interface) if resolver_mode == "dhcp" else _configure_resolver(management_interface, resolver_servers, domains)
    if resolver.returncode != 0:
        return resolver.returncode
    root_ssh = _configure_root_ssh(bool(payload.get("root_ssh_enabled")))
    if root_ssh != 0:
        return root_ssh
    web_terminal = _configure_web_terminal(bool(payload.get("web_terminal_enabled")))
    if web_terminal != 0:
        return web_terminal
    management_https = _configure_labfoundry_management_https(payload)
    if management_https != 0:
        return management_https
    print(
        json.dumps(
            {
                "appliance_settings": "apply complete",
                "fqdn": fqdn,
                "management_https_enabled": bool(payload.get("management_https_enabled")),
                "root_ssh_enabled": bool(payload.get("root_ssh_enabled")),
                "web_terminal_enabled": bool(payload.get("web_terminal_enabled")),
                "web_terminal_interfaces": payload.get("web_terminal_interfaces") or [],
                "resolver_mode": resolver_mode,
                "resolver_servers": resolver_servers,
            },
            sort_keys=True,
        )
    )
    return 0


