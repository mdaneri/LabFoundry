def _wan_forwarding_required(parsed: dict[str, list[dict[str, str]]]) -> bool:
    enabled_nat = any(_wan_bool(rule.get("enabled", ""), default=True) for rule in parsed["nat_rules"])
    enabled_routes = any(_wan_bool(route.get("enabled", ""), default=True) for route in parsed["routes"])
    enabled_routing_rules = any(_wan_bool(rule.get("enabled", ""), default=True) for rule in parsed["routing_rules"])
    return enabled_nat or enabled_routes or enabled_routing_rules


def _apply_wan_forwarding(parsed: dict[str, list[dict[str, str]]]) -> int:
    value = "1" if _wan_forwarding_required(parsed) else "0"
    WAN_SYSCTL_PATH.write_text(f"net.ipv4.ip_forward = {value}\n", encoding="utf-8")
    os.chmod(WAN_SYSCTL_PATH, 0o644)
    sysctl = _run(["sysctl", "-w", f"net.ipv4.ip_forward={value}"])
    print(sysctl.stdout, end="")
    print(sysctl.stderr, end="", file=sys.stderr)
    return sysctl.returncode


def _handle_wan(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"wan {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_wan_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _wan_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    parsed = _parse_wan_config(config_path)
    nat_validation = _validate_wan_nat_config(_render_wan_nat_config(parsed["nat_rules"]))
    if action == "validate":
        print(nat_validation.stdout, end="")
        print(nat_validation.stderr, end="", file=sys.stderr)
        if nat_validation.returncode != 0:
            return nat_validation.returncode
        print(
            json.dumps(
                {
                    "wan": "validation ok",
                    "routes": len(parsed["routes"]),
                    "nat_rules": len(parsed["nat_rules"]),
                    "wan_policies": len(parsed["wan_policies"]),
                    "routing_rules": len(parsed["routing_rules"]),
                    "scope": "ip-rule ip-route nftables tc-netem",
                },
                sort_keys=True,
            )
        )
        return 0
    nat_result = _apply_wan_nat(parsed)
    if nat_result != 0:
        return nat_result
    forwarding_result = _apply_wan_forwarding(parsed)
    if forwarding_result != 0:
        return forwarding_result
    target_route_result = _apply_wan_target_routes(parsed)
    if target_route_result != 0:
        return target_route_result
    rule_result = _apply_wan_policy_rules(parsed)
    if rule_result != 0:
        return rule_result
    route_result = _apply_wan_routes_and_qdiscs(parsed)
    if route_result != 0:
        return route_result
    print(
        json.dumps(
            {
                "wan": "apply complete",
                "routes": len(parsed["routes"]),
                "removed_routes": len(parsed["removed_routes"]),
                "routing_rules": len(parsed["routing_rules"]),
                "nat_rules": len(parsed["nat_rules"]),
                "wan_policies": len(parsed["wan_policies"]),
            },
            sort_keys=True,
        )
    )
    return 0


