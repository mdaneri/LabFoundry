def _run(command: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, check=False, capture_output=True, text=True)


def _run_with_input(command: list[str], input_text: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, input=input_text, check=False, capture_output=True, text=True)


def _run_account_command(command: list[str]) -> subprocess.CompletedProcess[str]:
    if os.environ.get("LABFOUNDRY_HELPER_USE_SYSTEMD_RUN") == "1":
        systemd_run = shutil.which("systemd-run")
        if systemd_run is not None:
            return _run([systemd_run, "--quiet", "--wait", "--pipe", "--collect", "--service-type=exec", *command])
    return _run(command)


def _run_account_command_with_input(command: list[str], input_text: str) -> subprocess.CompletedProcess[str]:
    if os.environ.get("LABFOUNDRY_HELPER_USE_SYSTEMD_RUN") == "1":
        systemd_run = shutil.which("systemd-run")
        if systemd_run is not None:
            return _run_with_input([systemd_run, "--quiet", "--wait", "--pipe", "--collect", "--service-type=exec", *command], input_text)
    return _run_with_input(command, input_text)


def _should_run_real_action_with_systemd(action: str) -> bool:
    return (
        action in SYSTEMD_RUN_REAL_ACTIONS
        and os.environ.get("LABFOUNDRY_HELPER_USE_SYSTEMD_RUN") == "1"
        and os.environ.get(SYSTEMD_RUN_CHILD_ENV) != "1"
        and shutil.which("systemd-run") is not None
    )


def _run_real_action_with_systemd(group: str, action: str, args: list[str]) -> int:
    helper_path = str(Path(__file__).resolve())
    command = [
        shutil.which("systemd-run") or "systemd-run",
        "--quiet",
        "--wait",
        "--pipe",
        "--collect",
        "--service-type=exec",
        f"--setenv={SYSTEMD_RUN_CHILD_ENV}=1",
        helper_path,
        group,
        action,
        "--real",
        *args,
    ]
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _chown_path(path: Path, uid: int, gid: int) -> None:
    chown = getattr(os, "chown", None)
    if chown is not None:
        chown(path, uid, gid)


def _usage() -> int:
    groups = ", ".join(sorted(COMMANDS))
    print(f"usage: labfoundry-helper <group> <action> [--real] [path]", file=sys.stderr)
    print(f"groups: {groups}", file=sys.stderr)
