def _install_nginx_include() -> None:
    NGINX_SITES_DIR.mkdir(parents=True, exist_ok=True)
    NGINX_CONF_INCLUDE_PATH.parent.mkdir(parents=True, exist_ok=True)
    include_text = "\n".join(
        [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            f"include {NGINX_SITES_DIR}/*.conf;",
            "",
        ]
    )
    current = NGINX_CONF_INCLUDE_PATH.read_text(encoding="utf-8") if NGINX_CONF_INCLUDE_PATH.exists() else ""
    if current != include_text:
        NGINX_CONF_INCLUDE_PATH.write_text(include_text, encoding="utf-8")
        os.chmod(NGINX_CONF_INCLUDE_PATH, 0o644)
    _ensure_nginx_main_config_includes_labfoundry()


def _http_block_end_offset(text: str) -> int:
    match = re.search(r"(?m)^http\s*\{", text)
    if not match:
        return -1
    depth = 1
    index = match.end()
    while index < len(text):
        char = text[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return index
        index += 1
    return -1


def _ensure_nginx_main_config_includes_labfoundry() -> None:
    if not NGINX_MAIN_CONFIG_PATH.exists():
        return
    text = NGINX_MAIN_CONFIG_PATH.read_text(encoding="utf-8")
    include_line = f"    include {NGINX_CONF_INCLUDE_PATH};"
    if str(NGINX_CONF_INCLUDE_PATH) in text:
        return
    end_offset = _http_block_end_offset(text)
    if end_offset < 0:
        return
    prefix = text[:end_offset].rstrip()
    suffix = text[end_offset:]
    next_text = f"{prefix}\n\n    # Managed by LabFoundry. Local changes may be overwritten.\n{include_line}\n{suffix}"
    tmp_target = NGINX_MAIN_CONFIG_PATH.with_suffix(".conf.tmp")
    tmp_target.write_text(next_text, encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(NGINX_MAIN_CONFIG_PATH)


def _nginx_test_command() -> subprocess.CompletedProcess[str]:
    nginx = _nginx_binary()
    if nginx is None:
        return subprocess.CompletedProcess(["nginx", "-t"], 127, "", "nginx command not found\n")
    return _run([nginx, "-t"])


def _reload_nginx() -> int:
    commands = [["systemctl", "enable", "--now", "nginx"]]
    reload_result = _run(["systemctl", "reload", "nginx"])
    if reload_result.returncode == 0:
        print(reload_result.stdout, end="")
        print(reload_result.stderr, end="", file=sys.stderr)
        return _run_checked_commands(commands)
    commands.append(["systemctl", "restart", "nginx"])
    return _run_checked_commands(commands)


def _nginx_site_metadata(text: str) -> list[tuple[str, set[str]]]:
    metadata: list[tuple[str, set[str]]] = []
    for block in re.findall(r"server\s*\{(?P<body>.*?)\n\}", text, flags=re.DOTALL):
        names: set[str] = set()
        listens: set[str] = set()
        for raw in block.splitlines():
            line = raw.strip().rstrip(";")
            if not line or line.startswith("#"):
                continue
            if line.startswith("server_name "):
                names.update(item for item in line.split()[1:] if item != "_")
            elif line.startswith("listen "):
                value = " ".join(part for part in line.split()[1:] if part not in {"ssl", "http2", "default_server"})
                listens.add(value)
        for name in names:
            metadata.append((name, listens))
    return metadata


def _nginx_site_conflict(site_path: Path, text: str) -> str:
    if not NGINX_SITES_DIR.exists():
        return ""
    candidate = _nginx_site_metadata(text)
    for other_path in NGINX_SITES_DIR.glob("*.conf"):
        if other_path.resolve() == site_path.resolve() or not other_path.is_file():
            continue
        for name, listens in _nginx_site_metadata(other_path.read_text(encoding="utf-8")):
            for candidate_name, candidate_listens in candidate:
                if name == candidate_name and listens.intersection(candidate_listens):
                    return f"nginx site {site_path.name} duplicates server_name {name} on {', '.join(sorted(listens.intersection(candidate_listens)))}."
    return ""


def _install_nginx_site(site_path: Path, text: str) -> int:
    nginx = _nginx_binary()
    if nginx is None:
        print("nginx command not found", file=sys.stderr)
        return 127
    _install_nginx_include()
    conflict = _nginx_site_conflict(site_path, text)
    if conflict:
        print(conflict, file=sys.stderr)
        return 2
    previous = site_path.read_text(encoding="utf-8") if site_path.exists() else None
    site_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_target = site_path.with_suffix(".conf.tmp")
    tmp_target.write_text(text, encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(site_path)
    validation = _nginx_test_command()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        if previous is None:
            site_path.unlink(missing_ok=True)
        else:
            site_path.write_text(previous, encoding="utf-8")
            os.chmod(site_path, 0o644)
        return validation.returncode
    return _reload_nginx()


def _remove_nginx_site(site_path: Path) -> int:
    if not site_path.exists():
        return 0
    _install_nginx_include()
    site_path.unlink()
    validation = _nginx_test_command()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        return validation.returncode
    return _reload_nginx()


def _management_proxy_location(upstream_host: str, upstream_port: int, forwarded_proto: str) -> list[str]:
    return [
        "  client_max_body_size 512m;",
        "  location / {",
        f"    proxy_pass http://{upstream_host}:{upstream_port};",
        "    proxy_http_version 1.1;",
        "    proxy_set_header Host $host;",
        "    proxy_set_header X-Real-IP $remote_addr;",
        "    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;",
        f"    proxy_set_header X-Forwarded-Proto {forwarded_proto};",
        "    proxy_set_header Upgrade $http_upgrade;",
        '    proxy_set_header Connection "upgrade";',
        "  }",
    ]


def _management_nginx_config(payload: dict, cert_path: Path | None = None, key_path: Path | None = None) -> str:
    fqdn = str(payload["fqdn"])
    https_enabled = bool(payload.get("management_https_enabled"))
    public_http_port = int(payload.get("management_public_http_port") or 80)
    public_https_port = int(payload.get("management_public_https_port") or 443)
    upstream_host = str(payload.get("management_upstream_host") or "127.0.0.1")
    upstream_port = int(payload.get("management_upstream_port") or payload.get("management_http_port") or 8000)
    lines = ["# Managed by LabFoundry. Local changes may be overwritten."]
    if not https_enabled:
        lines.extend(
            [
                "server {",
                f"  listen {public_http_port} default_server;",
                f"  server_name {fqdn} _;",
                *_management_proxy_location(upstream_host, upstream_port, "http"),
                "}",
                "",
            ]
        )
        return "\n".join(lines)
    lines.extend(
        [
            "server {",
            f"  listen {public_http_port} default_server;",
            "  server_name _;",
            "  return 308 https://$host$request_uri;",
            "}",
            "",
            "server {",
            f"  listen {public_https_port} ssl default_server;",
            f"  server_name {fqdn};",
            f"  ssl_certificate {cert_path};",
            f"  ssl_certificate_key {key_path};",
            *_management_proxy_location(upstream_host, upstream_port, "https"),
            "}",
            "",
        ]
    )
    return "\n".join(lines)


def _configure_labfoundry_management_https(payload: dict) -> int:
    enabled = bool(payload.get("management_https_enabled"))
    changed = False
    port = int(payload.get("management_upstream_port") or payload.get("management_http_port") or 8000)
    upstream_host = str(payload.get("management_upstream_host") or "127.0.0.1")
    legacy_redirect = _disable_legacy_http_redirect()
    if legacy_redirect != 0:
        return legacy_redirect
    cert_path: Path | None = None
    key_path: Path | None = None
    if enabled:
        cert_path = _ca_managed_path(str(payload["management_https_cert_path"]), "management_https_cert_path")
        key_path = _ca_managed_path(str(payload["management_https_key_path"]), "management_https_key_path")
        _grant_labfoundry_service_key_read(key_path)
    site_apply = _install_nginx_site(NGINX_MANAGEMENT_SITE_PATH, _management_nginx_config(payload, cert_path, key_path))
    if site_apply != 0:
        return site_apply
    next_text = _labfoundry_service_loopback_dropin(upstream_host, port)
    LABFOUNDRY_SERVICE_DROPIN_DIR.mkdir(parents=True, exist_ok=True)
    current_text = LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH.read_text(encoding="utf-8") if LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH.exists() else ""
    if current_text != next_text:
        tmp_target = LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH.with_suffix(".conf.tmp")
        tmp_target.write_text(next_text, encoding="utf-8")
        os.chmod(tmp_target, 0o644)
        tmp_target.replace(LABFOUNDRY_SERVICE_HTTPS_DROPIN_PATH)
        changed = True
    if not changed:
        return 0

    daemon_reload = _run(["systemctl", "daemon-reload"])
    print(daemon_reload.stdout, end="")
    print(daemon_reload.stderr, end="", file=sys.stderr)
    if daemon_reload.returncode != 0:
        return daemon_reload.returncode

    restart_command = ["systemctl", "restart", "labfoundry.service"]
    systemd_run = shutil.which("systemd-run")
    if systemd_run is not None:
        command = [
            systemd_run,
            "--quiet",
            "--collect",
            "--on-active=3",
            "--unit=labfoundry-management-ui-restart",
            *restart_command,
        ]
    else:
        command = restart_command
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _root_ssh_config(enabled: bool) -> str:
    lines = [
        "# Managed by LabFoundry. Local changes may be overwritten.",
        f"PermitRootLogin {'yes' if enabled else 'no'}",
    ]
    if enabled:
        lines.extend(["PasswordAuthentication yes", "KbdInteractiveAuthentication yes"])
    lines.append("")
    return "\n".join(lines)


def _ensure_sshd_dropin_include(*, unset_global_options: set[str] | None = None) -> int:
    include_line = "Include /etc/ssh/sshd_config.d/*.conf"
    unset_options = {option.lower() for option in (unset_global_options or set())}
    try:
        lines = SSHD_MAIN_CONFIG_PATH.read_text(encoding="utf-8").splitlines()
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2

    next_lines: list[str] = []
    include_seen = False
    in_match_block = False
    for line in lines:
        stripped = line.strip()
        lower = stripped.lower()
        if lower == include_line.lower():
            include_seen = True
            continue
        if lower.startswith("match "):
            in_match_block = True
        option = lower.split(None, 1)[0] if lower and not lower.startswith("#") else ""
        if not in_match_block and option in unset_options:
            next_lines.append(f"# LabFoundry manages this directive through {SSHD_ROOT_LOGIN_CONFIG_PATH.name}: {line}")
            continue
        next_lines.append(line)

    insert_at = next((index for index, line in enumerate(next_lines) if line.strip().lower().startswith("match ")), len(next_lines))
    next_lines.insert(insert_at, include_line)
    next_text = "\n".join(next_lines).rstrip() + "\n"
    current_text = SSHD_MAIN_CONFIG_PATH.read_text(encoding="utf-8")
    if include_seen and current_text == next_text:
        return 0
    SSHD_MAIN_CONFIG_PATH.write_text(next_text, encoding="utf-8")
    os.chmod(SSHD_MAIN_CONFIG_PATH, 0o644)
    return 0


def _configure_root_ssh(enabled: bool) -> int:
    SSHD_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    include_result = _ensure_sshd_dropin_include(
        unset_global_options={"PermitRootLogin", "PasswordAuthentication", "KbdInteractiveAuthentication"}
    )
    if include_result != 0:
        return include_result
    previous = SSHD_ROOT_LOGIN_CONFIG_PATH.read_text(encoding="utf-8") if SSHD_ROOT_LOGIN_CONFIG_PATH.exists() else None
    tmp_target = SSHD_ROOT_LOGIN_CONFIG_PATH.with_suffix(".conf.tmp")
    tmp_target.write_text(_root_ssh_config(enabled), encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(SSHD_ROOT_LOGIN_CONFIG_PATH)
    validation = _validate_sshd_config()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        if previous is None:
            SSHD_ROOT_LOGIN_CONFIG_PATH.unlink(missing_ok=True)
        else:
            SSHD_ROOT_LOGIN_CONFIG_PATH.write_text(previous, encoding="utf-8")
            os.chmod(SSHD_ROOT_LOGIN_CONFIG_PATH, 0o644)
        return validation.returncode
    restart = _run(["systemctl", "restart", "sshd"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    return restart.returncode


