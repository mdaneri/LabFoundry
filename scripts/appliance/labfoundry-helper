def _validate_vcf_backups_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("VCF backups config path must end with .conf")
    if not path.is_relative_to(VCF_BACKUPS_APPLY_DIR):
        raise ValueError(f"VCF backups config must be staged under {VCF_BACKUPS_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"VCF backups config does not exist: {path}")
    return path


def _vcf_backups_config_values(path: Path) -> dict[str, str | bool]:
    values: dict[str, str | bool] = {
        "enabled": False,
        "username": "",
        "storage_path": str(VCF_BACKUPS_DEFAULT_STORAGE_PATH),
        "remote_directory": VCF_BACKUPS_DEFAULT_REMOTE_DIRECTORY,
        "chroot_enabled": False,
    }
    in_match = False
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        stripped = raw_line.strip()
        if not stripped:
            continue
        if stripped.startswith("# LabFoundry VCF Backups enabled:"):
            values["enabled"] = stripped.rsplit(":", 1)[1].strip().lower() == "true"
        elif stripped.startswith("# LabFoundry VCF Backups user:"):
            values["username"] = stripped.rsplit(":", 1)[1].strip()
        elif stripped.startswith("# Backup volume mount:"):
            values["storage_path"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("# VCF remote directory:"):
            values["remote_directory"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("Match User "):
            in_match = True
            values["username"] = stripped.split(None, 2)[2].strip()
        elif in_match and stripped.startswith("ChrootDirectory "):
            values["chroot_enabled"] = True
            values["storage_path"] = stripped.split(None, 1)[1].strip()
        elif in_match and stripped.startswith("ForceCommand internal-sftp -d "):
            values["remote_directory"] = stripped.rsplit(" ", 1)[1].strip()
    return values


def _vcf_backups_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return [str(exc)]
    values = _vcf_backups_config_values(path)
    username = str(values["username"])
    storage_path = str(values["storage_path"])
    remote_directory = str(values["remote_directory"])
    if not text.startswith("# Managed by LabFoundry."):
        errors.append("VCF backups config must be rendered by LabFoundry.")
    if values["enabled"]:
        if not VCF_BACKUPS_USERNAME_PATTERN.fullmatch(username):
            errors.append("VCF backups user must be a local Unix username.")
        if not VCF_BACKUPS_PATH_PATTERN.fullmatch(storage_path):
            errors.append("Backup volume mount must be an absolute Linux path with safe characters.")
        if not VCF_BACKUPS_PATH_PATTERN.fullmatch(remote_directory):
            errors.append("VCF remote directory must be an absolute Linux path with safe characters.")
        if remote_directory != VCF_BACKUPS_DEFAULT_REMOTE_DIRECTORY and bool(values["chroot_enabled"]):
            errors.append(f"Chrooted VCF backups must use remote directory {VCF_BACKUPS_DEFAULT_REMOTE_DIRECTORY}.")
        required = [
            f"Match User {username}",
            "ForceCommand internal-sftp",
            "AllowTcpForwarding no",
            "X11Forwarding no",
            "PermitTTY no",
        ]
        for expected in required:
            if expected not in text:
                errors.append(f"VCF backups config is missing {expected}.")
    return errors


def _ensure_vcf_backups_user(username: str, storage_path: Path) -> int:
    if shutil.which("id") is None:
        print("id command not found", file=sys.stderr)
        return 127
    if _run(["id", username]).returncode == 0:
        return 0
    print(f"VCF backups OS user {username} does not exist. Apply the Local Users unit before VCF Backups.", file=sys.stderr)
    return 2


def _prepare_vcf_backups_storage(username: str, storage_path: Path, remote_directory: str, chroot_enabled: bool) -> int:
    storage_path.mkdir(parents=True, exist_ok=True)
    _chown_path(storage_path, 0, 0)
    os.chmod(storage_path, 0o755)
    writable_path = storage_path / remote_directory.strip("/")
    writable_path.mkdir(parents=True, exist_ok=True)
    chown = _run(["chown", username, str(writable_path)])
    print(chown.stdout, end="")
    print(chown.stderr, end="", file=sys.stderr)
    if chown.returncode != 0:
        return chown.returncode
    os.chmod(writable_path, 0o750 if chroot_enabled else 0o755)
    VCF_BACKUPS_AUTHORIZED_KEYS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(VCF_BACKUPS_AUTHORIZED_KEYS_DIR, 0o755)
    authorized_keys = VCF_BACKUPS_AUTHORIZED_KEYS_DIR / username
    if not authorized_keys.exists():
        authorized_keys.write_text("", encoding="utf-8")
    _chown_path(authorized_keys, 0, 0)
    os.chmod(authorized_keys, 0o644)
    return 0


def _install_vcf_backups_sshd_include() -> int:
    config_path = Path("/etc/ssh/sshd_config")
    include_line = "Include /etc/ssh/sshd_config.d/*.conf"
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    if include_line not in text:
        config_path.write_text(f"{include_line}\n{text}", encoding="utf-8")
        os.chmod(config_path, 0o644)
    return 0


def _validate_sshd_config() -> subprocess.CompletedProcess[str]:
    sshd = shutil.which("sshd")
    if sshd is not None:
        return _run([sshd, "-t"])
    else:
        sshd = "/usr/sbin/sshd"
        if not Path(sshd).exists():
            return subprocess.CompletedProcess([sshd, "-t"], 127, "", "sshd command not found\n")
    return _run([sshd, "-t"])


def _handle_vcf_backups(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"vcf-backups {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_vcf_backups_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _vcf_backups_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    values = _vcf_backups_config_values(config_path)
    if action == "validate":
        print(
            json.dumps(
                {
                    "vcf_backups": "validation ok",
                    "enabled": values["enabled"],
                    "username": values["username"],
                    "storage_path": values["storage_path"],
                    "remote_directory": values["remote_directory"],
                    "scope": "OpenSSH SFTP Match User drop-in",
                },
                sort_keys=True,
            )
        )
        return 0

    VCF_BACKUPS_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not values["enabled"]:
        if VCF_BACKUPS_CONFIG_PATH.exists():
            VCF_BACKUPS_CONFIG_PATH.unlink()
        restart = _run(["systemctl", "restart", "sshd"])
        print(restart.stdout, end="")
        print(restart.stderr, end="", file=sys.stderr)
        return restart.returncode

    username = str(values["username"])
    storage_path = Path(str(values["storage_path"]))
    remote_directory = str(values["remote_directory"])
    chroot_enabled = bool(values["chroot_enabled"])
    user_result = _ensure_vcf_backups_user(username, storage_path)
    if user_result != 0:
        return user_result
    storage_result = _prepare_vcf_backups_storage(username, storage_path, remote_directory, chroot_enabled)
    if storage_result != 0:
        return storage_result
    include_result = _install_vcf_backups_sshd_include()
    if include_result != 0:
        return include_result
    shutil.copy2(config_path, VCF_BACKUPS_CONFIG_PATH)
    os.chmod(VCF_BACKUPS_CONFIG_PATH, 0o644)
    validation = _validate_sshd_config()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        VCF_BACKUPS_CONFIG_PATH.unlink(missing_ok=True)
        return validation.returncode
    restart = _run(["systemctl", "restart", "sshd"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    if restart.returncode != 0:
        return restart.returncode
    print(
        json.dumps(
            {
                "vcf_backups": "apply complete",
                "config_path": str(VCF_BACKUPS_CONFIG_PATH),
                "storage_path": str(storage_path),
                "remote_directory": remote_directory,
                "username": username,
            },
            sort_keys=True,
        )
    )
    return 0


def _validate_vcf_depot_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("VCF Offline Depot nginx config path must end with .conf")
    if not path.is_relative_to(VCF_DEPOT_APPLY_DIR):
        raise ValueError(f"VCF Offline Depot nginx config must be staged under {VCF_DEPOT_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"VCF Offline Depot nginx config does not exist: {path}")
    return path


def _nginx_directive(text: str, directive: str) -> list[str]:
    values: list[str] = []
    for match in re.finditer(rf"^\s*{re.escape(directive)}\s+([^;]+);", text, flags=re.MULTILINE):
        values.append(match.group(1).strip())
    return values


def _vcf_depot_config_value(text: str, prefix: str, default: str = "") -> str:
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith(prefix):
            return stripped.removeprefix(prefix).strip()
    return default


def _vcf_depot_auth_required(text: str) -> bool:
    prefix = "# LabFoundry VCF Offline Depot unauthenticated access:"
    unauthenticated = _vcf_depot_config_value(text, prefix, "")
    if unauthenticated.lower() in {"1", "true", "yes", "on"}:
        return False
    if unauthenticated:
        return True
    return bool(_nginx_directive(text, "auth_basic"))


def _vcf_depot_auth_username(text: str) -> str:
    return _vcf_depot_config_value(text, "# LabFoundry VCF Offline Depot user:", VCF_DEPOT_DEFAULT_USERNAME) or VCF_DEPOT_DEFAULT_USERNAME


def _vcf_depot_prod_alias_path(alias: str) -> Path:
    normalized = alias.strip().removesuffix("$1").rstrip("/")
    return Path(normalized)


def _listen_address_and_port(value: str) -> tuple[str, int]:
    parts = value.split()
    listen = parts[0] if parts else ""
    if listen.startswith("[") and "]:" in listen:
        host, port_text = listen.rsplit(":", 1)
        host = host.strip("[]")
    elif ":" in listen:
        host, port_text = listen.rsplit(":", 1)
    else:
        host, port_text = "0.0.0.0", listen
    try:
        port = int(port_text)
    except ValueError as exc:
        raise ValueError(f"nginx listen port is invalid: {listen}") from exc
    if port < 1 or port > 65535:
        raise ValueError(f"nginx listen port must be between 1 and 65535: {listen}")
    try:
        ip_interface(f"{host}/32" if ":" not in host else f"{host}/128")
    except ValueError as exc:
        raise ValueError(f"nginx listen address is invalid: {host}") from exc
    return host, port


def _vcf_depot_config_errors(path: Path) -> list[str]:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return [str(exc)]
    errors: list[str] = []
    if "VCF Offline Depot HTTPS endpoint is disabled" in text:
        return []
    server_names = _nginx_directive(text, "server_name")
    if not server_names:
        errors.append("VCF Offline Depot nginx config must include server_name.")
    else:
        for name in server_names[0].split():
            if not HOSTNAME_PATTERN.fullmatch(name.strip().strip(".").lower()):
                errors.append(f"VCF Offline Depot server_name {name} must be a valid fully qualified DNS name.")
    listens = _nginx_directive(text, "listen")
    if not listens:
        errors.append("VCF Offline Depot nginx config must include listen.")
    for listen in listens:
        try:
            _listen_address_and_port(listen)
        except ValueError as exc:
            errors.append(str(exc))
    roots = _nginx_directive(text, "root")
    if roots:
        errors.append("VCF Offline Depot nginx config must not expose the depot store as a broad server root.")
    aliases = _nginx_directive(text, "alias")
    if not aliases:
        errors.append("VCF Offline Depot nginx config must include a /PROD/ alias.")
    else:
        prod_alias = next((alias for alias in aliases if _vcf_depot_prod_alias_path(alias) == VCF_DEPOT_PROD_PATH), aliases[0])
        if not prod_alias.startswith("/"):
            errors.append("VCF Offline Depot /PROD/ alias must be an absolute path.")
        if not _vcf_depot_prod_alias_path(prod_alias).as_posix().rstrip("/").endswith("/PROD"):
            errors.append("VCF Offline Depot /PROD/ alias must point at the depot store PROD directory.")
        if _vcf_depot_prod_alias_path(prod_alias) != VCF_DEPOT_PROD_PATH:
            errors.append(f"VCF Offline Depot /PROD/ alias must point at {VCF_DEPOT_PROD_PATH}.")
    for required in [
        "location = / {",
        "location ^~ /static/",
        "location = /favicon.ico",
        "location = /manifest.webmanifest",
        "location = /service-worker.js",
        "location = /PROD",
        "return 301 /PROD/;",
        "location = /PROD/login",
        "location = /PROD/logout",
        "location = /PROD/",
        "location ~ ^/PROD/.*/$",
        "location ~ ^/PROD/(?!login$|logout$|auth-check$)(.+[^/])$",
        "location /",
        "return 404;",
    ]:
        if required not in text:
            errors.append(f"VCF Offline Depot nginx config must include {required}.")
    for directive, label, private in [
        ("ssl_certificate", "VCF Offline Depot certificate", False),
        ("ssl_certificate_key", "VCF Offline Depot private key", True),
    ]:
        values = _nginx_directive(text, directive)
        if not values:
            errors.append(f"VCF Offline Depot nginx config must include {directive}.")
            continue
        try:
            cert_path = _ca_managed_path(values[0], directive)
            if not cert_path.is_file():
                errors.append(f"{label} does not exist: {cert_path}")
            else:
                errors.extend(_pem_errors(cert_path.read_text(encoding="utf-8"), label, private_key=private))
        except (OSError, ValueError) as exc:
            errors.append(str(exc))
    if "sendfile on;" not in text:
        errors.append("VCF Offline Depot nginx config must enable sendfile for static artifact serving.")
    if "default_type application/octet-stream;" not in text:
        errors.append("VCF Offline Depot nginx config must set default_type application/octet-stream.")
    if _vcf_depot_auth_required(text):
        username = _vcf_depot_auth_username(text)
        if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username):
            errors.append(f"VCF Offline Depot HTTP user {username} is invalid.")
        if "location = /_labfoundry_depot_auth" not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must include the LabFoundry auth-check location.")
        if "auth_request /_labfoundry_depot_auth;" not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must protect /PROD/ with auth_request.")
        if "satisfy any;" not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must allow browser sessions or HTTPS Basic Authentication.")
        if 'auth_basic "VCF Offline Depot";' not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must enable HTTPS Basic Authentication.")
        if f"auth_basic_user_file {VCF_DEPOT_HTPASSWD_PATH};" not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must use the managed password file.")
        if "error_page 401 = /_labfoundry_depot_login;" not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must redirect unauthenticated requests to the depot login.")
        if "proxy_pass http://127.0.0.1:8000/PROD/auth-failure;" not in text:
            errors.append("Authenticated VCF Offline Depot nginx config must return 401 to non-browser clients.")
    elif _nginx_directive(text, "auth_basic_user_file"):
        errors.append("Unauthenticated VCF Offline Depot nginx config must not include auth_basic_user_file.")
    return errors


def _ensure_vcf_depot_user(username: str) -> int:
    try:
        pwd.getpwnam(username)
    except KeyError:
        print(f"VCF Offline Depot OS user {username} does not exist. Apply the Local Users unit before VCF Offline Depot.", file=sys.stderr)
        return 2
    return 0


def _shadow_hash_for_user(username: str) -> str:
    try:
        text = VCF_DEPOT_SHADOW_PATH.read_text(encoding="utf-8")
    except OSError as exc:
        raise ValueError(f"Cannot read {VCF_DEPOT_SHADOW_PATH}: {exc}") from exc
    for line in text.splitlines():
        fields = line.split(":")
        if len(fields) >= 2 and fields[0] == username:
            password_hash = fields[1].strip()
            if not password_hash or password_hash.startswith("!") or password_hash.startswith("*"):
                raise ValueError(f"VCF Offline Depot OS user {username} does not have an active password hash. Apply Local Users after setting a password.")
            return password_hash
    raise ValueError(f"VCF Offline Depot OS user {username} is missing from {VCF_DEPOT_SHADOW_PATH}.")


def _write_vcf_depot_htpasswd(username: str) -> int:
    try:
        password_hash = _shadow_hash_for_user(username)
        _write_vcf_depot_htpasswd_entry(username, password_hash)
    except (OSError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    return 0


def _write_vcf_depot_htpasswd_entry(username: str, password_hash: str) -> None:
    temp_path: Path | None = None
    try:
        VCF_DEPOT_HTPASSWD_PATH.parent.mkdir(parents=True, exist_ok=True)
        try:
            grp.getgrnam("nginx")
            shutil.chown(VCF_DEPOT_HTPASSWD_PATH.parent, user="root", group="nginx")
            dir_mode = 0o750
            file_mode = 0o640
            file_group = "nginx"
        except KeyError:
            dir_mode = 0o755
            file_mode = 0o644
            file_group = None
        os.chmod(VCF_DEPOT_HTPASSWD_PATH.parent, dir_mode)
        with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=str(VCF_DEPOT_HTPASSWD_PATH.parent), delete=False) as handle:
            temp_path = Path(handle.name)
            handle.write(f"{username}:{password_hash}\n")
        if file_group:
            shutil.chown(temp_path, user="root", group=file_group)
        else:
            shutil.chown(temp_path, user="root")
        os.chmod(temp_path, file_mode)
        temp_path.replace(VCF_DEPOT_HTPASSWD_PATH)
    finally:
        if temp_path is not None and temp_path.exists():
            temp_path.unlink(missing_ok=True)


def _refresh_existing_vcf_depot_htpasswd() -> int:
    if not VCF_DEPOT_HTPASSWD_PATH.is_file():
        return 0
    try:
        username = VCF_DEPOT_HTPASSWD_PATH.read_text(encoding="utf-8").split(":", 1)[0].strip()
        if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username):
            raise ValueError("VCF Offline Depot managed password file has an invalid username.")
        try:
            password_hash = _shadow_hash_for_user(username)
        except ValueError:
            password_hash = "!"
        _write_vcf_depot_htpasswd_entry(username, password_hash)
    except (OSError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    return 0


def _remove_vcf_depot_htpasswd() -> None:
    try:
        VCF_DEPOT_HTPASSWD_PATH.unlink(missing_ok=True)
    except OSError:
        pass


def _prepare_vcf_depot_web_tree(text: str) -> None:
    for alias in _nginx_directive(text, "alias"):
        path = _vcf_depot_prod_alias_path(alias)
        if path != VCF_DEPOT_PROD_PATH:
            continue
        path.mkdir(parents=True, exist_ok=True)
        path.chmod(path.stat().st_mode | 0o755)
        for root, dirs, files in os.walk(path):
            root_path = Path(root)
            if root_path.is_symlink():
                continue
            root_path.chmod(root_path.stat().st_mode | 0o755)
            for dirname in dirs:
                child = root_path / dirname
                if not child.is_symlink():
                    child.chmod(child.stat().st_mode | 0o755)
            for filename in files:
                child = root_path / filename
                if not child.is_symlink():
                    child.chmod(child.stat().st_mode | 0o644)


def _safe_extract_archive(archive_path: Path, destination: Path) -> None:
    destination_resolved = destination.resolve()
    if destination.exists():
        shutil.rmtree(destination)
    destination.mkdir(parents=True, exist_ok=True)
    with tarfile.open(archive_path, "r:gz") as archive:
        for member in archive.getmembers():
            target = (destination / member.name).resolve()
            if target != destination_resolved and destination_resolved not in target.parents:
                raise ValueError("VCF Download Tool archive contains an unsafe path.")
        archive.extractall(destination, filter="data")


def _prepare_vcf_download_tool_tree(extraction_dir: Path) -> None:
    for root, dirs, files in os.walk(extraction_dir):
        root_path = Path(root)
        if root_path.is_symlink():
            continue
        root_path.chmod(0o755)
        for dirname in dirs:
            child = root_path / dirname
            if not child.is_symlink():
                child.chmod(0o755)
        for filename in files:
            child = root_path / filename
            if child.is_symlink():
                continue
            mode = child.stat().st_mode
            child.chmod(0o755 if mode & 0o111 else 0o644)


def _find_vcf_download_tool_binary(extraction_dir: Path) -> Path:
    for candidate in [extraction_dir / "vcf-download-tool", extraction_dir / "bin" / "vcf-download-tool"]:
        if candidate.is_file():
            return candidate
    for candidate in extraction_dir.rglob("vcf-download-tool"):
        if candidate.is_file():
            return candidate
    raise FileNotFoundError("VCF Download Tool archive does not contain a vcf-download-tool executable.")


def _parse_vcf_download_tool_version(output: str) -> str:
    match = re.search(r"\b\d+(?:\.\d+){2,}(?:[-+][A-Za-z0-9._-]+)?\b", output or "")
    return match.group(0) if match else ""


def _vcf_download_tool_version(tool_path: Path) -> str:
    try:
        completed = _run_vcfdt_user_command([str(tool_path), "--version"])
    except (KeyError, OSError):
        return ""
    return _parse_vcf_download_tool_version("\n".join(part for part in [completed.stdout, completed.stderr] if part))


def _remove_retired_vcf_download_tool_tree(path: Path) -> None:
    for attempt in range(3):
        try:
            shutil.rmtree(path)
            return
        except FileNotFoundError:
            return
        except OSError:
            if attempt == 2:
                print(f"warning: unable to remove retired VCF Download Tool runtime: {path}", file=sys.stderr)
                return
            time.sleep(0.1 * (attempt + 1))


def _replace_vcf_download_tool_runtime(tool_home: Path) -> tuple[Path, Path]:
    runtime_tool_home = VCF_DEPOT_RUNTIME_TOOL_DIR
    runtime_parent = runtime_tool_home.parent
    runtime_parent.mkdir(parents=True, exist_ok=True)
    replacement = Path(tempfile.mkdtemp(prefix=f".{runtime_tool_home.name}.staging-", dir=str(runtime_parent)))
    retired: Path | None = None
    try:
        for child in tool_home.iterdir():
            target = replacement / child.name
            if child.is_dir():
                shutil.copytree(child, target, dirs_exist_ok=True)
            else:
                shutil.copy2(child, target)
        if runtime_tool_home.is_dir():
            for preserved_name in ["log", "secrets"]:
                preserved = runtime_tool_home / preserved_name
                if preserved.is_dir():
                    shutil.copytree(preserved, replacement / preserved_name, dirs_exist_ok=True)

        replacement_tool_path = _find_vcf_download_tool_binary(replacement)
        runtime_tool_path = runtime_tool_home / replacement_tool_path.relative_to(replacement)
        runtime_wrapper_path = runtime_tool_home / "vcf-download-tool"
        if runtime_tool_path == runtime_wrapper_path:
            replacement_preserved_path = replacement / "vcf-download-tool.real"
            replacement_tool_path.replace(replacement_preserved_path)
            runtime_tool_path = runtime_tool_home / replacement_preserved_path.relative_to(replacement)
        (replacement / "vcf-download-tool").write_text(
            "\n".join(
                [
                    "#!/bin/sh",
                    f"cd {shlex_quote(str(_vcf_download_tool_home(runtime_tool_path)))} || exit 1",
                    f"exec {shlex_quote(str(runtime_tool_path))} \"$@\"",
                    "",
                ]
            ),
            encoding="utf-8",
        )
        os.chmod(replacement / "vcf-download-tool", 0o755)

        try:
            account = pwd.getpwnam(LABFOUNDRY_SERVICE_USER)
        except KeyError:
            account = None
        if account is not None:
            for runtime_path in [replacement, *replacement.rglob("*")]:
                _chown_path(runtime_path, account.pw_uid, account.pw_gid)

        if runtime_tool_home.exists():
            retired = Path(tempfile.mkdtemp(prefix=f".{runtime_tool_home.name}.retired-", dir=str(runtime_parent)))
            retired.rmdir()
            runtime_tool_home.replace(retired)
        try:
            replacement.replace(runtime_tool_home)
        except OSError:
            if retired is not None and retired.exists() and not runtime_tool_home.exists():
                retired.replace(runtime_tool_home)
                retired = None
            raise
    except Exception:
        if replacement.exists():
            shutil.rmtree(replacement, ignore_errors=True)
        raise

    if retired is not None:
        _remove_retired_vcf_download_tool_tree(retired)
    return runtime_tool_home, runtime_tool_path


def _stage_vcf_download_tool_archive(archive_path: Path) -> int:
    extraction_dir = VCF_DEPOT_TOOL_DIR / "extracted"
    try:
        _safe_extract_archive(archive_path, extraction_dir)
        _prepare_vcf_download_tool_tree(extraction_dir)
        tool_path = _find_vcf_download_tool_binary(extraction_dir)
    except (OSError, tarfile.TarError, ValueError, FileNotFoundError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    tool_path.chmod(0o755)
    wrapper_path = VCF_DEPOT_TOOL_DIR / "vcf-download-tool"
    tool_home = _vcf_download_tool_home(tool_path)
    wrapper_path.write_text(
        "\n".join(
            [
                "#!/bin/sh",
                f"cd {shlex_quote(str(tool_home))} || exit 1",
                f"exec {shlex_quote(str(tool_path))} \"$@\"",
                "",
            ]
        ),
        encoding="utf-8",
    )
    os.chmod(wrapper_path, 0o755)
    try:
        runtime_tool_home, runtime_tool_path = _replace_vcf_download_tool_runtime(tool_home)
    except (OSError, FileNotFoundError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    runtime_wrapper_path = runtime_tool_home / "vcf-download-tool"
    tool_version = _vcf_download_tool_version(runtime_wrapper_path)
    print(
        json.dumps(
            {
                "vcf_offline_depot": "stage-tool complete",
                "archive": archive_path.name,
                "tool_home": str(VCF_DEPOT_TOOL_DIR),
                "executable": str(wrapper_path),
                "runtime_executable": str(runtime_wrapper_path),
                "tool_version": tool_version,
                "version_command": "vcf-download-tool --version",
            },
            sort_keys=True,
        )
    )
    return 0


def _reset_vcf_download_tool_runtime() -> int:
    for directory in [VCF_DEPOT_TOOL_DIR, VCF_DEPOT_RUNTIME_TOOL_DIR]:
        if directory.exists():
            shutil.rmtree(directory)
    VCF_DEPOT_RUNTIME_TOOL_DIR.mkdir(parents=True, exist_ok=True)
    runtime_secrets_dir = VCF_DEPOT_RUNTIME_TOOL_DIR / "secrets"
    runtime_secrets_dir.mkdir(parents=True, exist_ok=True)
    os.chmod(VCF_DEPOT_RUNTIME_TOOL_DIR, 0o750)
    os.chmod(runtime_secrets_dir, 0o700)
    try:
        account = pwd.getpwnam(LABFOUNDRY_SERVICE_USER)
    except KeyError:
        account = None
    if account is not None:
        _chown_path(VCF_DEPOT_RUNTIME_TOOL_DIR, account.pw_uid, account.pw_gid)
        _chown_path(runtime_secrets_dir, account.pw_uid, account.pw_gid)
    print(json.dumps({"vcf_offline_depot": "tool runtime reset complete"}, sort_keys=True))
    return 0


def _parse_software_depot_id(output: str) -> str:
    uuid_match = re.search(r"\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\b", output)
    if uuid_match:
        return uuid_match.group(0)
    for line in output.splitlines():
        stripped = line.strip()
        if "vcf-download-tool" in stripped:
            continue
        if "software" in stripped.lower() and "depot" in stripped.lower() and "id" in stripped.lower():
            match = re.search(r"([A-Za-z0-9][A-Za-z0-9._:-]{7,})\s*$", stripped)
            if match:
                return match.group(1)
    for line in output.splitlines():
        stripped = line.strip()
        if re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._:-]{7,}", stripped) and "vcf-download-tool" not in stripped:
            return stripped
    return ""


def _generate_vcf_download_tool_software_depot_id() -> int:
    wrapper_path = VCF_DEPOT_RUNTIME_TOOL_DIR / "vcf-download-tool"
    if not wrapper_path.is_file():
        print(f"VCF Download Tool executable does not exist: {wrapper_path}", file=sys.stderr)
        return 2
    command = [str(wrapper_path), "configuration", "generate", "--software-depot-id"]
    try:
        completed = _run_vcfdt_user_command(command, input_text="Y\n")
    except KeyError:
        print("labfoundry service user does not exist.", file=sys.stderr)
        return 2
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    output = "\n".join(part for part in [completed.stdout, completed.stderr] if part)
    software_depot_id = _parse_software_depot_id(output)
    if completed.returncode != 0:
        print(f"VCFDT exited with code {completed.returncode}.", file=sys.stderr)
        return completed.returncode
    if not software_depot_id:
        print("VCFDT did not print a software depot ID.", file=sys.stderr)
        return 2
    print(
        json.dumps(
            {
                "vcf_offline_depot": "software depot ID generated",
                "software_depot_id": software_depot_id,
                "command": "vcf-download-tool configuration generate --software-depot-id",
            },
            sort_keys=True,
        )
    )
    return 0


def _vcf_download_tool_home(tool_path: Path) -> Path:
    return tool_path.parent.parent if tool_path.parent.name == "bin" else tool_path.parent


def _validate_vcf_depot_properties_path(raw_path: str) -> Path:
    path = Path(raw_path).resolve()
    apply_dir = VCF_DEPOT_APPLY_DIR.resolve()
    if not path.is_relative_to(apply_dir):
        raise ValueError(f"VCF Download Tool application properties must be staged under {VCF_DEPOT_APPLY_DIR}")
    if path.name != "application-prodv2.properties":
        raise ValueError("VCF Download Tool application properties must be named application-prodv2.properties")
    if not path.is_file():
        raise ValueError(f"VCF Download Tool application properties file does not exist: {path}")
    return path


def _apply_vcf_download_tool_properties(properties_path: Path) -> int:
    extraction_dir = VCF_DEPOT_TOOL_DIR / "extracted"
    try:
        tool_path = _find_vcf_download_tool_binary(extraction_dir)
    except FileNotFoundError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    text = properties_path.read_text(encoding="utf-8")
    if not text.strip():
        print("VCF Download Tool application properties cannot be empty.", file=sys.stderr)
        return 2
    target_paths = [
        _vcf_download_tool_home(tool_path) / "conf" / "application-prodv2.properties",
        VCF_DEPOT_RUNTIME_TOOL_DIR / "conf" / "application-prodv2.properties",
    ]
    runtime_secrets_dir = VCF_DEPOT_RUNTIME_TOOL_DIR / "secrets"
    runtime_secrets_dir.mkdir(parents=True, exist_ok=True)
    os.chmod(runtime_secrets_dir, 0o700)
    for target_path in target_paths:
        target_path.parent.mkdir(parents=True, exist_ok=True)
        target_path.write_text(text, encoding="utf-8")
        os.chmod(target_path, 0o640)
    try:
        account = pwd.getpwnam(LABFOUNDRY_SERVICE_USER)
    except KeyError:
        account = None
    if account is not None:
        _chown_path(VCF_DEPOT_RUNTIME_TOOL_DIR, account.pw_uid, account.pw_gid)
        _chown_path(runtime_secrets_dir, account.pw_uid, account.pw_gid)
        for target_path in target_paths:
            _chown_path(target_path.parent, account.pw_uid, account.pw_gid)
            _chown_path(target_path, account.pw_uid, account.pw_gid)
    print(
        json.dumps(
            {
                "vcf_offline_depot": "application properties apply complete",
                "config_path": str(target_paths[0]),
                "runtime_config_path": str(target_paths[1]),
            },
            sort_keys=True,
        )
    )
    return 0


def shlex_quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"


def _handle_vcf_offline_depot(action: str, args: list[str]) -> int:
    if action == "reset-tool":
        if args:
            print("vcf-offline-depot reset-tool does not accept arguments", file=sys.stderr)
            return 2
        return _reset_vcf_download_tool_runtime()
    if action == "stage-tool":
        if len(args) != 1:
            print("vcf-offline-depot stage-tool requires exactly one archive path", file=sys.stderr)
            return 2
        archive_path = Path(args[0])
        if not archive_path.is_file():
            print(f"VCF Download Tool archive does not exist: {archive_path}", file=sys.stderr)
            return 2
        if not archive_path.name.startswith("vcf-download-tool-") or not archive_path.name.endswith(".tar.gz"):
            print("VCF Download Tool archive must be named vcf-download-tool-*.tar.gz.", file=sys.stderr)
            return 2
        return _stage_vcf_download_tool_archive(archive_path)

    if action == "generate-software-depot-id":
        if args:
            print("vcf-offline-depot generate-software-depot-id does not accept arguments", file=sys.stderr)
            return 2
        return _generate_vcf_download_tool_software_depot_id()

    if action == "apply-properties":
        if len(args) != 1:
            print("vcf-offline-depot apply-properties requires exactly one staged application properties path", file=sys.stderr)
            return 2
        try:
            properties_path = _validate_vcf_depot_properties_path(args[0])
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            return 2
        return _apply_vcf_download_tool_properties(properties_path)

    if len(args) != 1:
        print(f"vcf-offline-depot {action} requires exactly one staged nginx config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_vcf_depot_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _vcf_depot_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    text = config_path.read_text(encoding="utf-8")
    disabled = "VCF Offline Depot HTTPS endpoint is disabled" in text

    if action == "validate":
        print(
            json.dumps(
                {
                    "vcf_offline_depot": "validation ok",
                    "enabled": not disabled,
                    "scope": "nginx HTTPS static file server",
                },
                sort_keys=True,
            )
        )
        return 0
    if action == "sync":
        print(json.dumps({"vcf_offline_depot": "sync command intent recorded", "enabled": not disabled}, sort_keys=True))
        return 0
    if action == "apply-https":
        if disabled:
            _remove_vcf_depot_htpasswd()
            result = _remove_nginx_site(VCF_DEPOT_SITE_PATH)
        else:
            if _vcf_depot_auth_required(text):
                username = _vcf_depot_auth_username(text)
                if username and _write_vcf_depot_htpasswd(username) != 0:
                    return 2
            else:
                _remove_vcf_depot_htpasswd()
            _prepare_vcf_depot_web_tree(text)
            result = _install_nginx_site(VCF_DEPOT_SITE_PATH, text)
        if result != 0:
            return result
        print(
            json.dumps(
                {
                    "vcf_offline_depot": "https apply complete",
                    "enabled": not disabled,
                    "config_path": str(VCF_DEPOT_SITE_PATH),
                },
                sort_keys=True,
            )
        )
        return 0

    print(f"unsupported vcf-offline-depot action: {action}", file=sys.stderr)
    return 2


def _load_appliance_update_config(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    if not isinstance(payload, dict):
        raise ValueError("appliance update config must be a JSON object")
    return payload


def _load_appliance_update_credentials(args: list[str]) -> dict[str, dict[str, str]]:
    if len(args) < 2:
        return {}
    path = Path(args[1])
    if not path.is_relative_to(APPLIANCE_UPDATE_APPLY_DIR) or path.name != "labfoundry-update-credentials.json":
        raise ValueError("appliance update credentials must use the protected staged credentials path")
    payload = json.loads(path.read_text(encoding="utf-8"))
    sources = payload.get("sources") if isinstance(payload, dict) else None
    if not isinstance(sources, dict):
        raise ValueError("appliance update credentials must contain a sources object")
    return {
        str(source_id): {"username": str(value.get("username") or ""), "secret": str(value.get("secret") or "")}
        for source_id, value in sources.items()
        if isinstance(value, dict) and str(value.get("secret") or "")
    }


def _appliance_update_config_errors(payload: dict, *, require_streams: bool = True) -> list[str]:
    errors: list[str] = []
    selected = payload.get("selected_streams")
    if not isinstance(selected, list) or (require_streams and not selected):
        errors.append("selected_streams must include at least one update stream.")
    else:
        allowed = {"photon_os", "python_libraries", "powershell_modules", "labfoundry_wheel"}
        for stream in selected:
            if stream not in allowed:
                errors.append(f"unsupported update stream {stream}.")
    sources = payload.get("sources")
    if not isinstance(sources, dict):
        errors.append("sources must be an object.")
        return errors
    manifest_urls_value = sources.get("labfoundry_manifest_urls")
    manifest_urls = (
        [str(value).strip() for value in manifest_urls_value if str(value).strip()]
        if isinstance(manifest_urls_value, list)
        else []
    )
    manifest_url = str(sources.get("labfoundry_manifest_url") or "").strip()
    if not manifest_urls and manifest_url:
        manifest_urls = [manifest_url]
    if "labfoundry_wheel" in (selected or []):
        if not manifest_urls:
            errors.append("at least one labfoundry manifest URL is required when LabFoundry Wheel is selected.")
        for value in manifest_urls:
            parsed = urlparse(value)
            if parsed.scheme not in {"http", "https"} or not parsed.netloc:
                errors.append("each labfoundry manifest URL must be an http or https URL.")
            if parsed.username or parsed.password:
                errors.append("labfoundry manifest URLs must not include embedded credentials.")
    python_urls_value = sources.get("python_index_urls")
    python_urls = (
        [str(value).strip() for value in python_urls_value if str(value).strip()]
        if isinstance(python_urls_value, list)
        else []
    )
    python_index_url = str(sources.get("python_index_url") or "").strip()
    if not python_urls and python_index_url:
        python_urls = [python_index_url]
    for value in python_urls:
        parsed = urlparse(value)
        if parsed.scheme not in {"http", "https"} or not parsed.netloc:
            errors.append("each python index URL must be an http or https URL.")
        if parsed.username or parsed.password:
            errors.append("python index URLs must not include embedded credentials.")
    powershell_repository_url = str(sources.get("powershell_repository_url") or "").strip()
    powershell_repository_name = str(sources.get("powershell_repository_name") or "").strip()
    if "powershell_modules" in (selected or []) and not powershell_repository_url:
        errors.append("powershell_repository_url is required when PowerShell Modules is selected.")
    if powershell_repository_url:
        parsed = urlparse(powershell_repository_url)
        if parsed.scheme not in {"http", "https"} or not parsed.netloc:
            errors.append("powershell_repository_url must be an http or https URL.")
        if parsed.username or parsed.password:
            errors.append("powershell_repository_url must not include embedded credentials.")
    requirements = payload.get("python_requirements", [])
    if requirements and (not isinstance(requirements, list) or not all(isinstance(item, str) and item.strip() for item in requirements)):
        errors.append("python_requirements must be a list of requirement strings.")
    powershell_modules = payload.get("powershell_modules", [])
    if powershell_modules and (
        not isinstance(powershell_modules, list)
        or not all(
            isinstance(item, dict)
            and str(item.get("name") or "").strip()
            and str(item.get("repository_name") or powershell_repository_name).strip()
            for item in powershell_modules
        )
    ):
        errors.append("powershell_modules must be a list of module objects with names and repositories.")
    return errors


def _appliance_update_python() -> str:
    return str(LABFOUNDRY_VENV_PYTHON_PATH if LABFOUNDRY_VENV_PYTHON_PATH.exists() else sys.executable)


def _command_payload(
    command: list[str], *, success_codes: set[int] | None = None, env: dict[str, str] | None = None
) -> dict:
    result = _run(command, env=env) if env is not None else _run(command)
    success_codes = success_codes or {0}
    stdout = result.stdout[-4000:]
    stderr = result.stderr[-4000:]
    if env:
        sensitive_values = [str(env.get("LF_REPO_USER") or ""), str(env.get("LF_REPO_SECRET") or "")]
        for key in ("PIP_INDEX_URL", "PIP_EXTRA_INDEX_URL"):
            for value in str(env.get(key) or "").split():
                parsed = urlparse(value)
                sensitive_values.extend([value, unquote(parsed.username or ""), unquote(parsed.password or "")])
        for value in sorted({value for value in sensitive_values if value}, key=len, reverse=True):
            stdout = stdout.replace(value, "[redacted]")
            stderr = stderr.replace(value, "[redacted]")
    return {
        "command": command,
        "returncode": result.returncode,
        "success": result.returncode in success_codes,
        "stdout": stdout,
        "stderr": stderr,
    }


def _fetch_http_bytes(url: str, credential: dict[str, str] | None = None) -> bytes:
    parsed = urlparse(url)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc:
        raise ValueError(f"unsupported update URL: {url}")
    request: str | Request = url
    if credential and str(credential.get("secret") or ""):
        token = base64.b64encode(
            f"{credential.get('username', '')}:{credential['secret']}".encode("utf-8")
        ).decode("ascii")
        request = Request(url, headers={"Authorization": f"Basic {token}"})
    with urlopen(request, timeout=60) as response:
        return response.read()


def _download_labfoundry_update_manifest(
    manifest_url: str, credential: dict[str, str] | None = None
) -> dict:
    raw = _fetch_http_bytes(manifest_url, credential) if credential else _fetch_http_bytes(manifest_url)
    try:
        payload = json.loads(raw.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise ValueError(f"LabFoundry manifest is not valid JSON: {exc}") from exc
    if not isinstance(payload, dict):
        raise ValueError("LabFoundry manifest must be a JSON object")
    for key in ("version", "git_commit", "wheel", "sha256"):
        if not str(payload.get(key) or "").strip():
            raise ValueError(f"LabFoundry manifest missing {key}")
    if not re.fullmatch(r"[0-9a-fA-F]{40}", str(payload["git_commit"])):
        raise ValueError("LabFoundry manifest git_commit must be a full 40-character hexadecimal commit")
    if not re.fullmatch(r"[0-9a-fA-F]{64}", str(payload["sha256"])):
        raise ValueError("LabFoundry manifest sha256 must be a 64-character hex digest")
    return payload


def _source_credential(source: dict, credentials: dict[str, dict[str, str]]) -> dict[str, str] | None:
    credential = credentials.get(str(source.get("id") or ""))
    return credential if isinstance(credential, dict) and str(credential.get("secret") or "") else None


def _authenticated_url(url: str, credential: dict[str, str] | None) -> str:
    if not credential:
        return url
    parsed = urlparse(url)
    username = quote(str(credential.get("username") or ""), safe="")
    secret = quote(str(credential.get("secret") or ""), safe="")
    host = parsed.hostname or ""
    if parsed.port:
        host = f"{host}:{parsed.port}"
    return parsed._replace(netloc=f"{username}:{secret}@{host}").geturl()


def _enabled_sources(payload: dict, kind: str) -> list[dict]:
    definitions = payload.get("source_definitions") or []
    return [
        source for source in definitions
        if isinstance(source, dict) and source.get("kind") == kind and source.get("enabled") is True
    ]


def _python_index_urls(payload: dict) -> list[str]:
    sources = payload.get("sources") or {}
    configured = sources.get("python_index_urls")
    if isinstance(configured, list):
        urls = [str(value).strip() for value in configured if str(value).strip()]
        if urls:
            return urls
    legacy = str(sources.get("python_index_url") or "").strip()
    return [legacy] if legacy else []


def _python_source_pairs(payload: dict) -> list[tuple[str, dict]]:
    pairs = [
        (str(source.get("url") or "").strip(), source)
        for source in _enabled_sources(payload, "python")
        if str(source.get("url") or "").strip()
    ]
    if pairs:
        return pairs
    return [(url, {}) for url in _python_index_urls(payload)]


def _labfoundry_manifest_sources(payload: dict) -> list[tuple[str, dict]]:
    definitions = _enabled_sources(payload, "labfoundry")
    pairs: list[tuple[str, dict]] = []
    for source in definitions:
        base = str(source.get("url") or "").strip()
        if not base:
            continue
        settings = source.get("settings") if isinstance(source.get("settings"), dict) else {}
        channel = str(settings.get("channel") or "stable")
        url = base if base.lower().endswith(".json") else f"{base.rstrip('/')}/channels/{channel}/manifest.json"
        pairs.append((url, source))
    if pairs:
        return pairs
    sources = payload.get("sources") or {}
    configured = sources.get("labfoundry_manifest_urls")
    urls = [str(value).strip() for value in configured if str(value).strip()] if isinstance(configured, list) else []
    if not urls:
        legacy = str(sources.get("labfoundry_manifest_url") or "").strip()
        urls = [legacy] if legacy else []
    return [(url, {}) for url in urls]


def _download_labfoundry_manifest_from_sources(
    payload: dict, credentials: dict[str, dict[str, str]]
) -> tuple[dict, str, dict[str, str] | None]:
    failures: list[str] = []
    for manifest_url, source in _labfoundry_manifest_sources(payload):
        credential = _source_credential(source, credentials)
        try:
            return _download_labfoundry_update_manifest(manifest_url, credential), manifest_url, credential
        except Exception as exc:  # noqa: BLE001 - ordered repositories are explicit failover sources.
            failures.append(f"{manifest_url}: {exc}")
    raise ValueError("No enabled LabFoundry manifest source succeeded: " + " ; ".join(failures))


def _restore_labfoundry_venv_permissions() -> None:
    venv = LABFOUNDRY_VENV_PYTHON_PATH.parents[1]
    if not venv.exists():
        return
    for root, dirs, files in os.walk(venv):
        for dirname in dirs:
            try:
                Path(root, dirname).chmod(0o755)
            except OSError:
                pass
        for filename in files:
            path = Path(root, filename)
            mode = 0o755 if path.parent.name == "bin" else 0o644
            try:
                path.chmod(mode)
            except OSError:
                pass


def _write_update_info(info: dict) -> None:
    APPLIANCE_UPDATE_INFO_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = APPLIANCE_UPDATE_INFO_PATH.with_suffix(".tmp")
    tmp_path.write_text(json.dumps(info, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    tmp_path.chmod(0o644)
    tmp_path.replace(APPLIANCE_UPDATE_INFO_PATH)


def _powershell_encoded_command(script: str) -> str:
    return base64.b64encode(script.encode("utf-16-le")).decode("ascii")


def _powershell_literal(value: str) -> str:
    return "'" + value.replace("'", "''") + "'"


def _sync_appliance_update_sources(payload: dict, credentials: dict[str, dict[str, str]] | None = None) -> dict:
    credentials = credentials or {}
    definitions = payload.get("source_definitions") or []
    if not isinstance(definitions, list):
        raise ValueError("source_definitions must be a list")
    commands: list[dict] = []

    managed_photon = [
        source
        for source in definitions
        if isinstance(source, dict)
        and source.get("kind") == "photon"
        and source.get("enabled") is True
        and isinstance(source.get("settings"), dict)
        and source["settings"].get("managed") is True
    ]
    photon_path = MANAGED_PHOTON_REPO_PATH
    if managed_photon:
        sections: list[str] = []
        for source in managed_photon:
            source_id = re.sub(r"[^a-z0-9_.-]+", "-", str(source.get("name") or "labfoundry").lower()).strip("-")
            if not source_id:
                raise ValueError("managed Photon source name must contain a usable repository identifier")
            source_url = str(source.get("url") or "").strip()
            parsed = urlparse(source_url)
            if parsed.scheme not in {"http", "https"} or not parsed.netloc:
                raise ValueError(f"managed Photon source {source_id} must use an HTTP(S) base URL")
            settings = source["settings"]
            lines = [
                f"[{source_id}]",
                f"name={source.get('name') or source_id}",
                f"baseurl={source_url}",
                "enabled=1",
                f"gpgcheck={1 if settings.get('gpgcheck', True) else 0}",
                f"sslverify={1 if settings.get('tls_verify', True) else 0}",
            ]
            if str(settings.get("gpgkey") or "").strip():
                lines.append(f"gpgkey={str(settings['gpgkey']).strip()}")
            credential = _source_credential(source, credentials)
            if credential:
                if any(character in str(credential.get("username") or "") + str(credential["secret"]) for character in "\r\n"):
                    raise ValueError(f"managed Photon source {source_id} credentials must not contain line breaks")
                lines.extend([f"username={credential.get('username', '')}", f"password={credential['secret']}"])
            sections.append("\n".join(lines))
        photon_path.parent.mkdir(parents=True, exist_ok=True)
        photon_path.write_text("\n\n".join(sections) + "\n", encoding="utf-8")
        photon_path.chmod(0o600 if any(_source_credential(source, credentials) for source in managed_photon) else 0o644)
        commands.append({"command": ["write", str(photon_path)], "returncode": 0, "success": True, "stdout": f"wrote {len(managed_photon)} managed Photon repositories", "stderr": ""})
    elif photon_path.exists():
        photon_path.unlink()
        commands.append({"command": ["remove", str(photon_path)], "returncode": 0, "success": True, "stdout": "removed managed Photon repository file", "stderr": ""})

    pip_path = LABFOUNDRY_PIP_CONFIG_PATH
    python_pairs = _python_source_pairs(payload)
    if python_pairs:
        authenticated_urls = [
            _authenticated_url(url, _source_credential(source, credentials))
            for url, source in python_pairs
        ]
        pip_lines = ["[global]", f"index-url = {authenticated_urls[0]}"]
        if len(authenticated_urls) > 1:
            pip_lines.append("extra-index-url =\n    " + "\n    ".join(authenticated_urls[1:]))
        trusted_hosts = [
            urlparse(url).hostname or "" for url, source in python_pairs
            if isinstance(source.get("settings"), dict) and source["settings"].get("tls_verify") is False
        ]
        if trusted_hosts:
            pip_lines.append("trusted-host =\n    " + "\n    ".join(trusted_hosts))
        pip_path.write_text("\n".join(pip_lines) + "\n", encoding="utf-8")
        pip_path.chmod(0o600 if any(_source_credential(source, credentials) for _, source in python_pairs) else 0o644)
        commands.append({"command": ["write", str(pip_path)], "returncode": 0, "success": True, "stdout": f"configured {len(python_pairs)} LabFoundry virtualenv pip indexes", "stderr": ""})
    elif pip_path.exists():
        pip_path.unlink()
        commands.append({"command": ["remove", str(pip_path)], "returncode": 0, "success": True, "stdout": "restored LabFoundry virtualenv pip defaults", "stderr": ""})

    pwsh = _command_path("pwsh")
    try:
        previous_state = json.loads(UPDATE_SOURCE_STATE_PATH.read_text(encoding="utf-8")) if UPDATE_SOURCE_STATE_PATH.exists() else {}
    except (OSError, json.JSONDecodeError):
        previous_state = {}
    previous_powershell_names = {
        str(value) for value in previous_state.get("powershell_repositories", []) if str(value).strip()
    } if isinstance(previous_state, dict) else set()
    current_powershell_names: set[str] = set()
    for source in definitions:
        if not isinstance(source, dict) or source.get("kind") != "powershell" or source.get("enabled") is not True:
            continue
        if pwsh is None:
            commands.append({"command": ["pwsh"], "returncode": 127, "success": False, "stdout": "", "stderr": "pwsh command not found"})
            continue
        name = str(source.get("name") or "").strip()
        url = str(source.get("url") or "").strip()
        if not name:
            raise ValueError("PowerShell source name is required")
        parsed = urlparse(url)
        if parsed.scheme not in {"http", "https"} or not parsed.netloc:
            raise ValueError(f"PowerShell source {name} must use an HTTP(S) URL")
        current_powershell_names.add(name)
        trusted = bool((source.get("settings") or {}).get("trusted")) if isinstance(source.get("settings"), dict) else False
        policy = "Trusted" if trusted else "Untrusted"
        script = (
            '$ErrorActionPreference = "Stop"; '
            f"$name = {_powershell_literal(name)}; $url = {_powershell_literal(url)}; "
            "$existing = Get-PSRepository -Name $name -ErrorAction SilentlyContinue; "
            f"if ($existing) {{ Set-PSRepository -Name $name -SourceLocation $url -InstallationPolicy {policy} }} "
            f"else {{ Register-PSRepository -Name $name -SourceLocation $url -InstallationPolicy {policy} }}; "
            "Get-PSRepository -Name $name | Select-Object Name,SourceLocation,InstallationPolicy | ConvertTo-Json -Compress"
        )
        commands.append(_command_payload([pwsh, "-NoLogo", "-NoProfile", "-NonInteractive", "-EncodedCommand", _powershell_encoded_command(script)]))
    if pwsh is not None:
        for name in sorted(previous_powershell_names - current_powershell_names):
            script = (
                '$ErrorActionPreference = "Stop"; '
                f"$name = {_powershell_literal(name)}; "
                "$existing = Get-PSRepository -Name $name -ErrorAction SilentlyContinue; "
                "if ($existing) { Unregister-PSRepository -Name $name }; "
                "[pscustomobject]@{Name=$name;Removed=[bool]$existing} | ConvertTo-Json -Compress"
            )
            commands.append(_command_payload([pwsh, "-NoLogo", "-NoProfile", "-NonInteractive", "-EncodedCommand", _powershell_encoded_command(script)]))
    UPDATE_SOURCE_STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    UPDATE_SOURCE_STATE_PATH.write_text(
        json.dumps({"powershell_repositories": sorted(current_powershell_names)}, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )
    UPDATE_SOURCE_STATE_PATH.chmod(0o600)
    return {"status": "succeeded" if all(command.get("success") for command in commands) else "failed", "commands": commands}


def _check_appliance_update(payload: dict, credentials: dict[str, dict[str, str]] | None = None) -> dict:
    credentials = credentials or {}
    selected = set(payload.get("selected_streams") or [])
    sources = payload.get("sources") or {}
    commands: list[dict] = []
    checks: dict[str, object] = {}
    if "photon_os" in selected:
        tdnf = _command_path("tdnf") or "tdnf"
        commands.append(_command_payload([tdnf, "makecache"], success_codes={0}))
        commands.append(_command_payload([tdnf, "check-update"], success_codes={0, 100}))
        checks["photon_os"] = "tdnf check-update completed; exit 100 means updates are available."
    if "python_libraries" in selected:
        command = [_appliance_update_python(), "-m", "pip", "list", "--outdated", "--format=json"]
        python_pairs = _python_source_pairs(payload)
        env = os.environ.copy()
        if python_pairs:
            authenticated = [
                _authenticated_url(url, _source_credential(source, credentials))
                for url, source in python_pairs
            ]
            env["PIP_INDEX_URL"] = authenticated[0]
            if len(authenticated) > 1:
                env["PIP_EXTRA_INDEX_URL"] = " ".join(authenticated[1:])
            commands.append(_command_payload(command, success_codes={0}, env=env))
        else:
            commands.append(_command_payload(command, success_codes={0}))
        checks["python_libraries"] = "pip outdated check completed."
    if "powershell_modules" in selected:
        pwsh = _command_path("pwsh") or "pwsh"
        default_repository = str(sources.get("powershell_repository_name") or "").strip()
        module_checks: list[dict] = []
        for module in payload.get("powershell_modules") or []:
            name = str(module.get("name") or "").strip()
            target = str(module.get("target_version") or "").strip()
            repository = str(module.get("repository_name") or default_repository).strip()
            script = (
                '$ErrorActionPreference = "Stop"; '
                "$credentialArgs = if ($env:LF_REPO_SECRET) { $credential = New-Object System.Management.Automation.PSCredential($env:LF_REPO_USER, (ConvertTo-SecureString $env:LF_REPO_SECRET -AsPlainText -Force)); @{Credential=$credential} } else { @{} }; "
                f"$module = Find-Module -Name {_powershell_literal(name)} -Repository {_powershell_literal(repository)}"
                + (f" -RequiredVersion {_powershell_literal(target)}" if target else "")
                + " @credentialArgs"
                + "; $module | Select-Object Name,Version,Repository | ConvertTo-Json -Compress"
            )
            source = next((item for item in _enabled_sources(payload, "powershell") if str(item.get("name") or "") == repository), {})
            credential = _source_credential(source, credentials)
            env = os.environ.copy()
            if credential:
                env.update({"LF_REPO_USER": str(credential.get("username") or ""), "LF_REPO_SECRET": str(credential["secret"])})
            command_args = [pwsh, "-NoLogo", "-NoProfile", "-NonInteractive", "-EncodedCommand", _powershell_encoded_command(script)]
            command = _command_payload(command_args, env=env) if credential else _command_payload(command_args)
            commands.append(command)
            module_checks.append({"name": name, "repository": repository, "target_version": target, "success": command["success"]})
        checks["powershell_modules"] = module_checks
    if "labfoundry_wheel" in selected:
        manifest, manifest_url, _credential = _download_labfoundry_manifest_from_sources(payload, credentials)
        checks["labfoundry_wheel"] = {
            "version": manifest.get("version"),
            "git_commit": manifest.get("git_commit"),
            "wheel": manifest.get("wheel"),
            "sha256": manifest.get("sha256"),
            "manifest_url": manifest_url,
        }
    return {"checks": checks, "commands": commands}


def _apply_python_libraries(payload: dict, credentials: dict[str, dict[str, str]] | None = None) -> list[dict]:
    credentials = credentials or {}
    sources = payload.get("sources") or {}
    requirements = [str(item).strip() for item in payload.get("python_requirements", []) if str(item).strip()]
    python = _appliance_update_python()
    bootstrap_command = [python, "-m", "pip", "install", "--upgrade"]
    python_pairs = _python_source_pairs(payload)
    env = os.environ.copy()
    if python_pairs:
        authenticated = [_authenticated_url(url, _source_credential(source, credentials)) for url, source in python_pairs]
        env["PIP_INDEX_URL"] = authenticated[0]
        if len(authenticated) > 1:
            env["PIP_EXTRA_INDEX_URL"] = " ".join(authenticated[1:])
    bootstrap_command.extend(["pip", "setuptools", "wheel"])
    commands = [_command_payload(bootstrap_command, env=env) if python_pairs else _command_payload(bootstrap_command)]
    if requirements:
        command = [python, "-m", "pip", "install", "--upgrade"]
        command.extend(requirements)
        commands.append(_command_payload(command, env=env) if python_pairs else _command_payload(command))
    _restore_labfoundry_venv_permissions()
    return commands


def _apply_powershell_modules(payload: dict, credentials: dict[str, dict[str, str]] | None = None) -> list[dict]:
    credentials = credentials or {}
    sources = payload.get("sources") or {}
    default_repository = str(sources.get("powershell_repository_name") or "").strip()
    pwsh = _command_path("pwsh") or "pwsh"
    commands: list[dict] = []
    for module in payload.get("powershell_modules") or []:
        name = str(module.get("name") or "").strip()
        target = str(module.get("target_version") or "").strip()
        policy = str(module.get("policy") or "pinned")
        repository = str(module.get("repository_name") or default_repository).strip()
        version_argument = f" -RequiredVersion {_powershell_literal(target)}" if policy == "pinned" and target else ""
        script = (
            '$ErrorActionPreference = "Stop"; '
            "$credentialArgs = if ($env:LF_REPO_SECRET) { $credential = New-Object System.Management.Automation.PSCredential($env:LF_REPO_USER, (ConvertTo-SecureString $env:LF_REPO_SECRET -AsPlainText -Force)); @{Credential=$credential} } else { @{} }; "
            f"Install-Module -Name {_powershell_literal(name)} -Repository {_powershell_literal(repository)}"
            f"{version_argument} @credentialArgs -Scope AllUsers -Force -AllowClobber -AcceptLicense -Confirm:$false; "
            f"$module = Get-Module -Name {_powershell_literal(name)} -ListAvailable | Sort-Object Version -Descending | Select-Object -First 1; "
            "if (-not $module) { throw 'Installed module could not be found' }; Import-Module $module.Path -Force; "
            "$module | Select-Object Name,Version,Path | ConvertTo-Json -Compress"
        )
        source = next((item for item in _enabled_sources(payload, "powershell") if str(item.get("name") or "") == repository), {})
        credential = _source_credential(source, credentials)
        env = os.environ.copy()
        if credential:
            env.update({"LF_REPO_USER": str(credential.get("username") or ""), "LF_REPO_SECRET": str(credential["secret"])})
        command_args = [pwsh, "-NoLogo", "-NoProfile", "-NonInteractive", "-EncodedCommand", _powershell_encoded_command(script)]
        commands.append(_command_payload(command_args, env=env) if credential else _command_payload(command_args))
    return commands


def _apply_labfoundry_wheel(payload: dict, credentials: dict[str, dict[str, str]] | None = None) -> tuple[dict, list[dict]]:
    credentials = credentials or {}
    failures: list[str] = []
    for manifest_url, source in _labfoundry_manifest_sources(payload):
        credential = _source_credential(source, credentials)
        try:
            manifest = _download_labfoundry_update_manifest(manifest_url, credential)
            wheel_url = urljoin(manifest_url, str(manifest["wheel"]))
            wheel_bytes = _fetch_http_bytes(wheel_url, credential) if credential else _fetch_http_bytes(wheel_url)
            digest = hashlib.sha256(wheel_bytes).hexdigest()
            if digest.lower() != str(manifest["sha256"]).lower():
                raise ValueError(f"LabFoundry wheel sha256 mismatch: expected {manifest['sha256']} got {digest}")
            with tempfile.TemporaryDirectory(prefix="labfoundry-update-") as temp_root:
                wheel_path = Path(temp_root) / Path(str(manifest["wheel"])).name
                wheel_path.write_bytes(wheel_bytes)
                command = [_appliance_update_python(), "-m", "pip", "install", "--force-reinstall", "--no-deps", str(wheel_path)]
                commands = [_command_payload(command)]
            _restore_labfoundry_venv_permissions()
            return manifest, commands
        except Exception as exc:  # noqa: BLE001 - try the next explicitly configured repository.
            failures.append(f"{manifest_url}: {exc}")
    raise ValueError("No enabled LabFoundry release source succeeded: " + " ; ".join(failures))


def _apply_appliance_update(payload: dict, credentials: dict[str, dict[str, str]] | None = None) -> dict:
    credentials = credentials or {}
    selected = set(payload.get("selected_streams") or [])
    commands: list[dict] = []
    attempted: dict[str, object] = {}
    reboot_recommended = False
    if "photon_os" in selected:
        tdnf = _command_path("tdnf") or "tdnf"
        commands.append(_command_payload([tdnf, "-y", "makecache"]))
        commands.append(_command_payload([tdnf, "-y", "update"]))
        attempted["photon_os"] = "Photon OS packages updated from configured repositories."
        reboot_recommended = True
    if "python_libraries" in selected:
        python_commands = _apply_python_libraries(payload, credentials)
        commands.extend(python_commands)
        attempted["python_libraries"] = "LabFoundry virtualenv Python libraries updated."
    if "powershell_modules" in selected:
        powershell_commands = _apply_powershell_modules(payload, credentials)
        commands.extend(powershell_commands)
        attempted["powershell_modules"] = "Managed PowerShell modules updated from the configured repository."
    if "labfoundry_wheel" in selected:
        manifest, wheel_commands = _apply_labfoundry_wheel(payload, credentials)
        commands.extend(wheel_commands)
        attempted["labfoundry_wheel"] = manifest
    succeeded = all(command.get("success") for command in commands)
    result = {
        "status": "succeeded" if succeeded else "failed",
        "applied": attempted if succeeded else {},
        "attempted": attempted,
        "commands": commands,
        "reboot_recommended": reboot_recommended if succeeded else False,
        "restart_required": "labfoundry_wheel" in selected and succeeded,
        "finished_at": datetime.now(timezone.utc).isoformat(),
    }
    if not succeeded:
        failed = [" ".join(command.get("command") or []) for command in commands if not command.get("success")]
        result["error"] = f"One or more appliance update commands failed: {' ; '.join(failed)}"
    _write_update_info(result)
    return result


def _restart_labfoundry_service_after_update() -> int:
    systemctl = _command_path("systemctl")
    if systemctl is None:
        print("systemctl command not found", file=sys.stderr)
        return 127
    systemd_run = shutil.which("systemd-run")
    if systemd_run is None:
        print("systemd-run is required to schedule the delayed LabFoundry service restart", file=sys.stderr)
        return 127
    result = _run(
        [
            systemd_run,
            "--quiet",
            "--on-active=3",
            "--unit=labfoundry-update-restart",
            systemctl,
            "restart",
            "labfoundry.service",
            "labfoundry-worker.service",
        ]
    )
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _console_unit_state(unit: str) -> dict[str, object] | None:
    load_state = _run(["systemctl", "show", "--property=LoadState", "--value", unit])
    if load_state.returncode != 0 or load_state.stdout.strip() == "not-found":
        return None
    enabled = _run(["systemctl", "is-enabled", unit])
    active = _run(["systemctl", "is-active", unit])
    return {
        "unit": unit,
        "enabled": enabled.returncode == 0,
        "enabled_state": enabled.stdout.strip() or enabled.stderr.strip(),
        "active": active.returncode == 0,
        "active_state": active.stdout.strip() or active.stderr.strip(),
    }


def _write_console_service_state(payload: dict[str, object]) -> None:
    CONSOLE_STATE_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(CONSOLE_STATE_DIR, 0o700)
    temporary = CONSOLE_SERVICE_STATE_PATH.with_suffix(".json.tmp")
    temporary.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.chmod(temporary, 0o600)
    os.replace(temporary, CONSOLE_SERVICE_STATE_PATH)


def _disable_console_managed_services() -> int:
    if CONSOLE_SERVICE_STATE_PATH.exists():
        print(json.dumps({"console": "maintenance isolation already enabled", "state_path": str(CONSOLE_SERVICE_STATE_PATH)}, sort_keys=True))
        return 0
    units = [state for unit in CONSOLE_MANAGED_SERVICE_UNITS if (state := _console_unit_state(unit)) is not None]
    _write_console_service_state(
        {
            "created_at": datetime.now(timezone.utc).isoformat(),
            "preserved": ["labfoundry-console.service", "systemd-networkd.service", "systemd-resolved.service", "labfoundry-firewall.service"],
            "units": units,
        }
    )
    failures: list[dict[str, object]] = []
    for state in units:
        unit = str(state["unit"])
        result = _run(["systemctl", "disable", "--now", unit])
        if result.returncode != 0:
            failures.append({"unit": unit, "returncode": result.returncode, "error": (result.stderr or result.stdout).strip()})
    payload = {
        "console": "maintenance isolation enabled" if not failures else "maintenance isolation completed with failures",
        "disabled_units": [str(state["unit"]) for state in units],
        "preserved": ["local console", "management networking", "resolver", "firewall"],
        "failures": failures,
        "state_path": str(CONSOLE_SERVICE_STATE_PATH),
    }
    print(json.dumps(payload, sort_keys=True))
    return 1 if failures else 0


def _restore_console_managed_services() -> int:
    if not CONSOLE_SERVICE_STATE_PATH.exists():
        print(json.dumps({"console": "maintenance isolation is not enabled"}, sort_keys=True))
        return 0
    try:
        payload = json.loads(CONSOLE_SERVICE_STATE_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        print(f"unable to read console service state: {exc}", file=sys.stderr)
        return 1
    units = payload.get("units") if isinstance(payload, dict) else None
    if not isinstance(units, list):
        print("console service state does not contain a units list", file=sys.stderr)
        return 1
    failures: list[dict[str, object]] = []
    restored: list[str] = []
    for state in units:
        if not isinstance(state, dict) or str(state.get("unit") or "") not in CONSOLE_MANAGED_SERVICE_UNITS:
            continue
        unit = str(state["unit"])
        commands: list[list[str]] = []
        if bool(state.get("enabled")):
            commands.append(["systemctl", "enable", unit])
        if bool(state.get("active")):
            commands.append(["systemctl", "start", unit])
        unit_failed = False
        for command in commands:
            result = _run(command)
            if result.returncode != 0:
                failures.append({"unit": unit, "returncode": result.returncode, "error": (result.stderr or result.stdout).strip()})
                unit_failed = True
                break
        if not unit_failed:
            restored.append(unit)
    if not failures:
        CONSOLE_SERVICE_STATE_PATH.unlink(missing_ok=True)
    result_payload = {
        "console": "maintenance isolation disabled" if not failures else "maintenance isolation restore failed",
        "restored_units": restored,
        "failures": failures,
        "state_path": str(CONSOLE_SERVICE_STATE_PATH),
    }
    print(json.dumps(result_payload, sort_keys=True))
    return 1 if failures else 0


def _handle_console(action: str, args: list[str]) -> int:
    if args:
        print(f"console {action} does not accept a path", file=sys.stderr)
        return 2
    if action == "status":
        print(
            json.dumps(
                {
                    "maintenance_isolation": CONSOLE_SERVICE_STATE_PATH.exists(),
                    "state_path": str(CONSOLE_SERVICE_STATE_PATH),
                    "managed_units": list(CONSOLE_MANAGED_SERVICE_UNITS),
                    "preserved": ["labfoundry-console.service", "systemd-networkd.service", "systemd-resolved.service", "labfoundry-firewall.service"],
                },
                sort_keys=True,
            )
        )
        return 0
    if action == "disable-services":
        return _disable_console_managed_services()
    if action == "restore-services":
        return _restore_console_managed_services()
    print(f"unsupported console action: {action}", file=sys.stderr)
    return 2


def _esx_storage_safe_slug(value: object) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", str(value or "").strip().lower()).strip("-")
    if not slug:
        raise ValueError("ESX Storage names must contain at least one letter or number")
    return slug[:63]


def _esx_storage_config_path(value: str) -> Path:
    path = Path(value).resolve(strict=True)
    root = ESX_STORAGE_APPLY_DIR.resolve(strict=True)
    if not path.is_relative_to(root) or path.name != "labfoundry-esx-storage.json":
        raise ValueError(f"ESX Storage manifest must be {ESX_STORAGE_APPLY_DIR / 'labfoundry-esx-storage.json'}")
    return path


def _esx_storage_manifest(path: Path) -> dict[str, object]:
    payload = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(payload, dict):
        raise ValueError("ESX Storage manifest must be a JSON object")
    return payload


def _esx_storage_manifest_hash(payload: dict[str, object]) -> str:
    desired = dict(payload)
    desired.pop("format_authorizations", None)
    encoded = json.dumps(desired, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(encoded).hexdigest()


def _esx_storage_by_id_map() -> dict[str, str]:
    result: dict[str, str] = {}
    root = Path("/dev/disk/by-id")
    if not root.is_dir():
        return result
    for link in sorted(root.iterdir()):
        if "-part" in link.name:
            continue
        try:
            target = str(link.resolve(strict=True))
        except OSError:
            continue
        current = result.get(target)
        if current is None or ("wwn-" in link.name and "wwn-" not in current):
            result[target] = str(link)
    return result


def _esx_storage_os_devices() -> set[str]:
    findmnt = _command_path("findmnt")
    lsblk = _command_path("lsblk")
    if findmnt is None or lsblk is None:
        return set()
    source_result = _run([findmnt, "-nro", "SOURCE", "/"])
    source = source_result.stdout.strip()
    if source_result.returncode != 0 or not source.startswith("/dev/"):
        return set()
    result = _run([lsblk, "-sno", "PATH", source])
    return {line.strip() for line in result.stdout.splitlines() if line.strip().startswith("/dev/")}


def _esx_storage_inventory() -> list[dict[str, object]]:
    lsblk = _command_path("lsblk")
    if lsblk is None:
        raise ValueError("lsblk is required for ESX Storage disk inventory")
    result = _run(
        [
            lsblk,
            "-J",
            "-b",
            "-o",
            "NAME,KNAME,PATH,TYPE,SIZE,MODEL,SERIAL,WWN,FSTYPE,UUID,LABEL,MOUNTPOINTS,PKNAME,RO,RM",
        ]
    )
    if result.returncode != 0:
        raise ValueError(result.stderr.strip() or "lsblk inventory failed")
    payload = json.loads(result.stdout)
    by_id = _esx_storage_by_id_map()
    os_devices = _esx_storage_os_devices()
    swap_devices = {
        line.split()[0]
        for line in Path("/proc/swaps").read_text(encoding="utf-8").splitlines()[1:]
        if line.split()
    } if Path("/proc/swaps").exists() else set()
    inventory: list[dict[str, object]] = []

    def walk(item: dict[str, object], parent_disk: str = "") -> None:
        device_path = str(item.get("path") or "")
        device_type = str(item.get("type") or "")
        disk_path = device_path if device_type == "disk" else parent_disk
        mountpoints = [str(value) for value in (item.get("mountpoints") or []) if value]
        primary_mount_path = next(
            (path for path in mountpoints if path.startswith(f"{ESX_STORAGE_MOUNT_ROOT.as_posix().rstrip('/')}/")),
            mountpoints[0] if mountpoints else "",
        )
        kname = str(item.get("kname") or item.get("name") or "")
        holders_root = Path("/sys/class/block") / kname / "holders"
        holders = sorted(path.name for path in holders_root.iterdir()) if holders_root.is_dir() else []
        children = list(item.get("children") or [])
        filesystem_type = str(item.get("fstype") or "")
        filesystem_uuid = str(item.get("uuid") or "")
        stable_id = by_id.get(device_path, "") or (f"UUID={filesystem_uuid}" if filesystem_uuid else "")
        candidate_type = ""
        if device_type == "disk" and not children and not filesystem_type and not mountpoints:
            candidate_type = "blank_disk"
        elif filesystem_type == "ext4" and mountpoints and not any(path in {"/", "/boot", "/boot/efi"} for path in mountpoints):
            candidate_type = "mounted_ext4"
        inventory.append(
            {
                "stable_device_id": stable_id,
                "device_path": device_path,
                "type": device_type,
                "parent_disk": disk_path,
                "model": str(item.get("model") or "").strip(),
                "serial": str(item.get("serial") or "").strip(),
                "wwn": str(item.get("wwn") or "").strip(),
                "size_bytes": int(item.get("size") or 0),
                "filesystem_type": filesystem_type,
                "filesystem_uuid": filesystem_uuid,
                "filesystem_label": str(item.get("label") or ""),
                "mount_path": primary_mount_path,
                "mount_paths": mountpoints,
                "partitions": [str(child.get("path") or child.get("name") or "") for child in children],
                "swap": device_path in swap_devices or filesystem_type == "swap",
                "lvm": filesystem_type == "LVM2_member" or any("dm-" in holder for holder in holders),
                "raid": filesystem_type == "linux_raid_member" or any("md" in holder for holder in holders),
                "holders": holders,
                "read_only": bool(item.get("ro")),
                "removable": bool(item.get("rm")),
                "os_related": device_path in os_devices or disk_path in os_devices,
                "candidate_type": candidate_type,
            }
        )
        for child in children:
            walk(child, disk_path)

    for block_device in payload.get("blockdevices", []):
        walk(block_device)
    return inventory


def _esx_storage_blank_disk_errors(entry: dict[str, object]) -> list[str]:
    errors: list[str] = []
    if str(entry.get("type")) != "disk":
        errors.append("not a whole disk")
    if not str(entry.get("stable_device_id") or "").startswith("/dev/disk/by-id/"):
        errors.append("missing stable /dev/disk/by-id identity")
    for key, label in [
        ("partitions", "has partitions"),
        ("filesystem_type", "has a filesystem"),
        ("mount_path", "is mounted"),
        ("swap", "is swap"),
        ("lvm", "belongs to LVM"),
        ("raid", "belongs to RAID"),
        ("holders", "has holders"),
        ("os_related", "is related to the operating-system disk"),
        ("read_only", "is read-only"),
    ]:
        if entry.get(key):
            errors.append(label)
    return errors


def _esx_storage_disk_is_initialized(entry: dict[str, object], *, label: str, mount_path: Path) -> bool:
    return (
        str(entry.get("filesystem_type") or "") == "ext4"
        and str(entry.get("filesystem_label") or "") == label
        and bool(entry.get("filesystem_uuid"))
        and not entry.get("partitions")
        and (
            not entry.get("mount_paths")
            or str(mount_path) in [str(path) for path in entry.get("mount_paths", [])]
        )
        and not entry.get("holders")
        and not entry.get("os_related")
    )


def _esx_storage_reserved_mount_owner(value: str) -> str:
    raw = value.strip()
    if not raw.startswith("/"):
        return ""
    path = PurePosixPath(raw)
    for reserved, owner in ESX_STORAGE_RESERVED_MOUNT_PATHS.items():
        if path == reserved or reserved in path.parents:
            return owner
    return ""


def _esx_storage_manifest_errors(payload: dict[str, object], *, require_authorization: bool = False) -> list[str]:
    errors: list[str] = []
    if payload.get("schema_version") != 1:
        errors.append("ESX Storage schema_version must be 1")
    validation = payload.get("validation") if isinstance(payload.get("validation"), dict) else {}
    errors.extend(str(error) for error in validation.get("errors", []) if str(error))
    volumes = payload.get("volumes") if isinstance(payload.get("volumes"), list) else []
    shares = payload.get("shares") if isinstance(payload.get("shares"), list) else []
    volumes_by_id: dict[object, dict[str, object]] = {}
    for volume in volumes:
        if not isinstance(volume, dict):
            errors.append("ESX Storage volume entries must be objects")
            continue
        volumes_by_id[volume.get("id")] = volume
        source_type = str(volume.get("source_type") or "")
        if source_type not in {"blank_disk", "mounted_ext4"}:
            errors.append(f"volume {volume.get('name')} has unsupported source_type")
        if source_type == "blank_disk" and not str(volume.get("stable_device_id") or "").startswith("/dev/disk/by-id/"):
            errors.append(f"volume {volume.get('name')} must use /dev/disk/by-id identity")
        mount_value = str(volume.get("mount_path") or "")
        if not mount_value.startswith("/"):
            errors.append(f"volume {volume.get('name')} mount path must be absolute")
        elif source_type == "blank_disk" and not mount_value.startswith(f"{ESX_STORAGE_MOUNT_ROOT.as_posix().rstrip('/')}/"):
            errors.append(f"new volume {volume.get('name')} mount path must be under {ESX_STORAGE_MOUNT_ROOT}")
        elif source_type == "mounted_ext4":
            owner = _esx_storage_reserved_mount_owner(mount_value)
            if owner:
                errors.append(f"existing volume {volume.get('name')} mount path is reserved for {owner}")
    enabled_shares = [share for share in shares if isinstance(share, dict) and share.get("enabled")]
    if payload.get("enabled") and not enabled_shares:
        errors.append("enabled ESX Storage requires at least one enabled share")
    for share in enabled_shares:
        if share.get("volume_id") not in volumes_by_id:
            errors.append(f"share {share.get('datastore_name')} references an unknown volume")
        if str(share.get("preferred_nfs_version")) not in {"3", "4.1"}:
            errors.append(f"share {share.get('datastore_name')} must prefer NFS 3 or 4.1")
        families = share.get("address_families") if isinstance(share.get("address_families"), list) else []
        if not families or any(family not in {"ipv4", "ipv6"} for family in families):
            errors.append(f"share {share.get('datastore_name')} must enable IPv4, IPv6, or both")
        clients = share.get("clients") if isinstance(share.get("clients"), dict) else {}
        for family in families:
            values = clients.get(family) if isinstance(clients.get(family), list) else []
            if not values:
                values = ["0.0.0.0/0" if family == "ipv4" else "::/0"]
                clients[family] = values
            for value in values:
                try:
                    network = ip_network(str(value), strict=False)
                    if network.version != (4 if family == "ipv4" else 6):
                        raise ValueError
                except ValueError:
                    errors.append(f"share {share.get('datastore_name')} has invalid {family} client {value}")
    if require_authorization:
        manifest_sha256 = _esx_storage_manifest_hash(payload)
        authorizations = payload.get("format_authorizations") if isinstance(payload.get("format_authorizations"), list) else []
        by_device = {str(item.get("stable_device_id") or ""): item for item in authorizations if isinstance(item, dict)}
        for volume in volumes:
            if not isinstance(volume, dict) or not volume.get("requires_format"):
                continue
            stable_id = str(volume.get("stable_device_id") or "")
            authorization = by_device.get(stable_id)
            expected = f"FORMAT {volume.get('name')}"
            if not authorization:
                errors.append(f"volume {volume.get('name')} is missing job-scoped format authorization")
            elif authorization.get("manifest_sha256") != manifest_sha256 or authorization.get("confirmation") != expected or not authorization.get("job_id"):
                errors.append(f"volume {volume.get('name')} format authorization does not match this job and manifest")
    return errors


def _esx_storage_replace_managed_fstab(lines: list[str]) -> None:
    existing = ESX_STORAGE_FSTAB_PATH.read_text(encoding="utf-8") if ESX_STORAGE_FSTAB_PATH.exists() else ""
    pattern = re.compile(
        rf"(?ms)^\s*{re.escape(ESX_STORAGE_FSTAB_BEGIN)}\s*$.*?^\s*{re.escape(ESX_STORAGE_FSTAB_END)}\s*$\n?"
    )
    cleaned = pattern.sub("", existing).rstrip()
    block = "\n".join([ESX_STORAGE_FSTAB_BEGIN, *lines, ESX_STORAGE_FSTAB_END])
    _write_secret_file(ESX_STORAGE_FSTAB_PATH, f"{cleaned}\n\n{block}\n" if cleaned else f"{block}\n", 0o644)


def _esx_storage_write_runtime_config(payload: dict[str, object]) -> None:
    enabled_shares = [share for share in payload.get("shares", []) if isinstance(share, dict) and share.get("enabled")]
    root_clients: list[str] = []
    export_lines: list[str] = []
    for share in enabled_shares:
        clients = share.get("clients") if isinstance(share.get("clients"), dict) else {}
        share_clients = list(
            dict.fromkeys(
                str(value)
                for family in ("ipv4", "ipv6")
                for value in (clients.get(family, []) or (["0.0.0.0/0"] if family == "ipv4" else ["::/0"]))
                if family in share.get("address_families", [])
            )
        )
        root_clients.extend(share_clients)
        options = "rw,sync,no_subtree_check,no_root_squash"
        export_lines.append(f"{share['bind_path']} " + " ".join(f"{client}({options})" for client in share_clients))
    root_options = "ro,fsid=0,crossmnt,sync,no_subtree_check,root_squash"
    if root_clients:
        export_lines.insert(0, f"{ESX_STORAGE_EXPORT_ROOT} " + " ".join(f"{client}({root_options})" for client in dict.fromkeys(root_clients)))
    _write_secret_file(ESX_STORAGE_EXPORTS_PATH, "\n".join(export_lines) + ("\n" if export_lines else ""), 0o644)
    nfs_config = """[nfsd]
vers2=n
vers3=y
vers4=y
vers4.0=n
vers4.1=y
tcp=y
udp=n

[mountd]
port=20048
manage-gids=y
"""
    _write_secret_file(ESX_STORAGE_NFS_CONFIG_PATH, nfs_config, 0o644)


def _esx_storage_apply(payload: dict[str, object]) -> dict[str, object]:
    inventory = _esx_storage_inventory()
    inventory_by_id = {str(item.get("stable_device_id") or ""): item for item in inventory}
    fstab_lines: list[str] = []
    commands: list[list[str]] = []
    volumes_by_id: dict[object, dict[str, object]] = {}
    for volume in payload.get("volumes", []):
        if not isinstance(volume, dict):
            continue
        volumes_by_id[volume.get("id")] = volume
        mount_path = Path(str(volume["mount_path"]))
        mount_path.mkdir(parents=True, exist_ok=True)
        if volume.get("source_type") == "blank_disk":
            stable_id = str(volume["stable_device_id"])
            entry = inventory_by_id.get(stable_id)
            if volume.get("requires_format"):
                if entry is None:
                    raise ValueError(f"approved disk disappeared before format: {stable_id}")
                label = f"lf-{hashlib.sha256(str(volume['name']).encode()).hexdigest()[:12]}"
                fingerprint = volume.get("fingerprint") if isinstance(volume.get("fingerprint"), dict) else {}
                for manifest_key, inventory_key, label_name in [
                    ("model", "model", "model"),
                    ("serial", "serial", "serial"),
                    ("wwn", "wwn", "WWN"),
                    ("size_bytes", "size_bytes", "capacity"),
                ]:
                    expected_value = fingerprint.get(manifest_key)
                    if expected_value in {None, "", 0}:
                        continue
                    if str(entry.get(inventory_key) or "") != str(expected_value):
                        raise ValueError(f"disk {stable_id} {label_name} changed after approval")
                already_initialized = _esx_storage_disk_is_initialized(entry, label=label, mount_path=mount_path)
                if not already_initialized:
                    safety_errors = _esx_storage_blank_disk_errors(entry)
                    if safety_errors:
                        raise ValueError(f"disk {stable_id} is no longer blank and eligible: {', '.join(safety_errors)}")
                    mkfs = _command_path("mkfs.ext4")
                    if mkfs is None:
                        raise ValueError("mkfs.ext4 is required for ESX Storage initialization")
                    command = [mkfs, "-F", "-L", label, stable_id]
                    result = _run(command, timeout=300)
                    commands.append(command)
                    if result.returncode != 0:
                        raise ValueError(result.stderr.strip() or f"mkfs.ext4 failed for {stable_id}")
            blkid = _command_path("blkid")
            if blkid is None:
                raise ValueError("blkid is required for ESX Storage UUID mounts")
            uuid_result = _run([blkid, "-s", "UUID", "-o", "value", stable_id])
            fs_uuid = uuid_result.stdout.strip()
            type_result = _run([blkid, "-s", "TYPE", "-o", "value", stable_id])
            if uuid_result.returncode != 0 or not fs_uuid or type_result.stdout.strip() != "ext4":
                raise ValueError(f"disk {stable_id} is not a readable ext4 filesystem after initialization")
            fstab_lines.append(f"UUID={fs_uuid} {mount_path} ext4 defaults,nofail,x-systemd.device-timeout=30 0 2")
            volume["filesystem_uuid"] = fs_uuid
        else:
            findmnt = _command_path("findmnt")
            if findmnt is None:
                raise ValueError("findmnt is required for existing ESX Storage volumes")
            find_result = _run([findmnt, "-nro", "FSTYPE", "--target", str(mount_path)])
            if find_result.returncode != 0 or find_result.stdout.strip() != "ext4":
                raise ValueError(f"existing volume {volume.get('name')} is not mounted as ext4 at {mount_path}")
    _esx_storage_replace_managed_fstab(fstab_lines)
    mount = _command_path("mount")
    if mount is None:
        raise ValueError("mount is required for ESX Storage")
    for volume in payload.get("volumes", []):
        if isinstance(volume, dict) and volume.get("source_type") == "blank_disk":
            result = _run([mount, str(volume["mount_path"])])
            commands.append([mount, str(volume["mount_path"])])
            if result.returncode != 0 and "already mounted" not in result.stderr.lower():
                raise ValueError(result.stderr.strip() or f"unable to mount {volume['mount_path']}")
    ESX_STORAGE_EXPORT_ROOT.mkdir(parents=True, exist_ok=True)
    desired_bind_paths = {
        str(share.get("bind_path"))
        for share in payload.get("shares", [])
        if isinstance(share, dict) and share.get("enabled")
    }
    findmnt_command = _command_path("findmnt")
    umount_command = _command_path("umount")
    if findmnt_command and umount_command:
        mounted_targets = _run([findmnt_command, "-rn", "-o", "TARGET"]).stdout.splitlines()
        for raw_target in sorted(mounted_targets, key=len, reverse=True):
            target = raw_target.strip()
            if not target.startswith(f"{ESX_STORAGE_EXPORT_ROOT}/") or target in desired_bind_paths:
                continue
            result = _run([umount_command, target])
            commands.append([umount_command, target])
            if result.returncode != 0:
                raise ValueError(result.stderr.strip() or f"unable to remove stale ESX Storage bind mount {target}")
            try:
                Path(target).rmdir()
            except OSError:
                pass
    for share in payload.get("shares", []):
        if not isinstance(share, dict) or not share.get("enabled"):
            continue
        volume = volumes_by_id[share["volume_id"]]
        volume_root = Path(str(volume["mount_path"])).resolve(strict=True)
        source = Path(str(share["source_path"]))
        source.mkdir(parents=True, exist_ok=True)
        resolved_source = source.resolve(strict=True)
        if not resolved_source.is_relative_to(volume_root):
            raise ValueError(f"share {share.get('datastore_name')} escapes its backing volume")
        bind_path = Path(str(share["bind_path"]))
        bind_path.mkdir(parents=True, exist_ok=True)
        find_bind = _run([_command_path("findmnt") or "findmnt", "-nro", "SOURCE", "--target", str(bind_path)])
        if find_bind.returncode != 0 or Path(find_bind.stdout.strip()).resolve() != resolved_source:
            bind_result = _run([mount, "--bind", str(resolved_source), str(bind_path)])
            commands.append([mount, "--bind", str(resolved_source), str(bind_path)])
            if bind_result.returncode != 0:
                raise ValueError(bind_result.stderr.strip() or f"unable to bind {resolved_source} to {bind_path}")
        fstab_lines.append(f"{resolved_source} {bind_path} none bind,nofail,x-systemd.requires-mounts-for={volume_root} 0 0")
    _esx_storage_replace_managed_fstab(fstab_lines)
    _esx_storage_write_runtime_config(payload)
    systemctl = _command_path("systemctl")
    exportfs = _command_path("exportfs")
    if systemctl is None or exportfs is None:
        raise ValueError("systemctl and exportfs from nfs-utils are required for ESX Storage")
    if payload.get("enabled") and any(isinstance(share, dict) and share.get("enabled") for share in payload.get("shares", [])):
        daemon_reload = _run([systemctl, "daemon-reload"])
        if daemon_reload.returncode != 0:
            raise ValueError(daemon_reload.stderr.strip() or "systemd daemon-reload failed")
        enable = _run([systemctl, "enable", "--now", "rpcbind.service", "nfs-server.service"], timeout=120)
        commands.append([systemctl, "enable", "--now", "rpcbind.service", "nfs-server.service"])
        if enable.returncode != 0:
            raise ValueError(enable.stderr.strip() or "unable to start NFS services")
        exports = _run([exportfs, "-rav"])
        commands.append([exportfs, "-rav"])
        if exports.returncode != 0:
            raise ValueError(exports.stderr.strip() or "exportfs refresh failed")
    else:
        _run([exportfs, "-ua"])
        _run([systemctl, "disable", "--now", "nfs-server.service", "rpcbind.service", "rpcbind.socket"], timeout=120)
    return {"status": "applied", "volumes": payload.get("volumes", []), "shares": len(payload.get("shares", [])), "commands": commands}


def _handle_esx_storage(action: str, args: list[str]) -> int:
    if action == "inventory":
        try:
            print(json.dumps(_esx_storage_inventory(), sort_keys=True, separators=(",", ":")))
            return 0
        except (OSError, ValueError, json.JSONDecodeError) as exc:
            print(str(exc), file=sys.stderr)
            return 1
    if action == "status":
        status: dict[str, object] = {"rpcbind": "unknown", "nfs_server": "unknown", "exports": []}
        systemctl = _command_path("systemctl")
        exportfs = _command_path("exportfs")
        if systemctl:
            status["rpcbind"] = _run([systemctl, "is-active", "rpcbind.service"]).stdout.strip() or "inactive"
            status["nfs_server"] = _run([systemctl, "is-active", "nfs-server.service"]).stdout.strip() or "inactive"
        if exportfs:
            status["exports"] = [line for line in _run([exportfs, "-v"]).stdout.splitlines() if line.strip()]
        print(json.dumps(status, sort_keys=True, separators=(",", ":")))
        return 0
    if action == "logs":
        journalctl = _command_path("journalctl")
        if journalctl is None:
            print("journalctl command not found", file=sys.stderr)
            return 127
        result = _run([journalctl, "-u", "nfs-server.service", "-u", "rpcbind.service", "-n", "200", "--no-pager"])
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        return result.returncode
    if len(args) != 1:
        print(f"esx-storage {action} requires exactly one staged manifest path", file=sys.stderr)
        return 2
    try:
        config_path = _esx_storage_config_path(args[0])
        payload = _esx_storage_manifest(config_path)
        errors = _esx_storage_manifest_errors(payload, require_authorization=action == "apply")
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    if action == "validate":
        print(json.dumps({"esx_storage": "validation complete", "config_path": str(config_path)}, sort_keys=True))
        return 0
    if action == "apply":
        try:
            print(json.dumps(_esx_storage_apply(payload), sort_keys=True))
            return 0
        except (OSError, ValueError, subprocess.TimeoutExpired) as exc:
            print(str(exc), file=sys.stderr)
            return 1
    print(f"unsupported esx-storage action: {action}", file=sys.stderr)
    return 2


def _handle_automation(action: str, args: list[str]) -> int:
    if action != "run" or len(args) < 3:
        print("automation run requires script path, interpreter, timeout seconds, and optional arguments after --", file=sys.stderr)
        return 2
    script_value, interpreter, timeout_value, *remaining = args
    if remaining and remaining[0] != "--":
        print("automation script arguments must follow --", file=sys.stderr)
        return 2
    script_arguments = remaining[1:] if remaining else []
    try:
        script_path = Path(script_value).resolve(strict=True)
        script_root = AUTOMATION_SCRIPT_DIR.resolve(strict=True)
        if not script_path.is_relative_to(script_root) or not script_path.is_file():
            raise ValueError(f"automation script must be a regular file under {AUTOMATION_SCRIPT_DIR}")
        timeout_seconds = int(timeout_value)
        if timeout_seconds < 1 or timeout_seconds > 86400:
            raise ValueError("automation timeout must be between 1 and 86400 seconds")
        command_name = {"bash": "bash", "python": "python3", "powershell": "pwsh"}.get(interpreter)
        if command_name is None:
            raise ValueError("automation interpreter must be bash, python, or powershell")
        executable = _command_path(command_name)
        systemd_run = shutil.which("systemd-run")
        if executable is None:
            raise ValueError(f"automation interpreter is not installed: {command_name}")
        if systemd_run is None:
            raise ValueError("systemd-run is required for managed automation scripts")
        account = pwd.getpwnam(AUTOMATION_USER)
    except (KeyError, OSError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2

    AUTOMATION_RUN_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(AUTOMATION_RUN_DIR, 0o750)
    _chown_path(script_path, int(account.pw_uid), int(account.pw_gid))
    os.chmod(script_path, 0o400)
    unit_suffix = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S%f")
    run_home = AUTOMATION_RUN_DIR / unit_suffix
    writable_directories = [run_home, run_home / ".cache", run_home / ".config", run_home / ".local", run_home / ".local" / "share"]
    for directory in writable_directories:
        directory.mkdir(parents=True, exist_ok=True)
        os.chmod(directory, 0o700)
        _chown_path(directory, int(account.pw_uid), int(account.pw_gid))
    try:
        result = _run(
            [
                systemd_run,
                "--quiet",
                "--wait",
                "--pipe",
                "--collect",
                "--service-type=exec",
                f"--unit=labfoundry-automation-{unit_suffix}",
                f"--uid={AUTOMATION_USER}",
                f"--setenv=HOME={run_home}",
                f"--setenv=XDG_CACHE_HOME={run_home / '.cache'}",
                f"--setenv=XDG_CONFIG_HOME={run_home / '.config'}",
                f"--setenv=XDG_DATA_HOME={run_home / '.local' / 'share'}",
                "--property=NoNewPrivileges=yes",
                "--property=PrivateTmp=yes",
                "--property=ProtectSystem=strict",
                "--property=ProtectHome=yes",
                f"--property=ReadWritePaths={run_home}",
                f"--property=WorkingDirectory={run_home}",
                f"--property=TimeoutStartSec={timeout_seconds}",
                executable,
                str(script_path),
                *script_arguments,
            ]
        )
    finally:
        shutil.rmtree(run_home, ignore_errors=True)
    print(result.stdout[-8000:], end="")
    print(result.stderr[-8000:], end="", file=sys.stderr)
    return result.returncode


def _schedule_appliance_power(action: str) -> int:
    systemctl = _command_path("systemctl")
    systemd_run = shutil.which("systemd-run")
    if systemctl is None:
        print("systemctl command not found", file=sys.stderr)
        return 127
    if systemd_run is None:
        print("systemd-run command not found; refusing an immediate appliance power action", file=sys.stderr)
        return 127
    systemctl_action = "reboot" if action == "reboot" else "poweroff"
    unit_suffix = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S%f")
    result = _run(
        [
            systemd_run,
            "--quiet",
            "--on-active=5",
            f"--unit=labfoundry-{action}-{unit_suffix}",
            systemctl,
            systemctl_action,
        ]
    )
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _handle_appliance_power(action: str, args: list[str]) -> int:
    if args:
        print(f"appliance-power {action} does not accept a path", file=sys.stderr)
        return 2
    return _schedule_appliance_power(action)


def _handle_appliance_update(action: str, args: list[str]) -> int:
    try:
        config_path = _validate_appliance_update_config_path(args[0])
        payload = _load_appliance_update_config(config_path)
        credentials = _load_appliance_update_credentials(args)
        errors = _appliance_update_config_errors(payload, require_streams=action != "sync-sources")
    except (IndexError, OSError, ValueError, json.JSONDecodeError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2

    if action == "check":
        try:
            result = _check_appliance_update(payload, credentials)
        except Exception as exc:  # noqa: BLE001 - helper reports validation/check failures as stderr.
            print(str(exc), file=sys.stderr)
            return 1
        print(json.dumps(result, indent=2, sort_keys=True))
        if any(not command.get("success") for command in result.get("commands", [])):
            return 1
        return 0
    if action == "apply":
        try:
            result = _apply_appliance_update(payload, credentials)
        except Exception as exc:  # noqa: BLE001 - helper reports update failures without tracebacks.
            print(str(exc), file=sys.stderr)
            return 1
        print(json.dumps(result, indent=2, sort_keys=True))
        if any(not command.get("success") for command in result.get("commands", [])):
            return 1
        return 0
    if action == "sync-sources":
        try:
            result = _sync_appliance_update_sources(payload, credentials)
        except Exception as exc:  # noqa: BLE001 - helper reports source configuration failures as stderr.
            print(str(exc), file=sys.stderr)
            return 1
        print(json.dumps(result, indent=2, sort_keys=True))
        return 0 if result.get("status") == "succeeded" else 1
    if action == "restart-service":
        return _restart_labfoundry_service_after_update()

    print(f"unsupported appliance-update action: {action}", file=sys.stderr)
    return 2


def main(argv: list[str]) -> int:
    if len(argv) < 3:
        return _usage()

    group = argv[1]
    action = argv[2]
    args = argv[3:]
    real_apply = False
    if "--real" in args:
        real_apply = True
        args = [arg for arg in args if arg != "--real"]

    if group not in COMMANDS or action not in COMMANDS[group]:
        return _usage()

    if (group, action) not in NO_PATH_ACTIONS and not args:
        print(f"{group} {action} requires a config or artifact path", file=sys.stderr)
        return 2

    normalized_args: list[str] = []
    try:
        normalized_args = args if (group, action) in NON_PATH_ARGUMENT_ACTIONS else [_validate_path(arg) for arg in args]
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2

    if real_apply and _should_run_real_action_with_systemd(action):
        return _run_real_action_with_systemd(group, action, normalized_args)

    record = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "helper": "labfoundry-helper",
        "group": group,
        "action": action,
        "args": normalized_args,
        "dry_run": not real_apply,
    }

    print(json.dumps(record, sort_keys=True))
    if record["dry_run"]:
        return 0

    if group == "staging":
        return _handle_staging(action, normalized_args)
    if group == "firewall":
        return _handle_firewall(action, normalized_args)
    if group == "network":
        return _handle_network(action, normalized_args)
    if group == "wan":
        return _handle_wan(action, normalized_args)
    if group == "dnsmasq":
        return _handle_dnsmasq(action, normalized_args)
    if group == "esxi-pxe":
        return _handle_esxi_pxe(action, normalized_args)
    if group == "esx-storage":
        return _handle_esx_storage(action, normalized_args)
    if group == "appliance-settings":
        return _handle_appliance_settings(action, normalized_args)
    if group == "web-terminal":
        return _handle_web_terminal(action, normalized_args)
    if group == "local-users":
        return _handle_local_users(action, normalized_args)
    if group == "ca":
        return _handle_ca(action, normalized_args)
    if group == "kms":
        return _handle_kms(action, normalized_args)
    if group == "ldap":
        return _handle_ldap(action, normalized_args)
    if group == "ntpd":
        return _handle_ntpd(action, normalized_args)
    if group == "nginx":
        return _handle_nginx(action, normalized_args)
    if group == "vcf-backups":
        return _handle_vcf_backups(action, normalized_args)
    if group == "vcf-offline-depot":
        return _handle_vcf_offline_depot(action, normalized_args)
    if group == "public-services":
        return _handle_public_services(action, normalized_args)
    if group == "appliance-update":
        return _handle_appliance_update(action, normalized_args)
    if group == "automation":
        return _handle_automation(action, normalized_args)
    if group == "appliance-power":
        return _handle_appliance_power(action, normalized_args)
    if group == "console":
