def _pem_errors(value: str, label: str, *, private_key: bool = False) -> list[str]:
    begin = "PRIVATE KEY" if private_key else "CERTIFICATE"
    if f"-----BEGIN {begin}-----" not in value or f"-----END {begin}-----" not in value:
        return [f"{label} must contain a PEM {begin.lower()} block."]
    return []


def _openssl_public_key(value: str, *, private_key: bool) -> str | None:
    openssl = shutil.which("openssl")
    if openssl is None:
        return None
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", delete=False) as temp_file:
        temp_file.write(value)
        temp_path = Path(temp_file.name)
    try:
        command = [openssl, "pkey", "-pubout", "-in", str(temp_path)] if private_key else [openssl, "x509", "-pubkey", "-noout", "-in", str(temp_path)]
        result = _run(command)
        if result.returncode != 0:
            return ""
        return result.stdout.strip()
    finally:
        temp_path.unlink(missing_ok=True)


def _ca_key_matches_certificate(certificate_pem: str, private_key_pem: str) -> bool | None:
    cert_public = _openssl_public_key(certificate_pem, private_key=False)
    key_public = _openssl_public_key(private_key_pem, private_key=True)
    if cert_public is None or key_public is None:
        return None
    return bool(cert_public and key_public and cert_public == key_public)


def _load_ca_payload(path: Path) -> dict:
    try:
        with path.open("r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except json.JSONDecodeError as exc:
        raise ValueError(f"CA config is not valid JSON: {exc}") from exc
    if not isinstance(payload, dict):
        raise ValueError("CA config root must be a JSON object")
    return payload


def _ca_payload_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        payload = _load_ca_payload(path)
    except ValueError as exc:
        return [str(exc)]
    root = payload.get("root") if isinstance(payload.get("root"), dict) else {}
    enabled = bool(payload.get("enabled"))
    root_cert = str(root.get("certificate_pem") or "")
    root_key = str(root.get("private_key_pem") or "")
    errors.extend(_pem_errors(root_cert, "root certificate"))
    if enabled:
        errors.extend(_pem_errors(root_key, "root private key", private_key=True))
    for label in ["root_cert_path", "legacy_root_cert_path", "ca_bundle_path"]:
        try:
            _ca_managed_path(str(root.get(label) or ""), label)
        except ValueError as exc:
            errors.append(str(exc))
    certificates = payload.get("certificates")
    if not isinstance(certificates, list):
        errors.append("CA certificates must be a list.")
        return errors
    for index, certificate in enumerate(certificates, start=1):
        if not isinstance(certificate, dict):
            errors.append(f"CA certificate {index} must be an object.")
            continue
        name = str(certificate.get("common_name") or f"certificate {index}")
        certificate_pem = str(certificate.get("certificate_pem") or "")
        private_key_pem = str(certificate.get("private_key_pem") or "")
        chain_pem = str(certificate.get("chain_pem") or "")
        errors.extend(_pem_errors(certificate_pem, f"certificate {name}"))
        if chain_pem:
            errors.extend(_pem_errors(chain_pem, f"certificate {name} chain"))
        key_path_value = str(certificate.get("key_path") or "")
        if key_path_value and not private_key_pem:
            errors.append(f"certificate {name} key_path requires a private key.")
        if private_key_pem:
            errors.extend(_pem_errors(private_key_pem, f"certificate {name} private key", private_key=True))
            matches = _ca_key_matches_certificate(certificate_pem, private_key_pem)
            if matches is False:
                errors.append(f"certificate {name} private key does not match the certificate public key.")
        for label in ["cert_path", "key_path", "chain_path"]:
            value = str(certificate.get(label) or "")
            if value:
                try:
                    _ca_managed_path(value, f"certificate {name} {label}")
                except ValueError as exc:
                    errors.append(str(exc))
    return errors


def _write_secret_file(path: Path, value: str, mode: int) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(value, encoding="utf-8")
    path.chmod(mode)


def _handle_ca(action: str, args: list[str]) -> int:
    try:
        config_path = _validate_ca_config_path(args[0])
    except (IndexError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _ca_payload_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    if action == "validate":
        print(json.dumps({"ca": "validation complete", "config_path": str(config_path)}, sort_keys=True))
        return 0
    payload = _load_ca_payload(config_path)
    root = payload["root"]
    root_cert = str(root["certificate_pem"])
    root_cert_path = _ca_managed_path(str(root["root_cert_path"]), "root_cert_path")
    legacy_root_path = _ca_managed_path(str(root["legacy_root_cert_path"]), "legacy_root_cert_path")
    bundle_path = _ca_managed_path(str(root["ca_bundle_path"]), "ca_bundle_path")
    _write_secret_file(root_cert_path, root_cert, 0o644)
    _write_secret_file(legacy_root_path, root_cert, 0o644)
    _write_secret_file(bundle_path, root_cert, 0o644)
    written = [str(root_cert_path), str(legacy_root_path), str(bundle_path)]
    for certificate in payload["certificates"]:
        cert_path_value = str(certificate.get("cert_path") or "")
        key_path_value = str(certificate.get("key_path") or "")
        chain_path_value = str(certificate.get("chain_path") or "")
        if cert_path_value:
            cert_path = _ca_managed_path(cert_path_value, "cert_path")
            _write_secret_file(cert_path, str(certificate["certificate_pem"]), 0o644)
            written.append(str(cert_path))
        if chain_path_value:
            chain_path = _ca_managed_path(chain_path_value, "chain_path")
            _write_secret_file(chain_path, str(certificate.get("chain_pem") or certificate["certificate_pem"]), 0o644)
            written.append(str(chain_path))
        if key_path_value and certificate.get("private_key_pem"):
            key_path = _ca_managed_path(key_path_value, "key_path")
            _write_secret_file(key_path, str(certificate["private_key_pem"]), 0o600)
            written.append(str(key_path))
    print(json.dumps({"ca": "apply complete", "config_path": str(config_path), "written_files": written}, sort_keys=True))
    return 0




def _validate_dnsmasq_config(path: Path) -> subprocess.CompletedProcess[str]:
    dnsmasq = shutil.which("dnsmasq")
    if dnsmasq is None:
        return subprocess.CompletedProcess(["dnsmasq", "--test", f"--conf-file={path}"], 127, "", "dnsmasq command not found\n")
    return _run([dnsmasq, "--test", f"--conf-file={path}"])


def _install_dnsmasq_service_dropin() -> None:
    dnsmasq = shutil.which("dnsmasq") or "/usr/sbin/dnsmasq"
    DNSMASQ_SERVICE_DROPIN_DIR.mkdir(parents=True, exist_ok=True)
    DNSMASQ_SERVICE_DROPIN_PATH.write_text(
        "\n".join(
            [
                "[Service]",
                "ExecStart=",
                f"ExecStart={dnsmasq} --keep-in-foreground --conf-file={DNSMASQ_CONFIG_PATH}",
                "",
            ]
        ),
        encoding="utf-8",
    )


def _read_dnsmasq_leases() -> int:
    lease_path = DNSMASQ_LEASE_FILE_PATH.resolve()
    if not lease_path.is_relative_to(DNSMASQ_STATE_DIR.resolve()):
        print(f"dnsmasq lease file must stay under {DNSMASQ_STATE_DIR}", file=sys.stderr)
        return 2
    if not lease_path.exists():
        return 0
    if not lease_path.is_file():
        print(f"dnsmasq lease path is not a regular file: {lease_path}", file=sys.stderr)
        return 2
    print(lease_path.read_text(encoding="utf-8"), end="")
    return 0


def _write_management_resolver(servers: list[str], domains: list[str]) -> None:
    if NETWORKD_MGMT_CONFIG_PATH.is_file():
        lines = NETWORKD_MGMT_CONFIG_PATH.read_text(encoding="utf-8").splitlines()
        updated: list[str] = []
        in_network = False
        inserted = False
        for line in lines:
            stripped = line.strip()
            if stripped == "[Network]":
                in_network = True
                updated.append(line)
                continue
            if in_network and stripped.startswith("[") and stripped.endswith("]"):
                if not inserted:
                    updated.extend([f"DNS={server}" for server in servers])
                    updated.extend([f"Domains={domain}" for domain in domains])
                    inserted = True
                in_network = False
            if in_network and (stripped.startswith("DNS=") or stripped.startswith("Domains=")):
                continue
            updated.append(line)
        if in_network and not inserted:
            updated.extend([f"DNS={server}" for server in servers])
            updated.extend([f"Domains={domain}" for domain in domains])
        NETWORKD_MGMT_CONFIG_PATH.write_text("\n".join(updated).rstrip() + "\n", encoding="utf-8")


def _configure_resolver(interface_name: str, servers: list[str], domains: list[str]) -> subprocess.CompletedProcess[str]:
    _write_management_resolver(servers, domains)
    commands = [
        ["resolvectl", "dns", interface_name, *servers],
        ["resolvectl", "domain", interface_name, *(domains or [""])],
    ]
    for command in commands:
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0:
            return result
    return subprocess.CompletedProcess(commands[-1], 0, "", "")


def _configure_local_resolver() -> subprocess.CompletedProcess[str]:
    return _configure_resolver("eth0", ["127.0.0.1"], ["~."])


def _handle_dnsmasq(action: str, args: list[str]) -> int:
    if action == "leases":
        if args:
            print("dnsmasq leases does not accept a path", file=sys.stderr)
            return 2
        return _read_dnsmasq_leases()

    if action in {"validate", "apply"}:
        try:
            config_path = _validate_dnsmasq_config_path(args[0])
        except (IndexError, ValueError) as exc:
            print(str(exc), file=sys.stderr)
            return 2

        validation = _validate_dnsmasq_config(config_path)
        print(validation.stdout, end="")
        print(validation.stderr, end="", file=sys.stderr)
        if action == "validate" or validation.returncode != 0:
            return validation.returncode

        DNSMASQ_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        DNSMASQ_STATE_DIR.mkdir(parents=True, exist_ok=True)
        shutil.copy2(config_path, DNSMASQ_CONFIG_PATH)
        _install_dnsmasq_service_dropin()
        daemon_reload = _run(["systemctl", "daemon-reload"])
        print(daemon_reload.stdout, end="")
        print(daemon_reload.stderr, end="", file=sys.stderr)
        if daemon_reload.returncode != 0:
            return daemon_reload.returncode
        enable = _run(["systemctl", "enable", "dnsmasq"])
        print(enable.stdout, end="")
        print(enable.stderr, end="", file=sys.stderr)
        if enable.returncode != 0:
            return enable.returncode
        restart = _run(["systemctl", "reload-or-restart", "dnsmasq"])
        print(restart.stdout, end="")
        print(restart.stderr, end="", file=sys.stderr)
        return restart.returncode

    if action == "reload":
        daemon_reload = _run(["systemctl", "daemon-reload"])
        print(daemon_reload.stdout, end="")
        print(daemon_reload.stderr, end="", file=sys.stderr)
        if daemon_reload.returncode != 0:
            return daemon_reload.returncode
        restart = _run(["systemctl", "reload-or-restart", "dnsmasq"])
        print(restart.stdout, end="")
        print(restart.stderr, end="", file=sys.stderr)
        if restart.returncode != 0:
            return restart.returncode
        return restart.returncode

    print(f"unsupported dnsmasq action: {action}", file=sys.stderr)
    return 2


def _validate_esxi_pxe_config_path(path_value: str) -> Path:
    path = Path(path_value).resolve()
    if path.suffix != ".json":
        raise ValueError("ESXi PXE manifest path must end with .json")
    if not path.is_relative_to(ESXI_PXE_APPLY_DIR):
        raise ValueError(f"ESXi PXE manifest must be staged under {ESXI_PXE_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"ESXi PXE manifest does not exist: {path}")
    return path


def _load_esxi_pxe_manifest(path: Path) -> dict:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise ValueError(f"ESXi PXE manifest is not valid JSON: {exc}") from exc
    if payload.get("kind") != "labfoundry-esxi-pxe":
        raise ValueError("ESXi PXE manifest kind is invalid")
    if payload.get("schema_version") != 1:
        raise ValueError("ESXi PXE manifest schema version is not supported")
    if Path(str(payload.get("http_root") or "")).resolve() != ESXI_PXE_HTTP_ROOT:
        raise ValueError(f"ESXi PXE http_root must be {ESXI_PXE_HTTP_ROOT}")
    if Path(str(payload.get("installer_iso_root") or ESXI_INSTALLER_ISO_ROOT)).resolve() != ESXI_INSTALLER_ISO_ROOT.resolve():
        raise ValueError(f"ESXi PXE installer_iso_root must be {ESXI_INSTALLER_ISO_ROOT}")
    if not isinstance(payload.get("kickstarts"), list):
        raise ValueError("ESXi PXE manifest kickstarts must be a list")
    if not isinstance(payload.get("hosts"), list):
        raise ValueError("ESXi PXE manifest hosts must be a list")
    return payload


def _esxi_pxe_manifest_errors(payload: dict) -> list[str]:
    errors: list[str] = []
    seen_ids: set[int] = set()
    iso_root = ESXI_INSTALLER_ISO_ROOT.resolve()
    for row in payload.get("kickstarts", []):
        if not isinstance(row, dict):
            errors.append("Kickstart entry must be an object.")
            continue
        try:
            kickstart_id = int(row.get("id"))
        except (TypeError, ValueError):
            errors.append("Kickstart id must be an integer.")
            continue
        if kickstart_id in seen_ids:
            errors.append(f"Kickstart {kickstart_id} is duplicated.")
        seen_ids.add(kickstart_id)
        generated_path = Path(str(row.get("generated_path") or "")).resolve()
        expected_path = (ESXI_PXE_HTTP_ROOT / f"{kickstart_id}.cfg").resolve()
        if generated_path != expected_path:
            errors.append(f"Kickstart {kickstart_id} generated_path must be {expected_path}.")
        content = str(row.get("content") or "")
        if row.get("enabled") and not content.strip():
            errors.append(f"Kickstart {kickstart_id} content is empty.")
        expected_hash = str(row.get("content_hash") or "")
        actual_hash = hashlib.sha256(content.encode("utf-8")).hexdigest()
        if expected_hash and expected_hash != actual_hash:
            errors.append(f"Kickstart {kickstart_id} content hash does not match manifest content.")
    for host in payload.get("hosts", []):
        if not isinstance(host, dict):
            errors.append("ESXi PXE host entry must be an object.")
            continue
        kickstart_id = host.get("kickstart_id")
        if host.get("enabled") and kickstart_id is not None and int(kickstart_id) not in seen_ids:
            errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} references missing Kickstart {kickstart_id}.")
        installer_iso_path = str(host.get("installer_iso_path") or "").strip()
        if installer_iso_path:
            selected_iso = Path(installer_iso_path)
            if not selected_iso.is_absolute():
                selected_iso = iso_root / installer_iso_path
            selected_iso = selected_iso.resolve()
            if selected_iso != iso_root and iso_root not in selected_iso.parents:
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} installer ISO must be under {iso_root}.")
            elif selected_iso.suffix.lower() != ".iso":
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} installer ISO must be a .iso file.")
            elif not selected_iso.is_file():
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} installer ISO is missing: {selected_iso}.")
    return errors


def _apply_esxi_pxe_manifest(payload: dict) -> int:
    ESXI_PXE_HTTP_ROOT.mkdir(parents=True, exist_ok=True)
    ESXI_INSTALLER_ISO_ROOT.mkdir(parents=True, exist_ok=True)
    enabled_ids: set[str] = set()
    generated_files: list[str] = []
    for row in payload.get("kickstarts", []):
        kickstart_id = str(int(row["id"]))
        generated_path = ESXI_PXE_HTTP_ROOT / f"{kickstart_id}.cfg"
        if row.get("enabled"):
            generated_path.write_text(str(row.get("content") or ""), encoding="utf-8")
            generated_path.chmod(0o644)
            enabled_ids.add(kickstart_id)
            generated_files.append(str(generated_path))
    for path in ESXI_PXE_HTTP_ROOT.glob("*.cfg"):
        if path.stem.isdigit() and path.stem not in enabled_ids:
            path.unlink(missing_ok=True)
    print(
        json.dumps(
            {
                "esxi_pxe": "apply complete",
                "generated_files": generated_files,
                "enabled_kickstarts": len(enabled_ids),
            },
            sort_keys=True,
        )
    )
    return 0


def _handle_esxi_pxe(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"esxi-pxe {action} requires exactly one staged manifest path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_esxi_pxe_config_path(args[0])
        payload = _load_esxi_pxe_manifest(config_path)
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _esxi_pxe_manifest_errors(payload)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    if action == "validate":
        print(
            json.dumps(
                {
                    "esxi_pxe": "validation ok",
                    "kickstarts": len(payload.get("kickstarts", [])),
                    "hosts": len(payload.get("hosts", [])),
                },
                sort_keys=True,
            )
        )
        return 0
    if action == "apply":
        return _apply_esxi_pxe_manifest(payload)
    print(f"unsupported esxi-pxe action: {action}", file=sys.stderr)
    return 2


def _kms_config_enabled(path: Path) -> bool:
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        stripped = raw_line.strip().lower()
        if stripped.startswith("# labfoundry kms enabled:"):
            return stripped.rsplit(":", 1)[1].strip() == "true"
    return False


def _read_kms_config(path: Path) -> configparser.ConfigParser:
    parser = configparser.ConfigParser()
    parser.read(path)
    return parser


def _kms_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return [str(exc)]
    if not text.startswith("# Managed by LabFoundry."):
        errors.append("KMS config must be rendered by LabFoundry.")
    parser = _read_kms_config(path)
    if not parser.has_section("server"):
        return [*errors, "KMS config must include a [server] section."]
    required = {
        "hostname",
        "port",
        "certificate_path",
        "key_path",
        "ca_path",
        "auth_suite",
        "policy_path",
        "enable_tls_client_auth",
        "logging_level",
        "database_path",
    }
    server_options = {option.lower() for option in parser.options("server")}
    missing = sorted(required - server_options)
    errors.extend(f"KMS config is missing {option}." for option in missing)
    if missing:
        return errors
    host = parser.get("server", "hostname").strip()
    try:
        ip_address(host)
    except ValueError:
        errors.append("KMS hostname must be the derived listen IP address.")
    try:
        port = parser.getint("server", "port")
        if port < 1 or port > 65535:
            errors.append("KMS port must be between 1 and 65535.")
    except ValueError:
        errors.append("KMS port must be an integer.")
    if parser.get("server", "auth_suite").strip() != "TLS1.2":
        errors.append("KMS auth_suite must be TLS1.2.")
    try:
        parser.getboolean("server", "enable_tls_client_auth")
    except ValueError:
        errors.append("KMS enable_tls_client_auth must be true or false.")

    enabled = _kms_config_enabled(path)
    for option, label, private in [
        ("certificate_path", "KMS server certificate", False),
        ("key_path", "KMS server private key", True),
        ("ca_path", "KMS CA certificate", False),
    ]:
        value = parser.get("server", option).strip()
        try:
            managed_path = _ca_managed_path(value, option)
        except ValueError as exc:
            errors.append(str(exc))
            continue
        if enabled:
            if not managed_path.is_file():
                errors.append(f"{label} does not exist: {managed_path}")
                continue
            try:
                errors.extend(_pem_errors(managed_path.read_text(encoding="utf-8"), label, private_key=private))
            except OSError as exc:
                errors.append(str(exc))

    database_path = Path(parser.get("server", "database_path").strip()).resolve()
    if not database_path.is_relative_to(KMS_STATE_DIR):
        errors.append(f"KMS database path must stay under {KMS_STATE_DIR}.")
    policy_path = Path(parser.get("server", "policy_path").strip()).resolve()
    if not policy_path.is_relative_to(KMS_CONFIG_DIR):
        errors.append(f"KMS policy path must stay under {KMS_CONFIG_DIR}.")
    if enabled and _pykmip_server_path() is None:
        errors.append("pykmip-server command not found")
    return errors


def _pykmip_server_path() -> str | None:
    discovered = shutil.which("pykmip-server")
    if discovered:
        return discovered
    if PYKMIP_SERVER_VENV_PATH.exists():
        return str(PYKMIP_SERVER_VENV_PATH)
    return None


def _install_kms_service(config_path: Path) -> None:
    python_path = str(LABFOUNDRY_VENV_PYTHON_PATH if LABFOUNDRY_VENV_PYTHON_PATH.exists() else sys.executable)
    KMS_SERVICE_PATH.parent.mkdir(parents=True, exist_ok=True)
    KMS_SERVICE_PATH.write_text(
        "\n".join(
            [
                "[Unit]",
                "Description=LabFoundry PyKMIP lab KMS",
                "After=network-online.target",
                "Wants=network-online.target",
                "",
                "[Service]",
                "Type=simple",
                f"ExecStart={python_path} {PYKMIP_COMPAT_SCRIPT_PATH} -f {config_path} -l {KMS_LOG_DIR / 'server.log'} -o {KMS_POLICY_DIR} -d {KMS_STATE_DIR / 'pykmip.db'}",
                "Restart=on-failure",
                "RestartSec=5",
                "NoNewPrivileges=true",
                "PrivateTmp=true",
                "ProtectSystem=full",
                "ProtectHome=true",
                f"ReadWritePaths={KMS_STATE_DIR} {KMS_LOG_DIR}",
                "",
                "[Install]",
                "WantedBy=multi-user.target",
                "",
            ]
        ),
        encoding="utf-8",
    )
    os.chmod(KMS_SERVICE_PATH, 0o644)


def _handle_kms(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"kms {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_kms_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _kms_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    enabled = _kms_config_enabled(config_path)
    if action == "validate":
        print(json.dumps({"kms": "validation ok", "enabled": enabled, "scope": "PyKMIP lab KMIP server"}, sort_keys=True))
        return 0

    KMS_STATE_DIR.mkdir(parents=True, exist_ok=True)
    KMS_LOG_DIR.mkdir(parents=True, exist_ok=True)
    KMS_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    KMS_POLICY_DIR.mkdir(parents=True, exist_ok=True)
    PYKMIP_CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    if not enabled:
        disable = _run(["systemctl", "disable", "--now", "labfoundry-kms.service"])
        print(disable.stdout, end="")
        print(disable.stderr, end="", file=sys.stderr)
        if disable.returncode not in {0, 1}:
            return disable.returncode
        print(json.dumps({"kms": "apply complete", "enabled": False, "database_path": str(KMS_STATE_DIR / "pykmip.db")}, sort_keys=True))
        return 0

    shutil.copy2(config_path, KMS_CONFIG_PATH)
    shutil.copy2(config_path, PYKMIP_CONFIG_PATH)
    os.chmod(KMS_CONFIG_PATH, 0o644)
    os.chmod(PYKMIP_CONFIG_PATH, 0o644)
    _install_kms_service(KMS_CONFIG_PATH)
    daemon_reload = _run(["systemctl", "daemon-reload"])
    print(daemon_reload.stdout, end="")
    print(daemon_reload.stderr, end="", file=sys.stderr)
    if daemon_reload.returncode != 0:
        return daemon_reload.returncode
    enable = _run(["systemctl", "enable", "labfoundry-kms.service"])
    print(enable.stdout, end="")
    print(enable.stderr, end="", file=sys.stderr)
    if enable.returncode != 0:
        return enable.returncode
    restart = _run(["systemctl", "restart", "labfoundry-kms.service"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    if restart.returncode != 0:
        return restart.returncode
    print(
        json.dumps(
            {
                "kms": "apply complete",
                "enabled": True,
                "config_path": str(KMS_CONFIG_PATH),
                "database_path": str(KMS_STATE_DIR / "pykmip.db"),
                "service": "labfoundry-kms.service",
            },
            sort_keys=True,
        )
    )
    return 0


def _validate_appliance_settings_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".json":
        raise ValueError("appliance settings config path must end with .json")
    if not path.is_relative_to(APPLIANCE_SETTINGS_APPLY_DIR):
        raise ValueError(f"appliance settings config must be staged under {APPLIANCE_SETTINGS_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"appliance settings config does not exist: {path}")
    return path


def _load_appliance_settings_config(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    if not isinstance(payload, dict):
        raise ValueError("appliance settings config must be a JSON object")
    return payload


def _appliance_settings_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        payload = _load_appliance_settings_config(path)
    except (OSError, json.JSONDecodeError, ValueError) as exc:
        return [str(exc)]

    fqdn = str(payload.get("fqdn") or "").strip().strip(".").lower()
    if not fqdn or not HOSTNAME_PATTERN.fullmatch(fqdn):
        errors.append("fqdn must be a valid fully qualified DNS name.")

    resolver_mode = str(payload.get("resolver_mode") or "")
    local_dns_enabled = bool(payload.get("local_dns_enabled"))
    resolver_servers = [str(server).strip() for server in payload.get("resolver_servers") or [] if str(server).strip()]
    if resolver_mode not in {"local_dns", "external"}:
        errors.append("resolver_mode must be local_dns or external.")
    if resolver_mode == "local_dns":
        if not local_dns_enabled:
            errors.append("local_dns mode requires local_dns_enabled=true.")
        if resolver_servers != ["127.0.0.1"]:
            errors.append("local_dns mode must use resolver server 127.0.0.1.")
    if resolver_mode == "external" and not resolver_servers:
        errors.append("external resolver mode requires at least one resolver server.")
    for server in resolver_servers:
        try:
            ip_interface(f"{server}/32" if ":" not in server else f"{server}/128")
        except ValueError:
            errors.append(f"resolver server {server} must be an IP address.")

    management_interface = str(payload.get("management_interface") or "").strip()
    if not _valid_network_interface_name(management_interface):
        errors.append("management_interface must be a valid interface name.")
    management_ip = str(payload.get("management_ip") or "").strip()
    if not management_ip:
        errors.append("management_ip is required.")
    else:
        try:
            ip_interface(f"{management_ip}/32" if ":" not in management_ip else f"{management_ip}/128")
        except ValueError:
            errors.append("management_ip must be a valid IP address.")

    ntp_servers = [str(server).strip() for server in payload.get("ntp_servers") or [] if str(server).strip()]
    if not ntp_servers:
        errors.append("ntp_servers must include at least one server.")
    for server in ntp_servers:
        try:
            ip_interface(f"{server}/32" if ":" not in server else f"{server}/128")
            continue
        except ValueError:
            pass
        normalized = server.strip().strip(".").lower()
        if not HOSTNAME_PATTERN.fullmatch(normalized):
            errors.append(f"ntp server {server} must be a valid DNS name or IP address.")

    management_http_port = payload.get("management_http_port", 8000)
    try:
        management_http_port = int(management_http_port)
    except (TypeError, ValueError):
        errors.append("management_http_port must be an integer.")
        management_http_port = 0
    if management_http_port < 1 or management_http_port > 65535:
        errors.append("management_http_port must be between 1 and 65535.")
    for field_name in ["management_public_http_port", "management_public_https_port", "management_upstream_port"]:
        value = payload.get(field_name, 80 if field_name.endswith("http_port") else 443 if field_name.endswith("https_port") else management_http_port)
        try:
            port_value = int(value)
        except (TypeError, ValueError):
            errors.append(f"{field_name} must be an integer.")
            continue
        if port_value < 1 or port_value > 65535:
            errors.append(f"{field_name} must be between 1 and 65535.")
    upstream_host = str(payload.get("management_upstream_host") or "127.0.0.1").strip()
    try:
        ip_interface(f"{upstream_host}/32" if ":" not in upstream_host else f"{upstream_host}/128")
    except ValueError:
        errors.append("management_upstream_host must be an IP address.")
    if not isinstance(payload.get("root_ssh_enabled", False), bool):
        errors.append("root_ssh_enabled must be a boolean.")

    if bool(payload.get("management_https_enabled")):
        cert_path_value = str(payload.get("management_https_cert_path") or "")
        key_path_value = str(payload.get("management_https_key_path") or "")
        if not cert_path_value:
            errors.append("management_https_cert_path is required when management HTTPS is enabled.")
        if not key_path_value:
            errors.append("management_https_key_path is required when management HTTPS is enabled.")
        if cert_path_value:
            try:
                cert_path = _ca_managed_path(cert_path_value, "management_https_cert_path")
                if not cert_path.is_file():
                    errors.append(f"management HTTPS certificate does not exist: {cert_path}")
                else:
                    cert_pem = cert_path.read_text(encoding="utf-8")
                    errors.extend(_pem_errors(cert_pem, "management HTTPS certificate"))
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
        if key_path_value:
            try:
                key_path = _ca_managed_path(key_path_value, "management_https_key_path")
                if not key_path.is_file():
                    errors.append(f"management HTTPS private key does not exist: {key_path}")
                else:
                    key_pem = key_path.read_text(encoding="utf-8")
                    errors.extend(_pem_errors(key_pem, "management HTTPS private key", private_key=True))
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
        if cert_path_value and key_path_value:
            try:
                cert_path = _ca_managed_path(cert_path_value, "management_https_cert_path")
                key_path = _ca_managed_path(key_path_value, "management_https_key_path")
                if cert_path.is_file() and key_path.is_file():
                    matches = _ca_key_matches_certificate(cert_path.read_text(encoding="utf-8"), key_path.read_text(encoding="utf-8"))
                    if matches is False:
                        errors.append("management HTTPS private key does not match the certificate public key.")
            except (OSError, ValueError) as exc:
                errors.append(str(exc))
    return errors


def _labfoundry_service_loopback_dropin(host: str, port: int) -> str:
    return "\n".join(
        [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            "[Service]",
            "ExecStart=",
            f"ExecStart={LABFOUNDRY_UVICORN_COMMAND.format(host=host, port=port)}",
            "",
        ]
    )


def _grant_labfoundry_service_key_read(key_path: Path) -> None:
    os.chmod(key_path, 0o640)
    try:
        shutil.chown(key_path, user="root", group="labfoundry")
    except (LookupError, OSError):
        if os.name != "nt":
            raise


def _run_checked_commands(commands: list[list[str]]) -> int:
    for command in commands:
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0:
            return result.returncode
    return 0


def _disable_legacy_http_redirect() -> int:
    commands: list[list[str]] = []
    if LABFOUNDRY_HTTP_REDIRECT_SERVICE_PATH.exists():
        commands.extend([["systemctl", "disable", "--now", "labfoundry-http-redirect.service"], ["systemctl", "daemon-reload"]])
    if LABFOUNDRY_HTTP_REDIRECT_SERVICE_PATH.exists():
        LABFOUNDRY_HTTP_REDIRECT_SERVICE_PATH.unlink()
    if LABFOUNDRY_HTTP_REDIRECT_SCRIPT_PATH.exists():
        LABFOUNDRY_HTTP_REDIRECT_SCRIPT_PATH.unlink()
    return _run_checked_commands(commands)


def _nginx_binary() -> str | None:
