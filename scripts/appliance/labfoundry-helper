def _validate_vcf_backups_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("VCF backups config path must end with .conf")
    if not path.is_relative_to(VCF_BACKUPS_APPLY_DIR):
        raise ValueError(f"VCF backups config must be staged under {VCF_BACKUPS_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"VCF backups config does not exist: {path}")
    return path


def _vcf_backups_config_values(path: Path) -> dict[str, str | bool]:
    values: dict[str, str | bool] = {
        "enabled": False,
        "username": "",
        "storage_path": str(VCF_BACKUPS_DEFAULT_STORAGE_PATH),
        "remote_directory": VCF_BACKUPS_DEFAULT_REMOTE_DIRECTORY,
        "chroot_enabled": False,
    }
    in_match = False
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        stripped = raw_line.strip()
        if not stripped:
            continue
        if stripped.startswith("# LabFoundry VCF Backups enabled:"):
            values["enabled"] = stripped.rsplit(":", 1)[1].strip().lower() == "true"
        elif stripped.startswith("# LabFoundry VCF Backups user:"):
            values["username"] = stripped.rsplit(":", 1)[1].strip()
        elif stripped.startswith("# Backup volume mount:"):
            values["storage_path"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("# VCF remote directory:"):
            values["remote_directory"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("Match User "):
            in_match = True
            values["username"] = stripped.split(None, 2)[2].strip()
        elif in_match and stripped.startswith("ChrootDirectory "):
            values["chroot_enabled"] = True
            values["storage_path"] = stripped.split(None, 1)[1].strip()
        elif in_match and stripped.startswith("ForceCommand internal-sftp -d "):
            values["remote_directory"] = stripped.rsplit(" ", 1)[1].strip()
    return values


def _vcf_backups_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return [str(exc)]
    values = _vcf_backups_config_values(path)
    username = str(values["username"])
    storage_path = str(values["storage_path"])
    remote_directory = str(values["remote_directory"])
    if not text.startswith("# Managed by LabFoundry."):
        errors.append("VCF backups config must be rendered by LabFoundry.")
    if values["enabled"]:
        if not VCF_BACKUPS_USERNAME_PATTERN.fullmatch(username):
            errors.append("VCF backups user must be a local Unix username.")
        if not VCF_BACKUPS_PATH_PATTERN.fullmatch(storage_path):
            errors.append("Backup volume mount must be an absolute Linux path with safe characters.")
        if not VCF_BACKUPS_PATH_PATTERN.fullmatch(remote_directory):
            errors.append("VCF remote directory must be an absolute Linux path with safe characters.")
        if remote_directory != VCF_BACKUPS_DEFAULT_REMOTE_DIRECTORY and bool(values["chroot_enabled"]):
            errors.append(f"Chrooted VCF backups must use remote directory {VCF_BACKUPS_DEFAULT_REMOTE_DIRECTORY}.")
        required = [
            f"Match User {username}",
            "ForceCommand internal-sftp",
            "AllowTcpForwarding no",
            "X11Forwarding no",
            "PermitTTY no",
        ]
        for expected in required:
            if expected not in text:
                errors.append(f"VCF backups config is missing {expected}.")
    return errors


def _ensure_vcf_backups_user(username: str, storage_path: Path) -> int:
    if shutil.which("id") is None:
        print("id command not found", file=sys.stderr)
        return 127
    if _run(["id", username]).returncode == 0:
        return 0
    print(f"VCF backups OS user {username} does not exist. Apply the Local Users unit before VCF Backups.", file=sys.stderr)
    return 2


def _prepare_vcf_backups_storage(username: str, storage_path: Path, remote_directory: str, chroot_enabled: bool) -> int:
    storage_path.mkdir(parents=True, exist_ok=True)
    _chown_path(storage_path, 0, 0)
    os.chmod(storage_path, 0o755)
    writable_path = storage_path / remote_directory.strip("/")
    writable_path.mkdir(parents=True, exist_ok=True)
    chown = _run(["chown", username, str(writable_path)])
    print(chown.stdout, end="")
    print(chown.stderr, end="", file=sys.stderr)
    if chown.returncode != 0:
        return chown.returncode
    os.chmod(writable_path, 0o750 if chroot_enabled else 0o755)
    VCF_BACKUPS_AUTHORIZED_KEYS_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(VCF_BACKUPS_AUTHORIZED_KEYS_DIR, 0o755)
    authorized_keys = VCF_BACKUPS_AUTHORIZED_KEYS_DIR / username
    if not authorized_keys.exists():
        authorized_keys.write_text("", encoding="utf-8")
    _chown_path(authorized_keys, 0, 0)
    os.chmod(authorized_keys, 0o644)
    return 0


def _install_vcf_backups_sshd_include() -> int:
    config_path = Path("/etc/ssh/sshd_config")
    include_line = "Include /etc/ssh/sshd_config.d/*.conf"
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    if include_line not in text:
        config_path.write_text(f"{include_line}\n{text}", encoding="utf-8")
        os.chmod(config_path, 0o644)
    return 0


def _validate_sshd_config() -> subprocess.CompletedProcess[str]:
    sshd = shutil.which("sshd")
    if sshd is not None:
        return _run([sshd, "-t"])
    else:
        sshd = "/usr/sbin/sshd"
        if not Path(sshd).exists():
            return subprocess.CompletedProcess([sshd, "-t"], 127, "", "sshd command not found\n")
    return _run([sshd, "-t"])


def _handle_vcf_backups(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"vcf-backups {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_vcf_backups_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _vcf_backups_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    values = _vcf_backups_config_values(config_path)
    if action == "validate":
        print(
            json.dumps(
                {
                    "vcf_backups": "validation ok",
                    "enabled": values["enabled"],
                    "username": values["username"],
                    "storage_path": values["storage_path"],
                    "remote_directory": values["remote_directory"],
                    "scope": "OpenSSH SFTP Match User drop-in",
                },
                sort_keys=True,
            )
        )
        return 0

    VCF_BACKUPS_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not values["enabled"]:
        if VCF_BACKUPS_CONFIG_PATH.exists():
            VCF_BACKUPS_CONFIG_PATH.unlink()
        restart = _run(["systemctl", "restart", "sshd"])
        print(restart.stdout, end="")
        print(restart.stderr, end="", file=sys.stderr)
        return restart.returncode

    username = str(values["username"])
    storage_path = Path(str(values["storage_path"]))
    remote_directory = str(values["remote_directory"])
    chroot_enabled = bool(values["chroot_enabled"])
    user_result = _ensure_vcf_backups_user(username, storage_path)
    if user_result != 0:
        return user_result
    storage_result = _prepare_vcf_backups_storage(username, storage_path, remote_directory, chroot_enabled)
    if storage_result != 0:
        return storage_result
    include_result = _install_vcf_backups_sshd_include()
    if include_result != 0:
        return include_result
    shutil.copy2(config_path, VCF_BACKUPS_CONFIG_PATH)
    os.chmod(VCF_BACKUPS_CONFIG_PATH, 0o644)
    validation = _validate_sshd_config()
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        VCF_BACKUPS_CONFIG_PATH.unlink(missing_ok=True)
        return validation.returncode
    restart = _run(["systemctl", "restart", "sshd"])
    print(restart.stdout, end="")
    print(restart.stderr, end="", file=sys.stderr)
    if restart.returncode != 0:
        return restart.returncode
    print(
        json.dumps(
            {
                "vcf_backups": "apply complete",
                "config_path": str(VCF_BACKUPS_CONFIG_PATH),
                "storage_path": str(storage_path),
                "remote_directory": remote_directory,
                "username": username,
            },
            sort_keys=True,
        )
    )
    return 0


def _validate_vcf_depot_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("VCF Offline Depot nginx config path must end with .conf")
    if not path.is_relative_to(VCF_DEPOT_APPLY_DIR):
        raise ValueError(f"VCF Offline Depot nginx config must be staged under {VCF_DEPOT_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"VCF Offline Depot nginx config does not exist: {path}")
    return path


def _nginx_directive(text: str, directive: str) -> list[str]:
    values: list[str] = []
    for match in re.finditer(rf"^\s*{re.escape(directive)}\s+([^;]+);", text, flags=re.MULTILINE):
        values.append(match.group(1).strip())
    return values


def _listen_address_and_port(value: str) -> tuple[str, int]:
    parts = value.split()
    listen = parts[0] if parts else ""
    if listen.startswith("[") and "]:" in listen:
        host, port_text = listen.rsplit(":", 1)
        host = host.strip("[]")
    elif ":" in listen:
        host, port_text = listen.rsplit(":", 1)
    else:
        host, port_text = "0.0.0.0", listen
    try:
        port = int(port_text)
    except ValueError as exc:
        raise ValueError(f"nginx listen port is invalid: {listen}") from exc
    if port < 1 or port > 65535:
        raise ValueError(f"nginx listen port must be between 1 and 65535: {listen}")
    try:
        ip_interface(f"{host}/32" if ":" not in host else f"{host}/128")
    except ValueError as exc:
        raise ValueError(f"nginx listen address is invalid: {host}") from exc
    return host, port


def _vcf_depot_config_errors(path: Path) -> list[str]:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return [str(exc)]
    errors: list[str] = []
    if "VCF Offline Depot HTTPS endpoint is disabled" in text:
        return []
    server_names = _nginx_directive(text, "server_name")
    if not server_names:
        errors.append("VCF Offline Depot nginx config must include server_name.")
    else:
        for name in server_names[0].split():
            if not HOSTNAME_PATTERN.fullmatch(name.strip().strip(".").lower()):
                errors.append(f"VCF Offline Depot server_name {name} must be a valid fully qualified DNS name.")
    listens = _nginx_directive(text, "listen")
    if not listens:
        errors.append("VCF Offline Depot nginx config must include listen.")
    for listen in listens:
        try:
            _listen_address_and_port(listen)
        except ValueError as exc:
            errors.append(str(exc))
    roots = _nginx_directive(text, "root")
    if not roots:
        errors.append("VCF Offline Depot nginx config must include root.")
    else:
        if not roots[0].startswith("/"):
            errors.append("VCF Offline Depot root must be an absolute path.")
    for directive, label, private in [
        ("ssl_certificate", "VCF Offline Depot certificate", False),
        ("ssl_certificate_key", "VCF Offline Depot private key", True),
    ]:
        values = _nginx_directive(text, directive)
        if not values:
            errors.append(f"VCF Offline Depot nginx config must include {directive}.")
            continue
        try:
            cert_path = _ca_managed_path(values[0], directive)
            if not cert_path.is_file():
                errors.append(f"{label} does not exist: {cert_path}")
            else:
                errors.extend(_pem_errors(cert_path.read_text(encoding="utf-8"), label, private_key=private))
        except (OSError, ValueError) as exc:
            errors.append(str(exc))
    if "sendfile on;" not in text:
        errors.append("VCF Offline Depot nginx config must enable sendfile for static artifact serving.")
    if "default_type application/octet-stream;" not in text:
        errors.append("VCF Offline Depot nginx config must set default_type application/octet-stream.")
    return errors


def _safe_extract_archive(archive_path: Path, destination: Path) -> None:
    destination_resolved = destination.resolve()
    if destination.exists():
        shutil.rmtree(destination)
    destination.mkdir(parents=True, exist_ok=True)
    with tarfile.open(archive_path, "r:gz") as archive:
        for member in archive.getmembers():
            target = (destination / member.name).resolve()
            if target != destination_resolved and destination_resolved not in target.parents:
                raise ValueError("VCF Download Tool archive contains an unsafe path.")
        archive.extractall(destination)


def _find_vcf_download_tool_binary(extraction_dir: Path) -> Path:
    for candidate in [extraction_dir / "vcf-download-tool", extraction_dir / "bin" / "vcf-download-tool"]:
        if candidate.is_file():
            return candidate
    for candidate in extraction_dir.rglob("vcf-download-tool"):
        if candidate.is_file():
            return candidate
    raise FileNotFoundError("VCF Download Tool archive does not contain a vcf-download-tool executable.")


def _stage_vcf_download_tool_archive(archive_path: Path) -> int:
    extraction_dir = VCF_DEPOT_TOOL_DIR / "extracted"
    try:
        _safe_extract_archive(archive_path, extraction_dir)
        tool_path = _find_vcf_download_tool_binary(extraction_dir)
    except (OSError, tarfile.TarError, ValueError, FileNotFoundError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    tool_path.chmod(tool_path.stat().st_mode | 0o111)
    wrapper_path = VCF_DEPOT_TOOL_DIR / "vcf-download-tool"
    wrapper_path.write_text(
        "\n".join(
            [
                "#!/bin/sh",
                f"exec {shlex_quote(str(tool_path))} \"$@\"",
                "",
            ]
        ),
        encoding="utf-8",
    )
    os.chmod(wrapper_path, 0o755)
    print(
        json.dumps(
            {
                "vcf_offline_depot": "stage-tool complete",
                "archive": archive_path.name,
                "tool_home": str(VCF_DEPOT_TOOL_DIR),
                "executable": str(wrapper_path),
            },
            sort_keys=True,
        )
    )
    return 0


def shlex_quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"


def _handle_vcf_offline_depot(action: str, args: list[str]) -> int:
    if action == "stage-tool":
        if len(args) != 1:
            print("vcf-offline-depot stage-tool requires exactly one archive path", file=sys.stderr)
            return 2
        archive_path = Path(args[0])
        if not archive_path.is_file():
            print(f"VCF Download Tool archive does not exist: {archive_path}", file=sys.stderr)
            return 2
        if not archive_path.name.startswith("vcf-download-tool-") or not archive_path.name.endswith(".tar.gz"):
            print("VCF Download Tool archive must be named vcf-download-tool-*.tar.gz.", file=sys.stderr)
            return 2
        return _stage_vcf_download_tool_archive(archive_path)

    if len(args) != 1:
        print(f"vcf-offline-depot {action} requires exactly one staged nginx config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_vcf_depot_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _vcf_depot_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    text = config_path.read_text(encoding="utf-8")
    disabled = "VCF Offline Depot HTTPS endpoint is disabled" in text

    if action == "validate":
        print(
            json.dumps(
                {
                    "vcf_offline_depot": "validation ok",
                    "enabled": not disabled,
                    "scope": "nginx HTTPS static file server",
                },
                sort_keys=True,
            )
        )
        return 0
    if action == "sync":
        print(json.dumps({"vcf_offline_depot": "sync command intent recorded", "enabled": not disabled}, sort_keys=True))
        return 0
    if action == "apply-https":
        if disabled:
            result = _remove_nginx_site(VCF_DEPOT_SITE_PATH)
        else:
            result = _install_nginx_site(VCF_DEPOT_SITE_PATH, text)
        if result != 0:
            return result
        print(
            json.dumps(
                {
                    "vcf_offline_depot": "https apply complete",
                    "enabled": not disabled,
                    "config_path": str(VCF_DEPOT_SITE_PATH),
                },
                sort_keys=True,
            )
        )
        return 0

    print(f"unsupported vcf-offline-depot action: {action}", file=sys.stderr)
    return 2


def main(argv: list[str]) -> int:
    if len(argv) < 3:
        return _usage()

    group = argv[1]
    action = argv[2]
    args = argv[3:]
    real_apply = False
    if "--real" in args:
        real_apply = True
        args = [arg for arg in args if arg != "--real"]

    if group not in COMMANDS or action not in COMMANDS[group]:
        return _usage()

    if action not in {"leases", "reload"} and not args:
        print(f"{group} {action} requires a config or artifact path", file=sys.stderr)
        return 2

    normalized_args: list[str] = []
    try:
        normalized_args = [_validate_path(arg) for arg in args]
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2

    if real_apply and _should_run_real_action_with_systemd(action):
        return _run_real_action_with_systemd(group, action, normalized_args)

    record = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "helper": "labfoundry-helper",
        "group": group,
        "action": action,
        "args": normalized_args,
        "dry_run": not real_apply,
    }

    print(json.dumps(record, sort_keys=True))
    if record["dry_run"]:
        return 0

    if group == "firewall":
        return _handle_firewall(action, normalized_args)
    if group == "network":
        return _handle_network(action, normalized_args)
    if group == "wan":
        return _handle_wan(action, normalized_args)
    if group == "dnsmasq":
        return _handle_dnsmasq(action, normalized_args)
    if group == "esxi-pxe":
        return _handle_esxi_pxe(action, normalized_args)
    if group == "appliance-settings":
        return _handle_appliance_settings(action, normalized_args)
    if group == "local-users":
        return _handle_local_users(action, normalized_args)
    if group == "ca":
        return _handle_ca(action, normalized_args)
    if group == "kms":
        return _handle_kms(action, normalized_args)
    if group == "vcf-backups":
        return _handle_vcf_backups(action, normalized_args)
    if group == "vcf-offline-depot":
        return _handle_vcf_offline_depot(action, normalized_args)

    print("real helper execution is not implemented for this apply unit", file=sys.stderr)
    return 78


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
