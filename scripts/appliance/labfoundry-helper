            [
                "[Unit]",
                "Description=LabFoundry routing and WAN NAT",
                "After=network-online.target",
                "Wants=network-online.target",
                "",
                "[Service]",
                "Type=oneshot",
                f"ExecStart=/usr/sbin/nft -f {WAN_NAT_CONFIG_PATH}",
                "RemainAfterExit=yes",
                "",
                "[Install]",
                "WantedBy=multi-user.target",
                "",
            ]
        ),
        encoding="utf-8",
    )
    _run(["systemctl", "daemon-reload"])
    _run(["systemctl", "enable", "--now", "labfoundry-nat.service"])


def _apply_wan_nat(parsed: dict[str, list[dict[str, str]]]) -> int:
    nat_config = _render_wan_nat_config(parsed["nat_rules"])
    validation = _validate_wan_nat_config(nat_config)
    print(validation.stdout, end="")
    print(validation.stderr, end="", file=sys.stderr)
    if validation.returncode != 0:
        return validation.returncode
    WAN_NAT_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    tmp_target = WAN_NAT_CONFIG_PATH.with_suffix(".nft.tmp")
    tmp_target.write_text(nat_config, encoding="utf-8")
    os.chmod(tmp_target, 0o644)
    tmp_target.replace(WAN_NAT_CONFIG_PATH)
    enabled_nat = any(_wan_bool(rule.get("enabled", ""), default=True) for rule in parsed["nat_rules"])
    if enabled_nat:
        WAN_SYSCTL_PATH.write_text("net.ipv4.ip_forward = 1\n", encoding="utf-8")
        os.chmod(WAN_SYSCTL_PATH, 0o644)
        sysctl = _run(["sysctl", "-w", "net.ipv4.ip_forward=1"])
        print(sysctl.stdout, end="")
        print(sysctl.stderr, end="", file=sys.stderr)
        if sysctl.returncode != 0:
            return sysctl.returncode
    apply_result = _run(["nft", "-f", str(WAN_NAT_CONFIG_PATH)])
    print(apply_result.stdout, end="")
    print(apply_result.stderr, end="", file=sys.stderr)
    if apply_result.returncode != 0:
        return apply_result.returncode
    _install_wan_nat_service()
    return 0


def _handle_wan(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"wan {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_wan_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _wan_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    parsed = _parse_wan_config(config_path)
    nat_validation = _validate_wan_nat_config(_render_wan_nat_config(parsed["nat_rules"]))
    if action == "validate":
        print(nat_validation.stdout, end="")
        print(nat_validation.stderr, end="", file=sys.stderr)
        if nat_validation.returncode != 0:
            return nat_validation.returncode
        print(
            json.dumps(
                {
                    "wan": "validation ok",
                    "routes": len(parsed["routes"]),
                    "nat_rules": len(parsed["nat_rules"]),
                    "wan_policies": len(parsed["wan_policies"]),
                    "scope": "ip-route nftables tc-netem",
                },
                sort_keys=True,
            )
        )
        return 0
    nat_result = _apply_wan_nat(parsed)
    if nat_result != 0:
        return nat_result
    route_result = _apply_wan_routes_and_qdiscs(parsed)
    if route_result != 0:
        return route_result
    print(
        json.dumps(
            {
                "wan": "apply complete",
                "routes": len(parsed["routes"]),
                "removed_routes": len(parsed["removed_routes"]),
                "nat_rules": len(parsed["nat_rules"]),
                "wan_policies": len(parsed["wan_policies"]),
            },
            sort_keys=True,
        )
    )
    return 0


