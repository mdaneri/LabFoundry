def _run(
    command: list[str], *, timeout: float | None = None, env: dict[str, str] | None = None
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, check=False, capture_output=True, text=True, timeout=timeout, env=env)


def _run_with_input(command: list[str], input_text: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, input=input_text, check=False, capture_output=True, text=True)


def _vcfdt_labfoundry_environment() -> tuple[dict[str, str], int | None, int | None]:
    try:
        account = pwd.getpwnam(LABFOUNDRY_SERVICE_USER)
    except KeyError:
        if os.name == "posix":
            raise
        account = None
    home = Path((getattr(account, "pw_dir", "") if account is not None else "") or str(LABFOUNDRY_STATE_DIR))
    uid = getattr(account, "pw_uid", None)
    gid = getattr(account, "pw_gid", None)
    home_existed = home.exists()
    vdt_state_dir = home / ".local" / "share" / "vmware" / "vdt"
    vdt_state_dir.mkdir(parents=True, exist_ok=True)
    if not home_existed:
        os.chmod(home, 0o750)
    for directory in [home / ".local", home / ".local" / "share", home / ".local" / "share" / "vmware", vdt_state_dir]:
        os.chmod(directory, 0o700)
    if uid is not None and gid is not None:
        for directory in [home, home / ".local", home / ".local" / "share", home / ".local" / "share" / "vmware", vdt_state_dir]:
            _chown_path(directory, uid, gid)
    env = os.environ.copy()
    env.update(
        {
            "HOME": str(home),
            "LOGNAME": LABFOUNDRY_SERVICE_USER,
            "USER": LABFOUNDRY_SERVICE_USER,
            "XDG_DATA_HOME": str(home / ".local" / "share"),
        }
    )
    return env, uid, gid


def _run_vcfdt_user_command(command: list[str], *, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
    env, uid, gid = _vcfdt_labfoundry_environment()
    kwargs: dict[str, object] = {
        "check": False,
        "capture_output": True,
        "text": True,
        "env": env,
    }
    if input_text is not None:
        kwargs["input"] = input_text
    if os.name == "posix" and uid is not None and gid is not None:
        def demote_to_labfoundry() -> None:
            os.initgroups(LABFOUNDRY_SERVICE_USER, gid)
            os.setgid(gid)
            os.setuid(uid)

        kwargs["preexec_fn"] = demote_to_labfoundry
    return subprocess.run(command, **kwargs)


def _run_account_command(command: list[str]) -> subprocess.CompletedProcess[str]:
    if os.environ.get("LABFOUNDRY_HELPER_USE_SYSTEMD_RUN") == "1":
        systemd_run = shutil.which("systemd-run")
        if systemd_run is not None:
            return _run([systemd_run, "--quiet", "--wait", "--pipe", "--collect", "--service-type=exec", *command])
    return _run(command)


def _run_account_command_with_input(command: list[str], input_text: str) -> subprocess.CompletedProcess[str]:
    if os.environ.get("LABFOUNDRY_HELPER_USE_SYSTEMD_RUN") == "1":
        systemd_run = shutil.which("systemd-run")
        if systemd_run is not None:
            return _run_with_input([systemd_run, "--quiet", "--wait", "--pipe", "--collect", "--service-type=exec", *command], input_text)
    return _run_with_input(command, input_text)


def _should_run_real_action_with_systemd(action: str) -> bool:
    return (
        action in SYSTEMD_RUN_REAL_ACTIONS
        and os.environ.get("LABFOUNDRY_HELPER_USE_SYSTEMD_RUN") == "1"
        and os.environ.get(SYSTEMD_RUN_CHILD_ENV) != "1"
        and shutil.which("systemd-run") is not None
    )


def _run_real_action_with_systemd(group: str, action: str, args: list[str]) -> int:
    helper_path = str(Path(__file__).resolve())
    command = [
        shutil.which("systemd-run") or "systemd-run",
        "--quiet",
        "--wait",
        "--pipe",
        "--collect",
        "--service-type=exec",
        f"--setenv={SYSTEMD_RUN_CHILD_ENV}=1",
        helper_path,
        group,
        action,
        "--real",
        *args,
    ]
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _chown_path(path: Path, uid: int, gid: int) -> None:
    chown = getattr(os, "chown", None)
    if chown is not None:
        chown(path, uid, gid)


def _usage() -> int:
    groups = ", ".join(sorted(COMMANDS))
    print(f"usage: labfoundry-helper <group> <action> [--real] [path]", file=sys.stderr)
    print(f"groups: {groups}", file=sys.stderr)
    return 2


def _validate_path(path_value: str) -> str:
    path = Path(path_value)
    if not path.is_absolute():
        raise ValueError(f"path must be absolute: {path_value}")
    return str(path)


def _handle_staging(action: str, args: list[str]) -> int:
    if action != "prepare":
        print(f"unsupported staging action: {action}", file=sys.stderr)
        return 2
    try:
        target = Path(_validate_path(args[0])).resolve()
    except (IndexError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    if not target.is_relative_to(LABFOUNDRY_APPLY_DIR):
        print(f"staging path must be under {LABFOUNDRY_APPLY_DIR}", file=sys.stderr)
        return 2
    directory = target if target.suffix == "" else target.parent
    if not directory.is_relative_to(LABFOUNDRY_APPLY_DIR):
        print(f"staging directory must be under {LABFOUNDRY_APPLY_DIR}", file=sys.stderr)
        return 2
    try:
        LABFOUNDRY_APPLY_DIR.mkdir(parents=True, exist_ok=True)
        directory.mkdir(parents=True, exist_ok=True)
        shutil.chown(LABFOUNDRY_APPLY_DIR, user="labfoundry", group="labfoundry")
        os.chmod(LABFOUNDRY_APPLY_DIR, 0o755)
        shutil.chown(directory, user="labfoundry", group="labfoundry")
        os.chmod(directory, 0o750)
        if target.exists() and target.is_file():
            shutil.chown(target, user="labfoundry", group="labfoundry")
            os.chmod(target, 0o600)
    except OSError as exc:
        print(f"unable to prepare staging path {target}: {exc}", file=sys.stderr)
        return 1
    print(json.dumps({"staging": "prepared", "path": str(target), "directory": str(directory)}, sort_keys=True))
    return 0


