def _local_user_password_policy_errors(password: str, username: str, policy: dict) -> list[str]:
    errors: list[str] = []
    try:
        min_length = int(policy.get("min_length", 12))
    except (TypeError, ValueError):
        min_length = 12
    if len(password) < min_length:
        errors.append(f"local user {username} password must be at least {min_length} characters.")
    if policy.get("require_uppercase", True) and not any(character.isupper() for character in password):
        errors.append(f"local user {username} password must include an uppercase letter.")
    if policy.get("require_lowercase", True) and not any(character.islower() for character in password):
        errors.append(f"local user {username} password must include a lowercase letter.")
    if policy.get("require_number", True) and not any(character.isdigit() for character in password):
        errors.append(f"local user {username} password must include a number.")
    if policy.get("require_special", True) and not any(not character.isalnum() for character in password):
        errors.append(f"local user {username} password must include a special character.")
    normalized_username = username.strip().lower()
    if policy.get("disallow_username", True) and normalized_username and normalized_username in password.lower():
        errors.append(f"local user {username} password must not contain the username.")
    return errors


def _local_users_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        payload = _load_local_users_config(path)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        return [str(exc)]
    if payload.get("managed_by") != "LabFoundry":
        errors.append("local users config must be rendered by LabFoundry.")
    if payload.get("version") != 1:
        errors.append("local users config version must be 1.")
    policy = payload.get("password_policy", {})
    if policy and not isinstance(policy, dict):
        errors.append("local users password_policy must be an object.")
        policy = {}
    if isinstance(policy, dict):
        try:
            min_length = int(policy.get("min_length", 12))
        except (TypeError, ValueError):
            errors.append("local users password_policy min_length must be a number.")
        else:
            if min_length < 8 or min_length > 128:
                errors.append("local users password_policy min_length must be between 8 and 128.")
        for key in ("require_uppercase", "require_lowercase", "require_number", "require_special", "disallow_username"):
            if key in policy and not isinstance(policy.get(key), bool):
                errors.append(f"local users password_policy {key} must be true or false.")
    removed_users = payload.get("removed_users", [])
    if not isinstance(removed_users, list):
        errors.append("local users removed_users must be a list.")
    else:
        for index, removed_username in enumerate(removed_users):
            username = str(removed_username or "").strip().lower()
            if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username):
                errors.append(f"removed local user {username or index} is not a valid Photon OS username.")
            if username in LOCAL_USERS_RESERVED_USERNAMES:
                errors.append(f"removed local user {username} is reserved by Photon OS or LabFoundry.")
    users = payload.get("users")
    if not isinstance(users, list):
        return [*errors, "local users config requires a users list."]
    seen: set[str] = set()
    for index, row in enumerate(users):
        if not isinstance(row, dict):
            errors.append(f"local user row {index} must be an object.")
            continue
        username = str(row.get("username") or "").strip().lower()
        if username in seen:
            errors.append(f"duplicate local user {username}.")
        seen.add(username)
        if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username):
            errors.append(f"local user {username or index} is not a valid Photon OS username.")
        if username in LOCAL_USERS_RESERVED_USERNAMES:
            errors.append(f"local user {username} is reserved by Photon OS or LabFoundry.")
        if row.get("home") != _local_user_home(username):
            errors.append(f"local user {username} home must be {_local_user_home(username)}.")
        shell = str(row.get("shell") or "").strip()
        if shell not in LOCAL_USERS_ALLOWED_SHELLS:
            errors.append(f"local user {username} shell must be one of {', '.join(sorted(LOCAL_USERS_ALLOWED_SHELLS))}.")
        if not isinstance(row.get("enabled"), bool):
            errors.append(f"local user {username} enabled must be true or false.")
        password = row.get("password")
        if password is not None and (not isinstance(password, str) or not password):
            errors.append(f"local user {username} pending password must be a non-empty string when present.")
        elif isinstance(password, str):
            errors.extend(_local_user_password_policy_errors(password, username, policy))
        if "unlock_requested" in row and not isinstance(row.get("unlock_requested"), bool):
            errors.append(f"local user {username} unlock_requested must be true or false.")
    return errors


def _local_users_payload(path: Path) -> dict:
    return _load_local_users_config(path)


def _command_path(command: str) -> str | None:
    found = shutil.which(command)
    if found:
        return found
    fallback = f"/usr/sbin/{command}"
    if Path(fallback).exists():
        return fallback
    return None


def _os_user_exists(username: str) -> bool:
    id_command = _command_path("id")
    return id_command is not None and _run([id_command, username]).returncode == 0


def _run_and_forward(command: list[str], *, account_command: bool = True) -> int:
    result = _run_account_command(command) if account_command else _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _ensure_os_user(username: str, home: str, shell: str) -> int:
    id_command = _command_path("id")
    useradd = _command_path("useradd")
    if id_command is None:
        print("id command not found", file=sys.stderr)
        return 127
    if _os_user_exists(username):
        return 0
    if useradd is None:
        print("useradd command not found", file=sys.stderr)
        return 127
    LOCAL_USERS_HOME_BASE.mkdir(parents=True, exist_ok=True)
    return _run_and_forward([useradd, "--home-dir", home, "--create-home", "--shell", shell, username])


def _set_os_user_shell(username: str, shell: str) -> int:
    usermod = _command_path("usermod")
    if usermod is None:
        print("usermod command not found", file=sys.stderr)
        return 127
    return _run_and_forward([usermod, "--shell", shell, username])


def _ensure_os_user_role_groups(username: str, role: str) -> int:
    id_command = _command_path("id")
    if id_command is None:
        print("id command not found", file=sys.stderr)
        return 127
    usermod = _command_path("usermod")
    groups_result = _run([id_command, "-nG", username])
    if groups_result.returncode != 0:
        print(groups_result.stdout, end="")
        print(groups_result.stderr, end="", file=sys.stderr)
        return groups_result.returncode
    groups = set(groups_result.stdout.split())
    if role == "admin":
        if "wheel" in groups:
            return 0
        if usermod is None:
            print("usermod command not found", file=sys.stderr)
            return 127
        return _run_and_forward([usermod, "--append", "--groups", "wheel", username])
    if "wheel" not in groups:
        return 0
    gpasswd = _command_path("gpasswd")
    if gpasswd is None:
        print("gpasswd command not found", file=sys.stderr)
        return 127
    return _run_and_forward([gpasswd, "--delete", username, "wheel"])


def _unlock_os_user(username: str) -> int:
    passwd = _command_path("passwd")
    if passwd is None:
        print("passwd command not found", file=sys.stderr)
        return 127
    return _run_and_forward([passwd, "-u", username])


def _reset_user_faillock(username: str) -> int:
    faillock = _command_path("faillock")
    if faillock is None:
        return 0
    return _run_and_forward([faillock, "--user", username, "--reset"])


def _delete_os_user(username: str) -> int:
    if not _os_user_exists(username):
        return 0
    userdel = _command_path("userdel")
    if userdel is None:
        print("userdel command not found", file=sys.stderr)
        return 127
    return _run_and_forward([userdel, "-r", username])


def _set_os_user_password(username: str, password: str) -> int:
    chpasswd = _command_path("chpasswd")
    if chpasswd is None:
        print("chpasswd command not found", file=sys.stderr)
        return 127
    result = _run_account_command_with_input([chpasswd], f"{username}:{password}\n")
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    if result.returncode != 0:
        return result.returncode
    unlock = _unlock_os_user(username)
    if unlock != 0:
        return unlock
    return _reset_user_faillock(username)


def _pwquality_policy_lines(policy: dict) -> list[str]:
    def bool_policy(name: str, default: bool = True) -> bool:
        value = policy.get(name, default)
        return bool(value)

    disallow_username = bool_policy("disallow_username")
    return [
        LOCAL_USERS_PWQUALITY_BEGIN,
        f"minlen = {int(policy.get('min_length', 12) or 12)}",
        f"ucredit = {-1 if bool_policy('require_uppercase') else 0}",
        f"lcredit = {-1 if bool_policy('require_lowercase') else 0}",
        f"dcredit = {-1 if bool_policy('require_number') else 0}",
        f"ocredit = {-1 if bool_policy('require_special') else 0}",
        f"usercheck = {1 if disallow_username else 0}",
        f"usersubstr = {3 if disallow_username else 0}",
        "enforcing = 1",
        "enforce_for_root",
        LOCAL_USERS_PWQUALITY_END,
    ]


def _apply_pwquality_conf(policy: dict) -> None:
    current = LOCAL_USERS_PWQUALITY_PATH.read_text(encoding="utf-8") if LOCAL_USERS_PWQUALITY_PATH.exists() else ""
    lines = current.splitlines()
    output: list[str] = []
    in_managed_block = False
    for line in lines:
        if line.strip() == LOCAL_USERS_PWQUALITY_BEGIN:
            in_managed_block = True
            continue
        if line.strip() == LOCAL_USERS_PWQUALITY_END:
            in_managed_block = False
            continue
        if not in_managed_block:
            output.append(line)
    while output and not output[-1].strip():
        output.pop()
    output.extend(["", *_pwquality_policy_lines(policy)])
    LOCAL_USERS_PWQUALITY_PATH.parent.mkdir(parents=True, exist_ok=True)
    LOCAL_USERS_PWQUALITY_PATH.write_text("\n".join(output).strip() + "\n", encoding="utf-8")
    os.chmod(LOCAL_USERS_PWQUALITY_PATH, 0o644)


def _ensure_pam_pwquality() -> None:
    path = LOCAL_USERS_SYSTEM_PASSWORD_PAM_PATH
    if not path.exists():
        return
    lines = path.read_text(encoding="utf-8").splitlines()
    if any("pam_pwquality.so" in line for line in lines):
        return
    insert_at = next((index for index, line in enumerate(lines) if line.strip().startswith("password") and "pam_unix.so" in line), len(lines))
    lines.insert(insert_at, "password  required    pam_pwquality.so  retry=3")
    path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    os.chmod(path, 0o644)


def _apply_local_users_password_policy(policy: dict) -> None:
    _apply_pwquality_conf(policy)
    _ensure_pam_pwquality()


def _passwd_status(username: str) -> tuple[str, str]:
    passwd = _command_path("passwd")
    if passwd is None:
        return "status unavailable", "passwd command not found"
    result = _run([passwd, "-S", username])
    if result.returncode != 0:
        return "status unavailable", (result.stderr or result.stdout).strip()
    parts = result.stdout.strip().split()
    code = parts[1] if len(parts) > 1 else ""
    if code in {"L", "LK"}:
        return "locked", result.stdout.strip()
    if code == "NP":
        return "password not set", result.stdout.strip()
    if code == "P":
        return "present", result.stdout.strip()
    return "present", result.stdout.strip()


def _faillock_blocked(username: str) -> tuple[bool, str]:
    faillock = _command_path("faillock")
    if faillock is None:
        return False, ""
    result = _run([faillock, "--user", username])
    if result.returncode != 0:
        return False, (result.stderr or result.stdout).strip()
    lines = [line.strip() for line in result.stdout.splitlines() if line.strip()]
    if any("Failures" in line for line in lines):
        for line in lines:
            parts = line.split()
            if len(parts) >= 2 and parts[0] == username:
                try:
                    return int(parts[1]) > 0, result.stdout.strip()
                except ValueError:
                    return False, result.stdout.strip()
        return False, result.stdout.strip()
    data_lines = [line for line in lines if not line.endswith(":") and not line.lower().startswith("when ")]
    return bool(data_lines), result.stdout.strip()


def _local_user_status_rows(users: list[dict]) -> list[dict[str, object]]:
    rows: list[dict[str, object]] = []
    for row in users:
        username = str(row.get("username") or "").strip().lower()
        if not username:
            continue
        if not _os_user_exists(username):
            rows.append({"username": username, "state": "absent", "exists": False, "detail": "OS account absent"})
            continue
        state, detail = _passwd_status(username)
        blocked, faillock_detail = _faillock_blocked(username)
        if blocked:
            state = "faillock blocked"
        rows.append(
            {
                "username": username,
                "state": state,
                "exists": True,
                "passwd_status": detail,
                "faillock_blocked": blocked,
                "faillock_status": faillock_detail,
                "detail": faillock_detail if blocked else detail,
            }
        )
    return rows


def _handle_local_users(action: str, args: list[str]) -> int:
    if action == "authenticate":
        if len(args) != 1 or not LOCAL_USERS_USERNAME_PATTERN.fullmatch(args[0]):
            return 1
        password = sys.stdin.readline().removesuffix("\n").removesuffix("\r")
        try:
            password_hash = _shadow_hash_for_user(args[0])
            crypt_library_name = ctypes.util.find_library("crypt") or "libcrypt.so.1"
            crypt_library = ctypes.CDLL(crypt_library_name)
            crypt_library.crypt.argtypes = [ctypes.c_char_p, ctypes.c_char_p]
            crypt_library.crypt.restype = ctypes.c_char_p
            candidate = crypt_library.crypt(password.encode("utf-8"), password_hash.encode("utf-8"))
            candidate_hash = candidate.decode("utf-8") if candidate else ""
        except (OSError, UnicodeError, ValueError):
            return 1
        return 0 if candidate_hash and not candidate_hash.startswith("*") and hmac.compare_digest(candidate_hash, password_hash) else 1
    if len(args) != 1:
        print(f"local-users {action} requires exactly one staged JSON config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_local_users_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _local_users_config_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    payload = _local_users_payload(config_path)
    users = payload["users"]
    policy = payload.get("password_policy") if isinstance(payload.get("password_policy"), dict) else {}
    removed_users = [str(username).strip().lower() for username in payload.get("removed_users", []) if str(username or "").strip()]
    if action == "status":
        print(json.dumps({"local_users": "status ok", "users": _local_user_status_rows(users)}, sort_keys=True))
        return 0
    if action == "validate":
        print(
            json.dumps(
                {
                    "local_users": "validation ok",
                    "users": len(users),
                    "passwords_pending": sum(1 for row in users if row.get("password")),
                    "removed_users": len(removed_users),
                    "unlock_requests": sum(1 for row in users if row.get("unlock_requested")),
                    "scope": "Photon OS local users",
                },
                sort_keys=True,
            )
        )
        return 0

    applied: list[str] = []
    deleted: list[str] = []
    unlocked: list[str] = []
    passwords_updated = 0
    _apply_local_users_password_policy(policy)
    for username in removed_users:
        delete_result = _delete_os_user(username)
        if delete_result != 0:
            return delete_result
        deleted.append(username)
    for row in users:
        username = str(row["username"])
        if not row.get("enabled"):
            delete_result = _delete_os_user(username)
            if delete_result != 0:
                return delete_result
            deleted.append(username)
            continue
        if not _os_user_exists(username) and not row.get("password"):
            print(f"local user {username} is enabled but missing on Photon OS and has no staged password.", file=sys.stderr)
            return 2
        ensure = _ensure_os_user(username, str(row["home"]), str(row["shell"]))
        if ensure != 0:
            return ensure
        shell_result = _set_os_user_shell(username, str(row["shell"]))
        if shell_result != 0:
            return shell_result
        group_result = _ensure_os_user_role_groups(username, str(row.get("role") or ""))
        if group_result != 0:
            return group_result
        if row.get("password"):
            password_result = _set_os_user_password(username, str(row["password"]))
            if password_result != 0:
                return password_result
            passwords_updated += 1
        if row.get("unlock_requested"):
            unlock_result = _unlock_os_user(username)
            if unlock_result != 0:
                return unlock_result
            faillock_result = _reset_user_faillock(username)
            if faillock_result != 0:
                return faillock_result
            unlocked.append(username)
        applied.append(username)
    refresh_result = _refresh_existing_vcf_depot_htpasswd()
    if refresh_result != 0:
        return refresh_result
    print(
        json.dumps(
            {
                "local_users": "apply complete",
                "users": len(users),
                "enabled_users": applied,
                "deleted_users": sorted(set(deleted)),
                "unlocked_users": unlocked,
                "passwords_updated": passwords_updated,
                "password_policy_applied": True,
            },
            sort_keys=True,
        )
    )
    return 0


def _validate_network_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("network config path must end with .conf")
    if not path.is_relative_to(NETWORK_APPLY_DIR):
        raise ValueError(f"network config must be staged under {NETWORK_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"network config does not exist: {path}")
    return path


def _parse_network_config(path: Path) -> tuple[list[dict[str, str]], list[dict[str, str]], list[dict[str, str]]]:
    physical_interfaces: list[dict[str, str]] = []
    vlan_interfaces: list[dict[str, str]] = []
    removed_vlan_interfaces: list[dict[str, str]] = []
    current_section = ""
    current: dict[str, str] | None = None
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            current_section = line.strip("[]")
            current = None
            continue
        if "=" not in line:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        if current_section == "physical_interfaces" and key == "interface":
            current = {"name": value}
            physical_interfaces.append(current)
            continue
        if current_section == "vlan_interfaces" and key == "vlan":
            current = {"name": value}
            vlan_interfaces.append(current)
            continue
        if current_section == "removed_vlan_interfaces" and key == "vlan":
            current = {"name": value}
            removed_vlan_interfaces.append(current)
            continue
        if current is not None:
            current[key] = value
    return physical_interfaces, vlan_interfaces, removed_vlan_interfaces


def _valid_network_interface_name(name: str) -> bool:
    return bool(name and NETWORK_INTERFACE_NAME_PATTERN.fullmatch(name) and "/" not in name)


def _networkd_managed_filename(name: str, suffix: str) -> str:
    if not _valid_network_interface_name(name):
        raise ValueError(f"invalid interface name for systemd-networkd file: {name}")
    return f"{NETWORKD_MANAGED_PREFIX}{name}.{suffix}"


def _read_existing_management_network_values() -> dict[str, list[str]]:
    values: dict[str, list[str]] = {"Gateway": [], "DNS": [], "Name": []}
    try:
        lines = NETWORKD_MGMT_CONFIG_PATH.read_text(encoding="utf-8").splitlines()
    except OSError:
        return values
    current_section = ""
    for raw_line in lines:
        line = raw_line.strip()
        if line.startswith("[") and line.endswith("]"):
            current_section = line.strip("[]")
            continue
        if current_section not in {"Match", "Network", "Route"} or "=" not in line:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        if key == "Name" and current_section == "Match" and value:
            values[key].append(value)
        if key == "DNS" and current_section == "Network" and value:
            values[key].append(value)
        if key == "Gateway" and value:
            values[key].append(value)
    return values


def _usable_management_default_gateways(networks: list[str], candidates: list[str]) -> list[str]:
    parsed_networks = []
    for network in networks:
        try:
            parsed_networks.append(ip_network(network, strict=False))
        except ValueError:
            continue
    selected_by_version: dict[int, str] = {}
    for gateway in candidates:
        try:
            gateway_address = ip_address(gateway)
        except ValueError:
            continue
        if gateway_address.version in selected_by_version:
            continue
        matching_networks = [network for network in parsed_networks if network.version == gateway_address.version]
        if not matching_networks:
            continue
        if gateway_address.version == 6 and gateway_address.is_link_local:
            selected_by_version[gateway_address.version] = str(gateway_address)
            continue
        if any(gateway_address in network for network in matching_networks):
            selected_by_version[gateway_address.version] = str(gateway_address)
    return [selected_by_version[version] for version in sorted(selected_by_version)]


def _systemd_networkd_files(path: Path) -> tuple[dict[str, str], list[str], list[str]]:
    physical_interfaces, vlan_interfaces, _removed_vlan_interfaces = _parse_network_config(path)
    vlans_by_parent: dict[str, list[dict[str, str]]] = {}
    for vlan in vlan_interfaces:
        vlans_by_parent.setdefault(vlan.get("parent", ""), []).append(vlan)

    management = next((row for row in physical_interfaces if row.get("role") == "management"), None)
    if management is None:
        management = next((row for row in physical_interfaces if row.get("name") == "eth0"), None)
    management_name = management.get("name", "eth0") if management else "eth0"
    preserved_management = _read_existing_management_network_values()
    files: dict[str, str] = {}
    reconfigure_links: list[str] = []
    admin_down_links: list[str] = []

    for interface in physical_interfaces:
        name = interface.get("name", "")
        if not _valid_network_interface_name(name):
            raise ValueError(f"invalid physical interface name: {name}")
        if name != management_name and interface.get("admin_state") == "down":
            admin_down_links.append(name)
            continue
        mode = interface.get("mode", "unused")
        ipv4_method = (interface.get("ipv4_method") or "static").strip().lower()
        ipv6_enabled = (interface.get("ipv6_enabled") or ("true" if interface.get("ipv6_cidr") else "false")).strip().lower() == "true"
        lines = [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            "[Match]",
            f"Name={name}",
            "",
            "[Network]",
        ]
        if ipv4_method == "dhcp":
            lines.append("DHCP=ipv4")
        elif interface.get("ip_cidr"):
            lines.append(f"Address={interface['ip_cidr']}")
        if not ipv6_enabled:
            lines.extend(["IPv6AcceptRA=no", "LinkLocalAddressing=no"])
        elif interface.get("ipv6_cidr"):
            lines.extend(["IPv6AcceptRA=no", "LinkLocalAddressing=ipv6"])
            lines.append(f"Address={interface['ipv6_cidr']}")
        else:
            lines.extend(["IPv6AcceptRA=yes", "LinkLocalAddressing=ipv6"])
        if name == management_name:
            for dns in preserved_management["DNS"]:
                lines.append(f"DNS={dns}")
        if mode == "trunk":
            for vlan in sorted(vlans_by_parent.get(name, []), key=lambda row: int(row.get("vlan_id", "0"))):
                lines.append(f"VLAN={vlan['name']}")
        if name == management_name:
            static_management_cidrs = []
            if ipv4_method != "dhcp" and interface.get("ip_cidr"):
                static_management_cidrs.append(interface["ip_cidr"])
            if ipv6_enabled and interface.get("ipv6_cidr"):
                static_management_cidrs.append(interface["ipv6_cidr"])
            gateway_candidates = []
            if "gateway" in interface or "ipv6_gateway" in interface:
                for key in ("gateway", "ipv6_gateway"):
                    if interface.get(key):
                        gateway_candidates.append(interface[key])
            else:
                gateway_candidates.extend(preserved_management["Gateway"])
                if shutil.which("ip") is not None:
                    gateway_candidates.extend(_runtime_default_gateways_for_interface(name))
            usable_gateways = _usable_management_default_gateways(static_management_cidrs, gateway_candidates)
            gateway_versions = {ip_address(gateway).version for gateway in usable_gateways}
            for cidr in static_management_cidrs:
                network = ip_network(cidr, strict=False)
                if network.version not in gateway_versions:
                    continue
                lines.extend(
                    [
                        "",
                        "[RoutingPolicyRule]",
                        f"From={network}",
                        f"Table={MANAGEMENT_ROUTE_TABLE_ID}",
                        f"Priority={MANAGEMENT_ROUTE_RULE_PRIORITY}",
                    ]
                )
            for gateway in usable_gateways:
                lines.extend(
                    [
                        "",
                        "[Route]",
                        f"Gateway={gateway}",
                        "",
                        "[Route]",
                        f"Gateway={gateway}",
                        f"Table={MANAGEMENT_ROUTE_TABLE_ID}",
                    ]
                )
        filename = "00-labfoundry-mgmt.network" if name == management_name else _networkd_managed_filename(name, "network")
        files[filename] = "\n".join(lines).strip() + "\n"
        if name != management_name:
            reconfigure_links.append(name)

    for vlan in vlan_interfaces:
        name = vlan.get("name", "")
        if not _valid_network_interface_name(name):
            raise ValueError(f"invalid VLAN interface name: {name}")
        netdev_lines = [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            "[NetDev]",
            f"Name={name}",
            "Kind=vlan",
            f"MTUBytes={vlan.get('mtu', '1500')}",
            "",
            "[VLAN]",
            f"Id={vlan['vlan_id']}",
        ]
        files[_networkd_managed_filename(name, "netdev")] = "\n".join(netdev_lines).strip() + "\n"
        network_lines = [
            "# Managed by LabFoundry. Local changes may be overwritten.",
            "[Match]",
            f"Name={name}",
            "",
            "[Network]",
            "IPv6AcceptRA=no",
        ]
        if vlan.get("ip_cidr"):
            network_lines.append(f"Address={vlan['ip_cidr']}")
        if vlan.get("ipv6_cidr"):
            network_lines.append(f"Address={vlan['ipv6_cidr']}")
        if not vlan.get("ip_cidr") and not vlan.get("ipv6_cidr"):
            network_lines.append("LinkLocalAddressing=no")
        files[_networkd_managed_filename(name, "network")] = "\n".join(network_lines).strip() + "\n"
        reconfigure_links.append(name)

    return files, reconfigure_links, admin_down_links


def _network_config_errors(path: Path) -> list[str]:
    physical_interfaces, vlan_interfaces, removed_vlan_interfaces = _parse_network_config(path)
    errors: list[str] = []
    physical_modes = {row.get("name", ""): row.get("mode", "") for row in physical_interfaces}
    physical_names = set(physical_modes)
    management_entries = [row for row in physical_interfaces if row.get("role") == "management"]
    if not management_entries:
        errors.append("Network config must include a management physical interface.")
    elif len(management_entries) > 1:
        errors.append("Network config must include only one management physical interface.")
    elif management_entries[0].get("name", "") != "eth0":
        errors.append("Network config must keep eth0 as the management physical interface.")
    for interface in physical_interfaces:
        name = interface.get("name", "")
        role = interface.get("role", "")
        ipv4_method = (interface.get("ipv4_method") or "static").strip().lower()
        ipv6_enabled_value = (interface.get("ipv6_enabled") or ("true" if interface.get("ipv6_cidr") else "false")).strip().lower()
        if not _valid_network_interface_name(name):
            errors.append(f"Interface name {name or '<missing>'} is invalid.")
        if ipv4_method not in {"static", "dhcp"}:
            errors.append(f"Interface {name or '<missing>'} IPv4 method {ipv4_method or '<missing>'} is invalid.")
        if ipv4_method == "dhcp" and role != "management":
            errors.append(f"Interface {name or '<missing>'} can use DHCP only when its role is management.")
        if ipv4_method == "dhcp" and interface.get("ip_cidr"):
            errors.append(f"Interface {name or '<missing>'} cannot set an IPv4 CIDR while IPv4 method is DHCP.")
        if role == "management" and ipv4_method == "static" and not interface.get("ip_cidr"):
            errors.append(f"Interface {name or '<missing>'} must set an IPv4 CIDR when IPv4 method is static.")
        gateway = interface.get("gateway", "").strip()
        if gateway:
            if role != "management" or ipv4_method != "static" or not interface.get("ip_cidr"):
                errors.append(
                    f"Interface {name or '<missing>'} can set an IPv4 gateway only when it is management with static IPv4."
                )
            else:
                try:
                    gateway_address = ip_address(gateway)
                    interface_address = ip_interface(interface["ip_cidr"])
                except ValueError:
                    errors.append(f"Interface {name or '<missing>'} IPv4 gateway {gateway} is invalid.")
                else:
                    if gateway_address.version != 4:
                        errors.append(f"Interface {name or '<missing>'} IPv4 gateway {gateway} uses the wrong IP family.")
                    elif gateway_address not in interface_address.network:
                        errors.append(
                            f"Interface {name or '<missing>'} IPv4 gateway {gateway} is not on-link for {interface['ip_cidr']}."
                        )
                    elif gateway_address == interface_address.ip:
                        errors.append(f"Interface {name or '<missing>'} IPv4 gateway cannot equal its interface address.")
        if ipv6_enabled_value not in {"true", "false"}:
            errors.append(f"Interface {name or '<missing>'} IPv6 enabled value {ipv6_enabled_value or '<missing>'} is invalid.")
        if ipv6_enabled_value == "false" and interface.get("ipv6_cidr"):
            errors.append(f"Interface {name or '<missing>'} cannot set an IPv6 CIDR while IPv6 is disabled.")
        if ipv6_enabled_value == "false" and interface.get("ipv6_gateway"):
            errors.append(f"Interface {name or '<missing>'} cannot set an IPv6 gateway while IPv6 is disabled.")
        ipv6_gateway = interface.get("ipv6_gateway", "").strip()
        if ipv6_gateway:
            if role != "management" or ipv6_enabled_value != "true" or not interface.get("ipv6_cidr"):
                errors.append(
                    f"Interface {name or '<missing>'} can set an IPv6 gateway only when it is management with static IPv6."
                )
            else:
                try:
                    gateway_address = ip_address(ipv6_gateway)
                    interface_address = ip_interface(interface["ipv6_cidr"])
                except ValueError:
                    errors.append(f"Interface {name or '<missing>'} IPv6 gateway {ipv6_gateway} is invalid.")
                else:
                    if gateway_address.version != 6:
                        errors.append(f"Interface {name or '<missing>'} IPv6 gateway {ipv6_gateway} uses the wrong IP family.")
                    elif not gateway_address.is_link_local and gateway_address not in interface_address.network:
                        errors.append(
                            f"Interface {name or '<missing>'} IPv6 gateway {ipv6_gateway} is not link-local or on-link for {interface['ipv6_cidr']}."
                        )
                    elif gateway_address == interface_address.ip:
                        errors.append(f"Interface {name or '<missing>'} IPv6 gateway cannot equal its interface address.")
        for key, version, label in [("ip_cidr", 4, "IPv4 CIDR"), ("ipv6_cidr", 6, "IPv6 CIDR")]:
            value = interface.get(key, "")
            if not value:
                continue
            try:
                parsed = ip_interface(value)
            except ValueError:
                errors.append(f"Interface {name or '<missing>'} {label} {value} is invalid.")
                continue
            if parsed.version != version:
                errors.append(f"Interface {name or '<missing>'} {label} {value} uses the wrong IP family.")
    for vlan in vlan_interfaces:
        name = vlan.get("name", "")
        parent = vlan.get("parent", "")
        raw_vlan_id = vlan.get("vlan_id", "")
        if not name:
            errors.append("VLAN entry is missing a name.")
        elif not _valid_network_interface_name(name):
            errors.append(f"VLAN name {name} is invalid.")
        if parent not in physical_names:
            errors.append(f"VLAN {name or '<unnamed>'} parent {parent or '<missing>'} is not in physical interfaces.")
        elif physical_modes.get(parent) != "trunk":
            errors.append(f"VLAN {name} parent {parent} is not marked trunk.")
        try:
            vlan_id = int(raw_vlan_id)
        except ValueError:
            errors.append(f"VLAN {name or '<unnamed>'} ID is not an integer.")
            vlan_id = 0
        if vlan_id < 1 or vlan_id > 4094:
            errors.append(f"VLAN {name or '<unnamed>'} ID must be between 1 and 4094.")
        expected_name = f"{parent}.{vlan_id}" if parent and vlan_id else ""
        if expected_name and name != expected_name:
            errors.append(f"VLAN {name} should be named {expected_name}.")
        if not vlan.get("ip_cidr") and not vlan.get("ipv6_cidr"):
            errors.append(f"VLAN {name or '<unnamed>'} must include IPv4 CIDR, IPv6 CIDR, or both.")
        for key, version, label in [("ip_cidr", 4, "IPv4 CIDR"), ("ipv6_cidr", 6, "IPv6 CIDR")]:
            value = vlan.get(key, "")
            if not value:
                continue
            try:
                parsed = ip_interface(value)
            except ValueError:
                errors.append(f"VLAN {name} {label} {value} is invalid.")
                continue
            if parsed.version != version:
                errors.append(f"VLAN {name} {label} {value} uses the wrong IP family.")
        try:
            mtu = int(vlan.get("mtu", "1500"))
        except ValueError:
            errors.append(f"VLAN {name or '<unnamed>'} MTU is not an integer.")
            mtu = 0
        if mtu < 576 or mtu > 9000:
            errors.append(f"VLAN {name or '<unnamed>'} MTU must be between 576 and 9000.")
    for vlan in removed_vlan_interfaces:
        name = vlan.get("name", "")
        parent = vlan.get("parent", "")
        raw_vlan_id = vlan.get("vlan_id", "")
        if not name:
            errors.append("Removed VLAN entry is missing a name.")
        elif not _valid_network_interface_name(name):
            errors.append(f"Removed VLAN name {name} is invalid.")
        if not parent:
            errors.append(f"Removed VLAN {name or '<unnamed>'} parent is missing.")
        try:
            vlan_id = int(raw_vlan_id)
        except ValueError:
            errors.append(f"Removed VLAN {name or '<unnamed>'} ID is not an integer.")
            vlan_id = 0
        if vlan_id < 1 or vlan_id > 4094:
            errors.append(f"Removed VLAN {name or '<unnamed>'} ID must be between 1 and 4094.")
        expected_name = f"{parent}.{vlan_id}" if parent and vlan_id else ""
        if expected_name and name != expected_name:
            errors.append(f"Removed VLAN {name} should be named {expected_name}.")
    return errors


def _link_exists(name: str) -> bool:
    return _run(["ip", "link", "show", "dev", name]).returncode == 0


def _is_vlan_link(name: str) -> bool:
    result = _run(["ip", "-j", "-d", "link", "show", "dev", name])
    if result.returncode != 0:
        return False
    try:
        rows = json.loads(result.stdout)
    except json.JSONDecodeError:
        return False
    if not rows:
        return False
    linkinfo = rows[0].get("linkinfo") or {}
    return linkinfo.get("info_kind") == "vlan"


def _apply_vlan_interfaces(path: Path) -> int:
    if shutil.which("ip") is None:
        print("ip command not found", file=sys.stderr)
        return 127
    errors = _network_config_errors(path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    _physical_interfaces, vlan_interfaces, removed_vlan_interfaces = _parse_network_config(path)
    removed_names: list[str] = []
    for vlan in removed_vlan_interfaces:
        name = vlan["name"]
        if not _link_exists(name):
            continue
        if not _is_vlan_link(name):
            print(f"refusing to delete non-VLAN link: {name}", file=sys.stderr)
            return 2
        delete = _run(["ip", "link", "delete", "dev", name])
        print(delete.stdout, end="")
        print(delete.stderr, end="", file=sys.stderr)
        if delete.returncode != 0:
            return delete.returncode
        removed_names.append(name)
    for vlan in vlan_interfaces:
        name = vlan["name"]
        parent = vlan["parent"]
        vlan_id = vlan["vlan_id"]
        mtu = vlan.get("mtu", "1500")
        if not _link_exists(parent):
            print(f"parent interface does not exist: {parent}", file=sys.stderr)
            return 2
        if not _link_exists(name):
            create = _run(["ip", "link", "add", "link", parent, "name", name, "type", "vlan", "id", vlan_id])
            print(create.stdout, end="")
            print(create.stderr, end="", file=sys.stderr)
            if create.returncode != 0:
                return create.returncode
        set_mtu = _run(["ip", "link", "set", "dev", name, "mtu", mtu])
        print(set_mtu.stdout, end="")
        print(set_mtu.stderr, end="", file=sys.stderr)
        if set_mtu.returncode != 0:
            return set_mtu.returncode
        link_up = _run(["ip", "link", "set", "dev", name, "up"])
        print(link_up.stdout, end="")
        print(link_up.stderr, end="", file=sys.stderr)
        if link_up.returncode != 0:
            return link_up.returncode
        flush = _run(["ip", "address", "flush", "dev", name, "scope", "global"])
        print(flush.stdout, end="")
        print(flush.stderr, end="", file=sys.stderr)
        if flush.returncode != 0:
            return flush.returncode
        if vlan.get("ip_cidr"):
            address = _run(["ip", "address", "replace", vlan["ip_cidr"], "dev", name])
            print(address.stdout, end="")
            print(address.stderr, end="", file=sys.stderr)
            if address.returncode != 0:
                return address.returncode
        if vlan.get("ipv6_cidr"):
            address = _run(["ip", "address", "replace", vlan["ipv6_cidr"], "dev", name])
            print(address.stdout, end="")
            print(address.stderr, end="", file=sys.stderr)
            if address.returncode != 0:
                return address.returncode
    print(
        json.dumps(
            {"network": "vlan apply complete", "removed_vlans": removed_names, "vlans": [vlan["name"] for vlan in vlan_interfaces]},
            sort_keys=True,
        )
    )
    return 0


def _install_systemd_networkd_files(path: Path) -> tuple[int, list[str], list[str], list[str]]:
    try:
        files, reconfigure_links, admin_down_links = _systemd_networkd_files(path)
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2, [], [], []
    if shutil.which("networkctl") is None:
        print("networkctl command not found", file=sys.stderr)
        return 127, [], [], []
    NETWORKD_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    for old_path in NETWORKD_CONFIG_DIR.glob(f"{NETWORKD_MANAGED_PREFIX}*"):
        if old_path.is_file() and old_path.suffix in {".network", ".netdev"}:
            old_path.unlink()
    for default_name in NETWORKD_DEFAULT_APPLIANCE_FILES:
        default_path = NETWORKD_CONFIG_DIR / default_name
        if default_path.is_file():
            default_path.unlink()
    installed: list[str] = []
    for filename, content in sorted(files.items()):
        target = NETWORKD_CONFIG_DIR / filename
        tmp_target = target.with_suffix(f"{target.suffix}.tmp")
        tmp_target.write_text(content, encoding="utf-8")
        os.chmod(tmp_target, 0o644)
        tmp_target.replace(target)
        installed.append(str(target))

    reload_result = _run(["networkctl", "reload"])
    print(reload_result.stdout, end="")
    print(reload_result.stderr, end="", file=sys.stderr)
    if reload_result.returncode != 0:
        return reload_result.returncode, installed, reconfigure_links, admin_down_links

    for link in reconfigure_links:
        if not _link_exists(link):
            continue
        reconfigure = _run(["networkctl", "reconfigure", link])
        print(reconfigure.stdout, end="")
        print(reconfigure.stderr, end="", file=sys.stderr)
        if reconfigure.returncode != 0:
            return reconfigure.returncode, installed, reconfigure_links, admin_down_links
    if admin_down_links and shutil.which("ip") is None:
        print("ip command not found", file=sys.stderr)
        return 127, installed, reconfigure_links, admin_down_links
    for link in admin_down_links:
        if not _link_exists(link):
            continue
        link_down = _run(["ip", "link", "set", "dev", link, "down"])
        print(link_down.stdout, end="")
        print(link_down.stderr, end="", file=sys.stderr)
        if link_down.returncode != 0:
            return link_down.returncode, installed, reconfigure_links, admin_down_links
    return 0, installed, reconfigure_links, admin_down_links


def _handle_network(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"network {action} requires exactly one staged config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_network_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _network_config_errors(config_path)
    if action == "validate":
        if errors:
            for error in errors:
                print(error, file=sys.stderr)
            return 2
        try:
            files, reconfigure_links, admin_down_links = _systemd_networkd_files(config_path)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            return 2
        print(
            json.dumps(
                {
                    "network": "validation ok",
                    "admin_down_links": admin_down_links,
                    "networkd_files": sorted(files),
                    "reconfigure_links": reconfigure_links,
                    "scope": "systemd-networkd",
                },
                sort_keys=True,
            )
        )
        return 0
    install_returncode, installed, reconfigure_links, admin_down_links = _install_systemd_networkd_files(config_path)
    if install_returncode != 0:
        return install_returncode
    vlan_returncode = _apply_vlan_interfaces(config_path)
    if vlan_returncode != 0:
        return vlan_returncode
    print(
        json.dumps(
            {
                "network": "systemd-networkd apply complete",
                "admin_down_links": admin_down_links,
                "installed_files": installed,
                "reconfigure_links": reconfigure_links,
            },
            sort_keys=True,
        )
    )
    return 0


def _validate_wan_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".conf":
        raise ValueError("WAN config path must end with .conf")
    if not path.is_relative_to(WAN_APPLY_DIR):
        raise ValueError(f"WAN config must be staged under {WAN_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"WAN config does not exist: {path}")
    return path


def _parse_wan_config(path: Path) -> dict[str, list[dict[str, str]]]:
    sections: dict[str, list[dict[str, str]]] = {
        "targets": [],
        "routes": [],
        "removed_routes": [],
        "routing_rules": [],
        "nat_rules": [],
        "wan_policies": [],
    }
    current_section = ""
    current: dict[str, str] | None = None
    record_keys = {
        "targets": "target",
        "routes": "route",
        "removed_routes": "route",
        "routing_rules": "routing",
        "nat_rules": "nat",
        "wan_policies": "policy",
    }
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            current_section = line.strip("[]")
            current = None
            continue
        if "=" not in line or current_section not in sections:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        if key == record_keys[current_section]:
            name_key = "name"
            if current_section in {"routes", "removed_routes"}:
                name_key = "destination_cidr"
            elif current_section == "targets":
                name_key = "name"
            current = {name_key: value}
            sections[current_section].append(current)
            continue
        if current is not None:
            current[key] = value
    return sections


def _wan_bool(value: str, *, default: bool = False) -> bool:
    if value.strip() == "":
        return default
    return value.strip().lower() in {"1", "true", "yes", "on", "enabled"}


def _wan_config_errors(path: Path) -> list[str]:
    parsed = _parse_wan_config(path)
    errors: list[str] = []
    targets = {row.get("name", ""): row for row in parsed["targets"]}
    policies = {row.get("name", ""): row for row in parsed["wan_policies"]}
    for target in parsed["targets"]:
        name = target.get("name", "")
        if not _valid_network_interface_name(name):
            errors.append(f"WAN target name {name or '<missing>'} is invalid.")
        if not target.get("ip_cidr") and not target.get("ipv6_cidr"):
            errors.append(f"WAN target {name or '<missing>'} must include an IPv4 or IPv6 CIDR.")
        if target.get("gateway"):
            try:
                gateway_address = ip_address(target["gateway"])
            except ValueError:
                errors.append(f"WAN target {name or '<missing>'} gateway {target['gateway']} is not a valid IP address.")
            else:
                target_networks = []
                for key in ("ip_cidr", "ipv6_cidr"):
                    if target.get(key):
                        try:
                            target_networks.append(ip_network(target[key], strict=False))
                        except ValueError:
                            continue
                if not any(
                    network.version == gateway_address.version
                    and (gateway_address in network or (gateway_address.version == 6 and gateway_address.is_link_local))
                    for network in target_networks
                ):
                    errors.append(
                        f"WAN target {name or '<missing>'} gateway {target['gateway']} is not on-link for its configured CIDR."
                    )
        if target.get("ip_cidr"):
            try:
                parsed_interface = ip_interface(target["ip_cidr"])
            except ValueError:
                errors.append(f"WAN target {name} IP CIDR {target['ip_cidr']} is invalid.")
            else:
                if parsed_interface.version != 4:
                    errors.append(f"WAN target {name} IPv4 CIDR must use an IPv4 address.")
        if target.get("ipv6_cidr"):
            try:
                parsed_interface = ip_interface(target["ipv6_cidr"])
            except ValueError:
                errors.append(f"WAN target {name} IPv6 CIDR {target['ipv6_cidr']} is invalid.")
            else:
                if parsed_interface.version != 6:
                    errors.append(f"WAN target {name} IPv6 CIDR must use an IPv6 address.")
        domain = target.get("routing_domain", "lab")
        if domain not in {"management", "lab"}:
            errors.append(f"WAN target {name or '<missing>'} routing domain must be management or lab.")
    for route in [*parsed["routes"], *parsed["removed_routes"]]:
        destination = route.get("destination_cidr", "")
        destination_network = None
        if not destination:
            errors.append("Route entry is missing a destination CIDR.")
        else:
            try:
                destination_network = ip_network(destination, strict=False)
            except ValueError:
                errors.append(f"Route {destination} is not a valid destination CIDR.")
                destination_network = None
        gateway = route.get("gateway", "")
        if gateway:
            try:
                gateway_address = ip_address(gateway)
            except ValueError:
                errors.append(f"Route {destination} gateway {gateway} is not a valid IP address.")
                gateway_address = None
            if destination_network and gateway_address and destination_network.version != gateway_address.version:
                errors.append(f"Route {destination} gateway {gateway} must use the same IP family as the destination.")
        interface_name = route.get("interface", "")
        if interface_name not in targets:
            errors.append(f"Route {destination or '<missing>'} references missing WAN target {interface_name or '<missing>'}.")
        elif targets[interface_name].get("routing_domain", "lab") == "management" or not _wan_bool(
            targets[interface_name].get("route_allowed", "true"),
            default=True,
        ):
            errors.append(f"Route {destination or '<missing>'} cannot target management routing domain {interface_name}.")
        try:
            metric = int(route.get("metric", "100"))
        except ValueError:
            errors.append(f"Route {destination or '<missing>'} metric is not an integer.")
            metric = 0
        if metric < 0:
            errors.append(f"Route {destination or '<missing>'} metric cannot be negative.")
        mode = route.get("wan_mode", "interface")
        if mode and mode != "interface":
            errors.append(
                f"Route {destination or '<missing>'} WAN mode {mode} is planned but not supported in v1; use interface mode."
            )
        policy_name = route.get("wan_policy", "")
        if policy_name and policy_name not in policies:
            errors.append(f"Route {destination or '<missing>'} references missing WAN policy {policy_name}.")
    for rule in parsed["nat_rules"]:
        name = rule.get("name", "")
        if not name:
            errors.append("NAT rule is missing a name.")
        outbound = rule.get("outbound_interface", "")
        if outbound not in targets:
            errors.append(f"NAT rule {name or '<missing>'} must use an access physical interface or enabled VLAN with an IP CIDR.")
        elif targets[outbound].get("routing_domain", "lab") == "management" or not _wan_bool(
            targets[outbound].get("route_allowed", "true"),
            default=True,
        ):
            errors.append(f"NAT rule {name or '<missing>'} cannot use management routing domain {outbound}.")
        elif not targets[outbound].get("ip_cidr"):
            errors.append(f"NAT rule {name or '<missing>'} must use an outbound interface with an IPv4 CIDR.")
        if not _wan_bool(rule.get("masquerade", ""), default=True):
            errors.append(f"NAT rule {name or '<missing>'} must use masquerade; destination NAT is not supported.")
        source = rule.get("source_resolved") or rule.get("source") or "any"
        if source.strip().lower() != "any":
            families: set[int] = set()
            for item in re.split(r"[\n,]+", source):
                value = item.strip()
                if not value:
                    continue
                try:
                    network = ip_network(value, strict=False)
                except ValueError:
                    errors.append(f"NAT rule {name or '<missing>'} source {value} is not a valid CIDR.")
                    continue
                families.add(network.version)
            if 6 in families:
                errors.append(f"NAT rule {name or '<missing>'} uses IPv6; NAT v1 supports IPv4 masquerade only.")
        try:
            priority = int(rule.get("priority", "100"))
        except ValueError:
            errors.append(f"NAT rule {name or '<missing>'} priority is not an integer.")
            priority = 0
        if priority < 0:
            errors.append(f"NAT rule {name or '<missing>'} priority cannot be negative.")
    for rule in parsed["routing_rules"]:
        name = rule.get("name", "")
        source = rule.get("source_interface", "")
        destination = rule.get("destination_interface", "")
        enabled = _wan_bool(rule.get("enabled", ""), default=True)
        if not name:
            errors.append("Routing rule is missing a name.")
        if enabled:
            for label, target_name in [("source", source), ("destination", destination)]:
                if target_name not in targets:
                    errors.append(f"Routing rule {name or '<missing>'} references missing {label} target {target_name or '<missing>'}.")
                elif targets[target_name].get("routing_domain", "lab") == "management" or not _wan_bool(
                    targets[target_name].get("route_allowed", "true"),
                    default=True,
                ):
                    errors.append(f"Routing rule {name or '<missing>'} {label} cannot use management routing domain {target_name}.")
        if enabled and source and destination and source == destination:
            errors.append(f"Routing rule {name or '<missing>'} must use different source and destination interfaces.")
        try:
            priority = int(rule.get("priority", "100"))
        except ValueError:
            errors.append(f"Routing rule {name or '<missing>'} priority is not an integer.")
            priority = 0
        if priority < 0:
            errors.append(f"Routing rule {name or '<missing>'} priority cannot be negative.")
    for policy in parsed["wan_policies"]:
        name = policy.get("name", "")
        if not name:
            errors.append("WAN policy is missing a name.")
        for key in ["latency_ms", "jitter_ms"]:
            try:
                value = int(policy.get(key, "0") or "0")
            except ValueError:
                errors.append(f"WAN policy {name or '<missing>'} {key} is not an integer.")
                value = 0
            if value < 0:
                errors.append(f"WAN policy {name or '<missing>'} {key} cannot be negative.")
        for key in ["packet_loss_percent", "corrupt_percent", "duplicate_percent", "reorder_percent"]:
            try:
                value = float(policy.get(key, "0") or "0")
            except ValueError:
                errors.append(f"WAN policy {name or '<missing>'} {key} is not a number.")
                value = 0.0
            if value < 0 or value > 100:
                errors.append(f"WAN policy {name or '<missing>'} {key} must be between 0 and 100.")
        if policy.get("bandwidth_mbit", ""):
            try:
                bandwidth = int(policy["bandwidth_mbit"])
            except ValueError:
                errors.append(f"WAN policy {name or '<missing>'} bandwidth_mbit is not an integer.")
                bandwidth = 1
            if bandwidth < 1:
                errors.append(f"WAN policy {name or '<missing>'} bandwidth_mbit must be at least 1.")
    return errors


def _wan_source_expr(source: str) -> str:
    value = source.strip()
    if not value or value.lower() == "any":
        return ""
    values = [item.strip() for item in re.split(r"[\n,]+", value) if item.strip()]
    if len(values) == 1:
        return f"ip saddr {values[0]} "
    return f"ip saddr {{ {', '.join(values)} }} "


def _render_wan_nat_config(nat_rules: list[dict[str, str]]) -> str:
    lines = [
        "# Managed by LabFoundry. Local changes may be overwritten.",
        "table ip labfoundry_nat {",
        "  chain postrouting {",
        "    type nat hook postrouting priority srcnat; policy accept;",
    ]
    enabled_rules = [rule for rule in nat_rules if _wan_bool(rule.get("enabled", ""), default=True)]
    for rule in sorted(enabled_rules, key=lambda item: int(item.get("priority", "100") or "100")):
        source = rule.get("source_resolved") or rule.get("source") or "any"
        comment = str(rule.get("name", "LabFoundry NAT")).replace('"', "'")
        lines.append(f'    {_wan_source_expr(source)}oifname "{rule["outbound_interface"]}" masquerade comment "{comment}"')
    lines.extend(["  }", "}", ""])
    return "\n".join(lines)


def _validate_wan_nat_config(nat_config: str) -> subprocess.CompletedProcess[str]:
    if shutil.which("nft") is None:
        return subprocess.CompletedProcess(["nft", "-c", "-f", "-"], 127, "", "nft command not found\n")
    return _run_with_input(["nft", "-c", "-f", "-"], nat_config)


def _wan_netem_args(policy: dict[str, str]) -> list[str]:
    args = ["delay", f"{int(policy.get('latency_ms', '0') or '0')}ms"]
    jitter = int(policy.get("jitter_ms", "0") or "0")
    if jitter:
        args.append(f"{jitter}ms")
    for key, label in [
        ("packet_loss_percent", "loss"),
        ("corrupt_percent", "corrupt"),
        ("duplicate_percent", "duplicate"),
        ("reorder_percent", "reorder"),
    ]:
        value = float(policy.get(key, "0") or "0")
        if value:
            args.extend([label, f"{value}%"])
    if policy.get("bandwidth_mbit", ""):
        args.extend(["rate", f"{int(policy['bandwidth_mbit'])}mbit"])
    return args


def _route_command_prefix(destination: str) -> list[str]:
    try:
        network = ip_network(destination, strict=False)
    except ValueError:
        return ["ip", "route"]
    return ["ip", "-6", "route"] if network.version == 6 else ["ip", "route"]


def _rule_command_prefix(source: str) -> list[str]:
    try:
        network = ip_network(source, strict=False)
    except ValueError:
        return ["ip", "rule"]
    return ["ip", "-6", "rule"] if network.version == 6 else ["ip", "rule"]


def _target_networks(target: dict[str, str]) -> list[str]:
    networks: list[str] = []
    for key in ("ip_cidr", "ipv6_cidr"):
        if target.get(key):
            networks.append(str(ip_network(target[key], strict=False)))
    return networks


def _target_network_owners(targets: list[dict[str, str]]) -> dict[str, int]:
    owners: dict[str, int] = {}
    for index, target in enumerate(targets):
        for network in _target_networks(target):
            owner_index = owners.get(network)
            if owner_index is None:
                owners[network] = index
                continue
            owner = targets[owner_index]
            if owner.get("routing_domain", "lab") != "management" and target.get("routing_domain", "lab") == "management":
                owners[network] = index
    return owners


def _target_route_table_id(target: dict[str, str]) -> int:
    return MANAGEMENT_ROUTE_TABLE_ID if target.get("routing_domain", "lab") == "management" else LAB_ROUTE_TABLE_ID


def _run_target_route_replace(network: str, interface_name: str, table_id: int) -> int:
    command = [*_route_command_prefix(network), "replace", network, "dev", interface_name, "table", str(table_id)]
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _run_target_route_delete(network: str, interface_name: str, table_id: int) -> int:
    command = [*_route_command_prefix(network), "del", network, "dev", interface_name, "table", str(table_id)]
    result = _run(command)
    if result.returncode == 2:
        return 0
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _run_default_gateway_route_replace(gateway: str, interface_name: str, table_id: int | None = None) -> int:
    try:
        gateway_address = ip_address(gateway)
    except ValueError:
        print(f"invalid gateway for {interface_name}: {gateway}", file=sys.stderr)
        return 2
    prefix = ["ip", "-6", "route"] if gateway_address.version == 6 else ["ip", "route"]
    command = [*prefix, "replace", "default", "via", gateway, "dev", interface_name]
    if table_id is not None:
        command.extend(["table", str(table_id)])
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _run_default_gateway_route_delete(interface_name: str, table_id: int | None, version: int) -> int:
    prefix = ["ip", "-6", "route"] if version == 6 else ["ip", "route"]
    command = [*prefix, "del", "default", "dev", interface_name]
    if table_id is not None:
        command.extend(["table", str(table_id)])
    result = _run(command)
    if result.returncode == 2:
        return 0
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _runtime_default_gateways_for_interface(interface_name: str) -> list[str]:
    gateways: list[str] = []
    for prefix in (["ip", "route"], ["ip", "-6", "route"]):
        try:
            result = _run([*prefix, "show", "default", "dev", interface_name])
        except OSError:
            continue
        if result.returncode != 0:
            continue
        for line in result.stdout.splitlines():
            parts = line.split()
            if parts[:1] == ["default"] and "via" in parts:
                gateway = parts[parts.index("via") + 1]
                if gateway not in gateways:
                    gateways.append(gateway)
    return gateways


def _management_default_gateways_for_target(target: dict[str, str]) -> list[str]:
    target_networks = _target_networks(target)
    if "gateway" in target or "ipv6_gateway" in target:
        configured = [target.get(key, "").strip() for key in ("gateway", "ipv6_gateway")]
        return _usable_management_default_gateways(target_networks, [gateway for gateway in configured if gateway])
    candidates: list[str] = []
    interface_name = target.get("name", "")
    preserved = _read_existing_management_network_values()
    management_names = set(preserved.get("Name", []))
    if not management_names or interface_name in management_names:
        candidates.extend(preserved.get("Gateway", []))
    candidates.extend(_runtime_default_gateways_for_interface(interface_name))
    return _usable_management_default_gateways(target_networks, candidates)


def _apply_wan_target_routes(parsed: dict[str, list[dict[str, str]]]) -> int:
    if shutil.which("ip") is None:
        print("ip command not found", file=sys.stderr)
        return 127
    targets = parsed["targets"]
    network_owners = _target_network_owners(targets)
    for index, target in enumerate(targets):
        table_id = _target_route_table_id(target)
        interface_name = target.get("name", "")
        management = target.get("routing_domain", "lab") == "management"
        gateways = _management_default_gateways_for_target(target) if management else []
        gateways_by_version = {ip_address(gateway).version: gateway for gateway in gateways}
        for network in _target_networks(target):
            if network_owners[network] != index:
                result = _run_target_route_delete(network, interface_name, table_id)
                if result != 0:
                    return result
                continue
            network_version = ip_network(network, strict=False).version
            if management and network_version not in gateways_by_version:
                result = _run_target_route_delete(network, interface_name, table_id)
                if result != 0:
                    return result
                continue
            result = _run_target_route_replace(network, interface_name, table_id)
            if result != 0:
                return result
        if management:
            network_versions = {ip_network(network, strict=False).version for network in _target_networks(target)}
            for version in network_versions:
                gateway = gateways_by_version.get(version)
                if gateway is None:
                    result = _run_default_gateway_route_delete(interface_name, table_id, version)
                    if result != 0:
                        return result
                    continue
                result = _run_default_gateway_route_replace(gateway, interface_name, table_id)
                if result != 0:
                    return result
            for version, gateway in gateways_by_version.items():
                result = _run_default_gateway_route_replace(gateway, interface_name)
                if result != 0:
                    return result
            if (
                "gateway" in target
                and not target.get("gateway", "").strip()
                and target.get("ipv4_method", "static").strip().lower() == "static"
            ):
                result = _run_default_gateway_route_delete(interface_name, None, 4)
                if result != 0:
                    return result
            if "ipv6_gateway" in target and not target.get("ipv6_gateway", "").strip() and target.get("ipv6_cidr", "").strip():
                result = _run_default_gateway_route_delete(interface_name, None, 6)
                if result != 0:
                    return result
    return 0


def _run_rule_replace(source_network: str, table_id: int, priority: int) -> int:
    prefix = _rule_command_prefix(source_network)
    delete = _run([*prefix, "del", "priority", str(priority)])
    if delete.returncode not in {0, 2}:
        print(delete.stdout, end="")
        print(delete.stderr, end="", file=sys.stderr)
        return delete.returncode
    add = _run([*prefix, "add", "from", source_network, "table", str(table_id), "priority", str(priority)])
    print(add.stdout, end="")
    print(add.stderr, end="", file=sys.stderr)
    return add.returncode


def _run_rule_priority_delete(prefix: list[str], priority: int) -> int:
    result = _run([*prefix, "del", "priority", str(priority)])
    if result.returncode in {0, 2}:
        return 0
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def _cleanup_wan_policy_rules() -> int:
    prefixes = [["ip", "rule"], ["ip", "-6", "rule"]]
    for base_priority in (MANAGEMENT_ROUTE_RULE_PRIORITY, LAB_ROUTE_RULE_PRIORITY):
        for priority in range(base_priority, base_priority + ROUTE_RULE_PRIORITY_WINDOW):
            for prefix in prefixes:
                result = _run_rule_priority_delete(prefix, priority)
                if result != 0:
                    return result
    return 0


def _apply_wan_policy_rules(parsed: dict[str, list[dict[str, str]]]) -> int:
    if shutil.which("ip") is None:
        print("ip command not found", file=sys.stderr)
        return 127
    cleanup_result = _cleanup_wan_policy_rules()
    if cleanup_result != 0:
        return cleanup_result
    targets = parsed["targets"]
    network_owners = _target_network_owners(targets)
    for index, target in enumerate(targets):
        domain = target.get("routing_domain", "lab")
        table_id = _target_route_table_id(target)
        base_priority = MANAGEMENT_ROUTE_RULE_PRIORITY if domain == "management" else LAB_ROUTE_RULE_PRIORITY
        management_gateway_versions = (
            {ip_address(gateway).version for gateway in _management_default_gateways_for_target(target)}
            if domain == "management"
            else set()
        )
        for source_network in _target_networks(target):
            if network_owners[source_network] != index:
                continue
            if domain == "management" and ip_network(source_network, strict=False).version not in management_gateway_versions:
                continue
            result = _run_rule_replace(source_network, table_id, base_priority + index)
            if result != 0:
                return result
    return 0


def _run_route_delete(destination: str, interface_name: str) -> int:
    command = [*_route_command_prefix(destination), "del", destination, "dev", interface_name, "table", str(LAB_ROUTE_TABLE_ID)]
    result = _run(command)
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    if result.returncode == 2:
        return 0
    return result.returncode


def _apply_wan_routes_and_qdiscs(parsed: dict[str, list[dict[str, str]]]) -> int:
    if shutil.which("ip") is None:
        print("ip command not found", file=sys.stderr)
        return 127
    if shutil.which("tc") is None:
        print("tc command not found", file=sys.stderr)
        return 127
    policies = {policy["name"]: policy for policy in parsed["wan_policies"]}
    touched_qdisc_targets: set[str] = set()
    for route in parsed["routes"]:
        destination = route["destination_cidr"]
        interface_name = route["interface"]
        enabled = _wan_bool(route.get("enabled", ""), default=True)
        if not enabled:
            delete_result = _run_route_delete(destination, interface_name)
            if delete_result != 0:
                return delete_result
            touched_qdisc_targets.add(interface_name)
            continue
        command = [*_route_command_prefix(destination), "replace", destination]
        if route.get("gateway"):
            command.extend(["via", route["gateway"]])
        command.extend(["dev", interface_name, "metric", str(int(route.get("metric", "100") or "100")), "table", str(LAB_ROUTE_TABLE_ID)])
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0:
            return result.returncode
        touched_qdisc_targets.add(interface_name)
    for route in parsed["removed_routes"]:
        delete_result = _run_route_delete(route["destination_cidr"], route["interface"])
        if delete_result != 0:
            return delete_result
        touched_qdisc_targets.add(route["interface"])
    policy_by_target: dict[str, dict[str, str]] = {}
    for route in parsed["routes"]:
        if not _wan_bool(route.get("enabled", ""), default=True):
            continue
        policy_name = route.get("wan_policy", "")
        policy = policies.get(policy_name)
        if policy and _wan_bool(policy.get("enabled", ""), default=True):
            policy_by_target[route["interface"]] = policy
    for interface_name in sorted(touched_qdisc_targets | set(policy_by_target)):
        policy = policy_by_target.get(interface_name)
        if policy:
            command = ["tc", "qdisc", "replace", "dev", interface_name, "root", "netem", *_wan_netem_args(policy)]
        else:
            command = ["tc", "qdisc", "del", "dev", interface_name, "root"]
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0 and not (command[2] == "del" and result.returncode == 2):
            return result.returncode
    return 0


