def _command_path(command: str) -> str | None:
    found = shutil.which(command)
    if found:
        return found
    fallback = f"/usr/sbin/{command}"
    if Path(fallback).exists():
        return fallback
    return None


def _os_user_exists(username: str) -> bool:
    id_command = _command_path("id")
    return id_command is not None and _run([id_command, username]).returncode == 0


