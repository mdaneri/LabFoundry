def _pem_errors(value: str, label: str, *, private_key: bool = False) -> list[str]:
    begin = "PRIVATE KEY" if private_key else "CERTIFICATE"
    if f"-----BEGIN {begin}-----" not in value or f"-----END {begin}-----" not in value:
        return [f"{label} must contain a PEM {begin.lower()} block."]
    return []


def _crl_errors(value: str, label: str) -> list[str]:
    if not value:
        return []
    if "-----BEGIN X509 CRL-----" not in value or "-----END X509 CRL-----" not in value:
        return [f"{label} must contain a PEM X509 CRL block."]
    return []


def _openssl_public_key(value: str, *, private_key: bool) -> str | None:
    openssl = shutil.which("openssl")
    if openssl is None:
        return None
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", delete=False) as temp_file:
        temp_file.write(value)
        temp_path = Path(temp_file.name)
    try:
        command = [openssl, "pkey", "-pubout", "-in", str(temp_path)] if private_key else [openssl, "x509", "-pubkey", "-noout", "-in", str(temp_path)]
        result = _run(command)
        if result.returncode != 0:
            return ""
        return result.stdout.strip()
    finally:
        temp_path.unlink(missing_ok=True)


def _ca_key_matches_certificate(certificate_pem: str, private_key_pem: str) -> bool | None:
    cert_public = _openssl_public_key(certificate_pem, private_key=False)
    key_public = _openssl_public_key(private_key_pem, private_key=True)
    if cert_public is None or key_public is None:
        return None
    return bool(cert_public and key_public and cert_public == key_public)


def _load_ca_payload(path: Path) -> dict:
    try:
        with path.open("r", encoding="utf-8") as handle:
            payload = json.load(handle)
    except json.JSONDecodeError as exc:
        raise ValueError(f"CA config is not valid JSON: {exc}") from exc
    if not isinstance(payload, dict):
        raise ValueError("CA config root must be a JSON object")
    return payload


def _ca_payload_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        payload = _load_ca_payload(path)
    except ValueError as exc:
        return [str(exc)]
    root = payload.get("root") if isinstance(payload.get("root"), dict) else {}
    enabled = bool(payload.get("enabled"))
    root_cert = str(root.get("certificate_pem") or "")
    root_key = str(root.get("private_key_pem") or "")
    errors.extend(_pem_errors(root_cert, "root certificate"))
    if enabled:
        errors.extend(_pem_errors(root_key, "root private key", private_key=True))
    for label in ["root_cert_path", "legacy_root_cert_path", "ca_bundle_path", "crl_path"]:
        if label == "crl_path" and not root.get(label):
            continue
        try:
            _ca_managed_path(str(root.get(label) or ""), label)
        except ValueError as exc:
            errors.append(str(exc))
    errors.extend(_crl_errors(str(root.get("crl_pem") or ""), "CA CRL"))
    certificates = payload.get("certificates")
    if not isinstance(certificates, list):
        errors.append("CA certificates must be a list.")
        return errors
    for index, certificate in enumerate(certificates, start=1):
        if not isinstance(certificate, dict):
            errors.append(f"CA certificate {index} must be an object.")
            continue
        name = str(certificate.get("common_name") or f"certificate {index}")
        certificate_pem = str(certificate.get("certificate_pem") or "")
        private_key_pem = str(certificate.get("private_key_pem") or "")
        chain_pem = str(certificate.get("chain_pem") or "")
        errors.extend(_pem_errors(certificate_pem, f"certificate {name}"))
        if chain_pem:
            errors.extend(_pem_errors(chain_pem, f"certificate {name} chain"))
        key_path_value = str(certificate.get("key_path") or "")
        if key_path_value and not private_key_pem:
            errors.append(f"certificate {name} key_path requires a private key.")
        if private_key_pem:
            errors.extend(_pem_errors(private_key_pem, f"certificate {name} private key", private_key=True))
            matches = _ca_key_matches_certificate(certificate_pem, private_key_pem)
            if matches is False:
                errors.append(f"certificate {name} private key does not match the certificate public key.")
        for label in ["cert_path", "key_path", "chain_path"]:
            value = str(certificate.get(label) or "")
            if value:
                try:
                    _ca_managed_path(value, f"certificate {name} {label}")
                except ValueError as exc:
                    errors.append(str(exc))
    return errors


def _write_secret_file(path: Path, value: str, mode: int) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(value, encoding="utf-8")
    path.chmod(mode)


def _grant_ldap_private_key_read(key_path: Path) -> None:
