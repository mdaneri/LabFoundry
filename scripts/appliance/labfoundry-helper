def _handle_appliance_settings(action: str, args: list[str]) -> int:
    if len(args) != 1:
        print(f"appliance-settings {action} requires exactly one staged JSON config path", file=sys.stderr)
        return 2
    try:
        config_path = _validate_appliance_settings_config_path(args[0])
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _appliance_settings_config_errors(config_path)
    if action == "validate":
        if errors:
            for error in errors:
                print(error, file=sys.stderr)
            return 2
        payload = _load_appliance_settings_config(config_path)
        print(
            json.dumps(
                {
                    "appliance_settings": "validation ok",
                    "resolver_mode": payload["resolver_mode"],
                    "management_https_enabled": bool(payload.get("management_https_enabled")),
                    "root_ssh_enabled": bool(payload.get("root_ssh_enabled")),
                    "management_interface": payload["management_interface"],
                    "scope": "systemd-resolved, systemd-timesyncd, LabFoundry management UI, and root SSH login",
                },
                sort_keys=True,
            )
        )
        return 0
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2

    payload = _load_appliance_settings_config(config_path)
    fqdn = str(payload["fqdn"])
    management_interface = str(payload["management_interface"])
    resolver_mode = str(payload["resolver_mode"])
    resolver_servers = [str(server) for server in payload["resolver_servers"]]
    domains = ["~."] if resolver_mode == "local_dns" else []
    timesyncd = _install_timesyncd_config([str(server) for server in payload["ntp_servers"]])
    if timesyncd != 0:
        return timesyncd
    hostname = _apply_hostname(fqdn)
    if hostname != 0:
        return hostname
    resolver = _configure_resolver(management_interface, resolver_servers, domains)
    if resolver.returncode != 0:
        return resolver.returncode
    root_ssh = _configure_root_ssh(bool(payload.get("root_ssh_enabled")))
    if root_ssh != 0:
        return root_ssh
    management_https = _configure_labfoundry_management_https(payload)
    if management_https != 0:
        return management_https
    print(
        json.dumps(
            {
                "appliance_settings": "apply complete",
                "fqdn": fqdn,
                "management_https_enabled": bool(payload.get("management_https_enabled")),
                "root_ssh_enabled": bool(payload.get("root_ssh_enabled")),
                "resolver_mode": resolver_mode,
                "resolver_servers": resolver_servers,
                "timesyncd_dropin": str(TIMESYNCD_DROPIN_PATH),
            },
            sort_keys=True,
        )
    )
    return 0


def _validate_local_users_config_path(path_value: str) -> Path:
    path = Path(_validate_path(path_value)).resolve()
    if path.suffix != ".json":
        raise ValueError("local users config path must end with .json")
    if not path.is_relative_to(LOCAL_USERS_APPLY_DIR):
        raise ValueError(f"local users config must be staged under {LOCAL_USERS_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"local users config does not exist: {path}")
    return path


def _load_local_users_config(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    if not isinstance(payload, dict):
        raise ValueError("local users config must be a JSON object")
    return payload


def _local_user_home(username: str) -> str:
    return (LOCAL_USERS_HOME_BASE / username).as_posix()


def _local_user_password_policy_errors(password: str, username: str, policy: dict) -> list[str]:
    errors: list[str] = []
    try:
        min_length = int(policy.get("min_length", 12))
    except (TypeError, ValueError):
        min_length = 12
    if len(password) < min_length:
        errors.append(f"local user {username} password must be at least {min_length} characters.")
    if policy.get("require_uppercase", True) and not any(character.isupper() for character in password):
        errors.append(f"local user {username} password must include an uppercase letter.")
    if policy.get("require_lowercase", True) and not any(character.islower() for character in password):
        errors.append(f"local user {username} password must include a lowercase letter.")
    if policy.get("require_number", True) and not any(character.isdigit() for character in password):
        errors.append(f"local user {username} password must include a number.")
    if policy.get("require_special", True) and not any(not character.isalnum() for character in password):
        errors.append(f"local user {username} password must include a special character.")
    normalized_username = username.strip().lower()
    if policy.get("disallow_username", True) and normalized_username and normalized_username in password.lower():
        errors.append(f"local user {username} password must not contain the username.")
    return errors


def _local_users_config_errors(path: Path) -> list[str]:
    errors: list[str] = []
    try:
        payload = _load_local_users_config(path)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        return [str(exc)]
    if payload.get("managed_by") != "LabFoundry":
        errors.append("local users config must be rendered by LabFoundry.")
    if payload.get("version") != 1:
        errors.append("local users config version must be 1.")
    policy = payload.get("password_policy", {})
    if policy and not isinstance(policy, dict):
        errors.append("local users password_policy must be an object.")
        policy = {}
    if isinstance(policy, dict):
        try:
            min_length = int(policy.get("min_length", 12))
        except (TypeError, ValueError):
            errors.append("local users password_policy min_length must be a number.")
        else:
            if min_length < 8 or min_length > 128:
                errors.append("local users password_policy min_length must be between 8 and 128.")
        for key in ("require_uppercase", "require_lowercase", "require_number", "require_special", "disallow_username"):
            if key in policy and not isinstance(policy.get(key), bool):
                errors.append(f"local users password_policy {key} must be true or false.")
    removed_users = payload.get("removed_users", [])
    if not isinstance(removed_users, list):
        errors.append("local users removed_users must be a list.")
    else:
        for index, removed_username in enumerate(removed_users):
            username = str(removed_username or "").strip().lower()
            if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username):
                errors.append(f"removed local user {username or index} is not a valid Photon OS username.")
            if username in LOCAL_USERS_RESERVED_USERNAMES:
                errors.append(f"removed local user {username} is reserved by Photon OS or LabFoundry.")
    users = payload.get("users")
    if not isinstance(users, list):
        return [*errors, "local users config requires a users list."]
    seen: set[str] = set()
    for index, row in enumerate(users):
        if not isinstance(row, dict):
            errors.append(f"local user row {index} must be an object.")
            continue
        username = str(row.get("username") or "").strip().lower()
        if username in seen:
            errors.append(f"duplicate local user {username}.")
        seen.add(username)
        if not LOCAL_USERS_USERNAME_PATTERN.fullmatch(username):
            errors.append(f"local user {username or index} is not a valid Photon OS username.")
        if username in LOCAL_USERS_RESERVED_USERNAMES:
            errors.append(f"local user {username} is reserved by Photon OS or LabFoundry.")
        if row.get("home") != _local_user_home(username):
            errors.append(f"local user {username} home must be {_local_user_home(username)}.")
        shell = str(row.get("shell") or "").strip()
        if shell not in LOCAL_USERS_ALLOWED_SHELLS:
            errors.append(f"local user {username} shell must be one of {', '.join(sorted(LOCAL_USERS_ALLOWED_SHELLS))}.")
        if not isinstance(row.get("enabled"), bool):
            errors.append(f"local user {username} enabled must be true or false.")
        password = row.get("password")
        if password is not None and (not isinstance(password, str) or not password):
            errors.append(f"local user {username} pending password must be a non-empty string when present.")
        elif isinstance(password, str):
            errors.extend(_local_user_password_policy_errors(password, username, policy))
        if "unlock_requested" in row and not isinstance(row.get("unlock_requested"), bool):
            errors.append(f"local user {username} unlock_requested must be true or false.")
    return errors


def _local_users_payload(path: Path) -> dict:
