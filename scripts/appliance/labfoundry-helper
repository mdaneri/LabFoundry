    os.chmod(key_path, 0o640)


def _handle_ca(action: str, args: list[str]) -> int:
    try:
        config_path = _validate_ca_config_path(args[0])
    except (IndexError, ValueError) as exc:
        print(str(exc), file=sys.stderr)
        return 2
    errors = _ca_payload_errors(config_path)
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 2
    if action == "validate":
        print(json.dumps({"ca": "validation complete", "config_path": str(config_path)}, sort_keys=True))
        return 0
    payload = _load_ca_payload(config_path)
    root = payload["root"]
    root_cert = str(root["certificate_pem"])
    root_cert_path = _ca_managed_path(str(root["root_cert_path"]), "root_cert_path")
    legacy_root_path = _ca_managed_path(str(root["legacy_root_cert_path"]), "legacy_root_cert_path")
    bundle_path = _ca_managed_path(str(root["ca_bundle_path"]), "ca_bundle_path")
    crl_path_value = str(root.get("crl_path") or "")
    crl_pem = str(root.get("crl_pem") or "")
    _write_secret_file(root_cert_path, root_cert, 0o644)
    _write_secret_file(legacy_root_path, root_cert, 0o644)
    _write_secret_file(bundle_path, root_cert, 0o644)
    written = [str(root_cert_path), str(legacy_root_path), str(bundle_path)]
    removed: list[str] = []
    if crl_path_value:
        crl_path = _ca_managed_path(crl_path_value, "crl_path")
        if crl_pem:
            _write_secret_file(crl_path, crl_pem, 0o644)
            written.append(str(crl_path))
        elif crl_path.exists():
            crl_path.unlink()
            removed.append(str(crl_path))
    for certificate in payload["certificates"]:
        cert_path_value = str(certificate.get("cert_path") or "")
        key_path_value = str(certificate.get("key_path") or "")
        chain_path_value = str(certificate.get("chain_path") or "")
        if cert_path_value:
            cert_path = _ca_managed_path(cert_path_value, "cert_path")
            _write_secret_file(cert_path, str(certificate["certificate_pem"]), 0o644)
            written.append(str(cert_path))
        if chain_path_value:
            chain_path = _ca_managed_path(chain_path_value, "chain_path")
            _write_secret_file(chain_path, str(certificate.get("chain_pem") or certificate["certificate_pem"]), 0o644)
            written.append(str(chain_path))
        if key_path_value and certificate.get("private_key_pem"):
            key_path = _ca_managed_path(key_path_value, "key_path")
            _write_secret_file(key_path, str(certificate["private_key_pem"]), 0o600)
            if key_path == LDAP_KEY_PATH.resolve():
                try:
                    _grant_ldap_private_key_read(key_path)
                except (LookupError, OSError) as exc:
                    print(f"Could not preserve slapd access to the LDAP private key: {exc}", file=sys.stderr)
                    return 1
            written.append(str(key_path))
    print(json.dumps({"ca": "apply complete", "config_path": str(config_path), "written_files": written, "removed_files": removed}, sort_keys=True))
    return 0




def _validate_dnsmasq_config(path: Path) -> subprocess.CompletedProcess[str]:
    dnsmasq = shutil.which("dnsmasq")
    if dnsmasq is None:
        return subprocess.CompletedProcess(["dnsmasq", "--test", f"--conf-file={path}"], 127, "", "dnsmasq command not found\n")
    return _run([dnsmasq, "--test", f"--conf-file={path}"])


def _dnsmasq_config_uses_dnssec(path: Path) -> bool:
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip().lower()
        if line == "dnssec":
            return True
    return False


def _dnsmasq_supports_dnssec() -> tuple[bool, str]:
    dnsmasq = shutil.which("dnsmasq")
    if dnsmasq is None:
        return False, "dnsmasq command not found"
    result = _run([dnsmasq, "--version"])
    output = f"{result.stdout}\n{result.stderr}".lower()
    if result.returncode != 0:
        return False, (result.stderr or result.stdout or "dnsmasq --version failed").strip()
    if "no-dnssec" in output:
        return False, "installed dnsmasq reports no-DNSSEC"
    if "dnssec" in output:
        return True, ""
    return False, "installed dnsmasq does not report DNSSEC support"


def _find_dnsmasq_trust_anchor_file() -> Path | None:
    for candidate in DNSMASQ_DNSSEC_TRUST_ANCHOR_CANDIDATES:
        if candidate.is_file():
            return candidate
    return None


def _prepare_dnsmasq_dnssec(path: Path) -> tuple[bool, str]:
    if not _dnsmasq_config_uses_dnssec(path):
        return True, ""
    supported, detail = _dnsmasq_supports_dnssec()
    if not supported:
        return False, f"DNSSEC validation is enabled, but {detail}."
    anchor_path = _find_dnsmasq_trust_anchor_file()
    if anchor_path is None:
        candidates = ", ".join(str(candidate) for candidate in DNSMASQ_DNSSEC_TRUST_ANCHOR_CANDIDATES)
        return False, f"DNSSEC validation is enabled, but no package trust-anchor file was found. Checked: {candidates}."
    DNSMASQ_APPLY_DIR.mkdir(parents=True, exist_ok=True)
    shutil.copy2(anchor_path, DNSMASQ_DNSSEC_TRUST_ANCHORS_PATH)
    try:
        shutil.chown(DNSMASQ_DNSSEC_TRUST_ANCHORS_PATH, user="labfoundry", group="labfoundry")
    except LookupError:
        pass
    os.chmod(DNSMASQ_DNSSEC_TRUST_ANCHORS_PATH, 0o644)
    return True, ""


def _dnsmasq_tftp_roots(path: Path) -> list[Path]:
    roots: list[Path] = []
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or not line.startswith("tftp-root="):
            continue
        value = line.split("=", 1)[1].strip()
        if value:
            roots.append(Path(value))
    return roots


def _prepare_dnsmasq_tftp_roots(path: Path) -> None:
    allowed_root = ESXI_TFTP_ROOT.resolve()
    for root in _dnsmasq_tftp_roots(path):
        if root.resolve() != allowed_root:
            raise ValueError(f"dnsmasq TFTP root must be {ESXI_TFTP_ROOT}")
        root.mkdir(parents=True, exist_ok=True)
        try:
            shutil.chown(root, user="labfoundry", group="labfoundry")
        except LookupError:
            pass


def _install_dnsmasq_service_dropin() -> None:
    dnsmasq = shutil.which("dnsmasq") or "/usr/sbin/dnsmasq"
    DNSMASQ_SERVICE_DROPIN_DIR.mkdir(parents=True, exist_ok=True)
    DNSMASQ_SERVICE_DROPIN_PATH.write_text(
        "\n".join(
            [
                "[Service]",
                "ExecStart=",
                f"ExecStart={dnsmasq} --keep-in-foreground --conf-file={DNSMASQ_CONFIG_PATH}",
                "",
            ]
        ),
        encoding="utf-8",
    )


def _read_dnsmasq_leases() -> int:
    lease_path = DNSMASQ_LEASE_FILE_PATH.resolve()
    if not lease_path.is_relative_to(DNSMASQ_STATE_DIR.resolve()):
        print(f"dnsmasq lease file must stay under {DNSMASQ_STATE_DIR}", file=sys.stderr)
        return 2
    if not lease_path.exists():
        return 0
    if not lease_path.is_file():
        print(f"dnsmasq lease path is not a regular file: {lease_path}", file=sys.stderr)
        return 2
    print(lease_path.read_text(encoding="utf-8"), end="")
    return 0


def _systemd_unit_logs(unit: str) -> int:
    journalctl = shutil.which("journalctl")
    if journalctl is None:
        print("journalctl command not found", file=sys.stderr)
        return 127
    result = _run([journalctl, "-u", unit, "-n", "500", "--no-pager", "--output=short-iso"])
    if result.stdout:
        print(result.stdout, end="" if result.stdout.endswith("\n") else "\n")
    if result.stderr:
        print(result.stderr, file=sys.stderr, end="" if result.stderr.endswith("\n") else "\n")
    return result.returncode


def _write_management_resolver(servers: list[str], domains: list[str]) -> None:
    if NETWORKD_MGMT_CONFIG_PATH.is_file():
        lines = NETWORKD_MGMT_CONFIG_PATH.read_text(encoding="utf-8").splitlines()
        updated: list[str] = []
        in_network = False
        inserted = False
        for line in lines:
            stripped = line.strip()
            if stripped == "[Network]":
                in_network = True
                updated.append(line)
                continue
            if in_network and stripped.startswith("[") and stripped.endswith("]"):
                if not inserted:
                    updated.extend([f"DNS={server}" for server in servers])
                    updated.extend([f"Domains={domain}" for domain in domains])
                    inserted = True
                in_network = False
            if in_network and (stripped.startswith("DNS=") or stripped.startswith("Domains=")):
                continue
            updated.append(line)
        if in_network and not inserted:
            updated.extend([f"DNS={server}" for server in servers])
            updated.extend([f"Domains={domain}" for domain in domains])
        NETWORKD_MGMT_CONFIG_PATH.write_text("\n".join(updated).rstrip() + "\n", encoding="utf-8")


def _configure_resolver(interface_name: str, servers: list[str], domains: list[str]) -> subprocess.CompletedProcess[str]:
    _write_management_resolver(servers, domains)
    commands = [
        ["resolvectl", "dns", interface_name, *servers],
        ["resolvectl", "domain", interface_name, *(domains or [""])],
    ]
    for command in commands:
        result = _run(command)
        print(result.stdout, end="")
        print(result.stderr, end="", file=sys.stderr)
        if result.returncode != 0:
            return result
    return subprocess.CompletedProcess(commands[-1], 0, "", "")


def _configure_dhcp_resolver(interface_name: str) -> subprocess.CompletedProcess[str]:
    _write_management_resolver([], [])
    result = _run(["resolvectl", "revert", interface_name])
    print(result.stdout, end="")
    print(result.stderr, end="", file=sys.stderr)
    return result


def _configure_local_resolver() -> subprocess.CompletedProcess[str]:
    return _configure_resolver("eth0", ["127.0.0.1"], ["~."])


def _handle_dnsmasq(action: str, args: list[str]) -> int:
    if action == "logs":
        if args:
            print("dnsmasq logs does not accept a path", file=sys.stderr)
            return 2
        return _systemd_unit_logs("dnsmasq.service")
    if action == "leases":
        if args:
            print("dnsmasq leases does not accept a path", file=sys.stderr)
            return 2
        return _read_dnsmasq_leases()

    if action in {"validate", "apply"}:
        try:
            config_path = _validate_dnsmasq_config_path(args[0])
        except (IndexError, ValueError) as exc:
            print(str(exc), file=sys.stderr)
            return 2

        dnssec_ready, dnssec_error = _prepare_dnsmasq_dnssec(config_path)
        if not dnssec_ready:
            print(dnssec_error, file=sys.stderr)
            return 2
        validation = _validate_dnsmasq_config(config_path)
        print(validation.stdout, end="")
        print(validation.stderr, end="", file=sys.stderr)
        if action == "validate" or validation.returncode != 0:
            return validation.returncode

        try:
            _prepare_dnsmasq_tftp_roots(config_path)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            return 2

        DNSMASQ_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        DNSMASQ_STATE_DIR.mkdir(parents=True, exist_ok=True)
        shutil.copy2(config_path, DNSMASQ_CONFIG_PATH)
        _install_dnsmasq_service_dropin()
        daemon_reload = _run(["systemctl", "daemon-reload"])
        print(daemon_reload.stdout, end="")
        print(daemon_reload.stderr, end="", file=sys.stderr)
        if daemon_reload.returncode != 0:
            return daemon_reload.returncode
        enable = _run(["systemctl", "enable", "dnsmasq"])
        print(enable.stdout, end="")
        print(enable.stderr, end="", file=sys.stderr)
        if enable.returncode != 0:
            return enable.returncode
        restart = _run(["systemctl", "reload-or-restart", "dnsmasq"])
        print(restart.stdout, end="")
        print(restart.stderr, end="", file=sys.stderr)
        return restart.returncode

    if action == "reload":
        daemon_reload = _run(["systemctl", "daemon-reload"])
        print(daemon_reload.stdout, end="")
        print(daemon_reload.stderr, end="", file=sys.stderr)
        if daemon_reload.returncode != 0:
            return daemon_reload.returncode
        restart = _run(["systemctl", "reload-or-restart", "dnsmasq"])
        print(restart.stdout, end="")
        print(restart.stderr, end="", file=sys.stderr)
        if restart.returncode != 0:
            return restart.returncode
        return restart.returncode

    print(f"unsupported dnsmasq action: {action}", file=sys.stderr)
    return 2


def _validate_esxi_pxe_config_path(path_value: str) -> Path:
    path = Path(path_value).resolve()
    if path.suffix != ".json":
        raise ValueError("ESXi PXE manifest path must end with .json")
    if not path.is_relative_to(ESXI_PXE_APPLY_DIR):
        raise ValueError(f"ESXi PXE manifest must be staged under {ESXI_PXE_APPLY_DIR}")
    if not path.is_file():
        raise ValueError(f"ESXi PXE manifest does not exist: {path}")
    return path


def _load_esxi_pxe_manifest(path: Path) -> dict:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise ValueError(f"ESXi PXE manifest is not valid JSON: {exc}") from exc
    if payload.get("kind") != "labfoundry-esxi-pxe":
        raise ValueError("ESXi PXE manifest kind is invalid")
    if payload.get("schema_version") != ESXI_PXE_SCHEMA_VERSION:
        raise ValueError("ESXi PXE manifest schema version is not supported")
    if Path(str(payload.get("http_root") or "")).resolve() != ESXI_PXE_HTTP_ROOT:
        raise ValueError(f"ESXi PXE http_root must be {ESXI_PXE_HTTP_ROOT}")
    if Path(str(payload.get("http_base") or ESXI_PXE_HTTP_BASE)).resolve() != ESXI_PXE_HTTP_BASE.resolve():
        raise ValueError(f"ESXi PXE http_base must be {ESXI_PXE_HTTP_BASE}")
    if Path(str(payload.get("image_http_root") or ESXI_PXE_IMAGE_HTTP_ROOT)).resolve() != ESXI_PXE_IMAGE_HTTP_ROOT.resolve():
        raise ValueError(f"ESXi PXE image_http_root must be {ESXI_PXE_IMAGE_HTTP_ROOT}")
    if Path(str(payload.get("installer_iso_root") or ESXI_INSTALLER_ISO_ROOT)).resolve() != ESXI_INSTALLER_ISO_ROOT.resolve():
        raise ValueError(f"ESXi PXE installer_iso_root must be {ESXI_INSTALLER_ISO_ROOT}")
    if not isinstance(payload.get("kickstarts"), list):
        raise ValueError("ESXi PXE manifest kickstarts must be a list")
    if not isinstance(payload.get("hosts"), list):
        raise ValueError("ESXi PXE manifest hosts must be a list")
    if not isinstance(payload.get("artifacts"), list):
        raise ValueError("ESXi PXE manifest artifacts must be a list")
    return payload


def _simple_pxe_filename(value: str) -> bool:
    return bool(re.fullmatch(r"[A-Za-z0-9._-]+", value or "")) and "/" not in value and "\\" not in value and not value.startswith(".")


def _find_pxe_boot_binary(filename: str) -> Path | None:
    for directory in PXE_BOOT_BINARY_DIRS:
        candidate = directory / filename
        if candidate.is_file():
            return candidate
    for directory in PXE_BOOT_BINARY_DIRS:
        if not directory.is_dir():
            continue
        for candidate in directory.rglob(filename):
            if candidate.is_file():
                return candidate
    return None


def _esxi_pxe_boot_errors(boot: dict) -> list[str]:
    errors: list[str] = []
    if not isinstance(boot, dict):
        return ["ESXi PXE boot settings must be an object."]
    enabled = bool(boot.get("enabled"))
    native_uefi_http_enabled = bool(boot.get("native_uefi_http_enabled"))
    if enabled:
        hostname = str(boot.get("hostname") or "").strip()
        listen_address = str(boot.get("listen_address") or "").splitlines()[0].strip()
        if not hostname or "." not in hostname:
            errors.append("ESXi PXE hostname must be a fully qualified DNS name.")
        try:
            ip_address(listen_address)
        except ValueError:
            errors.append("ESXi PXE listen_address must include at least one IP address.")
        try:
            http_port = int(boot.get("http_port") or ESXI_PXE_DEFAULT_HTTP_PORT)
            if http_port < 1 or http_port > 65535:
                errors.append("ESXi PXE HTTP port must be between 1 and 65535.")
        except (TypeError, ValueError):
            errors.append("ESXi PXE HTTP port must be an integer.")
        tftp_root = Path(str(boot.get("tftp_root") or "")).resolve()
        if tftp_root != ESXI_TFTP_ROOT.resolve():
            errors.append(f"ESXi PXE TFTP root must be {ESXI_TFTP_ROOT}.")
        for key, label in (
            ("bios_bootfile", "BIOS bootfile"),
            ("uefi_bootfile", "UEFI bootfile"),
            ("bios_second_stage_bootfile", "BIOS second-stage bootfile"),
            ("uefi_second_stage_bootfile", "UEFI second-stage bootfile"),
            ("native_uefi_bootfile", "native UEFI bootfile"),
        ):
            filename = str(boot.get(key) or "")
            if not _simple_pxe_filename(filename):
                errors.append(f"{label} must be a simple filename.")
        for key, label in (
            ("bios_bootfile", "BIOS PXE bootfile"),
            ("uefi_bootfile", "UEFI PXE bootfile"),
            ("bios_second_stage_bootfile", "BIOS second-stage bootfile"),
        ):
            filename = str(boot.get(key) or "")
            if _simple_pxe_filename(filename) and _find_pxe_boot_binary(filename) is None:
                errors.append(
                    f"{label} {filename} was not found. Install the Photon syslinux/ipxe boot packages "
                    f"or stage the expected bootloader under {PXE_BOOTLOADER_STAGING_DIR}."
                )
    if native_uefi_http_enabled:
        url = str(boot.get("native_uefi_http_url") or boot.get("effective_native_uefi_http_url") or "").strip()
        if not re.fullmatch(r"https?://[^\s\"'<>]+", url):
            errors.append("Native UEFI HTTP URL must be an absolute HTTP or HTTPS URL.")
    return errors


def _esxi_pxe_manifest_errors(payload: dict) -> list[str]:
    errors: list[str] = []
    seen_ids: set[int] = set()
    enabled_ids: set[int] = set()
    iso_root = ESXI_INSTALLER_ISO_ROOT.resolve()
    errors.extend(_esxi_pxe_boot_errors(payload.get("boot") or {"enabled": False}))
    for row in payload.get("kickstarts", []):
        if not isinstance(row, dict):
            errors.append("Kickstart entry must be an object.")
            continue
        try:
            kickstart_id = int(row.get("id"))
        except (TypeError, ValueError):
            errors.append("Kickstart id must be an integer.")
            continue
        if kickstart_id in seen_ids:
            errors.append(f"Kickstart {kickstart_id} is duplicated.")
        seen_ids.add(kickstart_id)
        if row.get("enabled"):
            enabled_ids.add(kickstart_id)
        content = str(row.get("content") or "")
        if row.get("enabled") and not content.strip():
            errors.append(f"Kickstart {kickstart_id} content is empty.")
        expected_hash = str(row.get("content_hash") or "")
        actual_hash = hashlib.sha256(content.encode("utf-8")).hexdigest()
        if expected_hash and expected_hash != actual_hash:
            errors.append(f"Kickstart {kickstart_id} content hash does not match manifest content.")
        generated_path = Path(str(row.get("generated_path") or "")).resolve()
        resolved_root = ESXI_PXE_HTTP_ROOT.resolve()
        if generated_path != resolved_root and resolved_root not in generated_path.parents:
            errors.append(f"Kickstart {kickstart_id} generated_path must stay under {resolved_root}.")
        elif generated_path.suffix != ".cfg":
            errors.append(f"Kickstart {kickstart_id} generated_path must end in .cfg.")
        http_path = str(row.get("http_path") or "").strip()
        if not http_path.startswith(f"{ESXI_KICKSTART_HTTP_PREFIX}/") or not http_path.endswith(".cfg"):
            errors.append(f"Kickstart {kickstart_id} http_path must stay under {ESXI_KICKSTART_HTTP_PREFIX}.")
        elif generated_path.name != Path(http_path).name:
            errors.append(f"Kickstart {kickstart_id} generated_path filename must match http_path.")
        if expected_hash and generated_path.stem != expected_hash[:12]:
            errors.append(f"Kickstart {kickstart_id} generated_path must use the content hash prefix {expected_hash[:12]}.")
    for host in payload.get("hosts", []):
        if not isinstance(host, dict):
            errors.append("ESXi PXE host entry must be an object.")
            continue
        kickstart_id = host.get("kickstart_id")
        if host.get("enabled") and kickstart_id is not None:
            try:
                normalized_kickstart_id = int(kickstart_id)
            except (TypeError, ValueError):
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} references invalid Kickstart {kickstart_id}.")
            else:
                if normalized_kickstart_id not in enabled_ids:
                    errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} references disabled or missing Kickstart {kickstart_id}.")
        installer_iso_path = str(host.get("installer_iso_path") or "").strip()
        if installer_iso_path:
            selected_iso = Path(installer_iso_path)
            if not selected_iso.is_absolute():
                selected_iso = iso_root / installer_iso_path
            selected_iso = selected_iso.resolve()
            if selected_iso != iso_root and iso_root not in selected_iso.parents:
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} installer ISO must be under {iso_root}.")
            elif selected_iso.suffix.lower() != ".iso":
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} installer ISO must be a .iso file.")
            elif not selected_iso.is_file() and not selected_iso.is_dir():
                errors.append(f"Host {host.get('hostname') or host.get('mac_address') or 'unknown'} installer ISO is missing: {selected_iso}.")
    for artifact in payload.get("artifacts", []):
        if not isinstance(artifact, dict):
            errors.append("ESXi PXE artifact entry must be an object.")
            continue
        label = str(artifact.get("hostname") or artifact.get("mac_address") or "unknown")
        mac_key = str(artifact.get("mac_key") or "")
        if mac_key != "default" and not re.fullmatch(r"01(?:-[0-9a-f]{2}){6}", mac_key):
            errors.append(f"Host {label} MAC key is invalid.")
        image_key = str(artifact.get("image_key") or "")
        if not re.fullmatch(r"[a-z0-9][a-z0-9._-]{0,160}", image_key):
            errors.append(f"Host {label} image key is invalid.")
        kickstart_id = artifact.get("kickstart_id")
        if kickstart_id is not None:
            try:
                normalized_kickstart_id = int(kickstart_id)
            except (TypeError, ValueError):
                errors.append(f"Host {label} artifact references invalid Kickstart {kickstart_id}.")
            else:
                if normalized_kickstart_id not in enabled_ids:
                    errors.append(f"Host {label} artifact references disabled or missing Kickstart {kickstart_id}.")
        installer_iso_path = str(artifact.get("installer_iso_path") or "").strip()
        if not installer_iso_path:
            errors.append(f"Host {label} artifact is missing installer ISO path.")
        else:
            selected_iso = Path(installer_iso_path)
            if not selected_iso.is_absolute():
                selected_iso = iso_root / installer_iso_path
            selected_iso = selected_iso.resolve()
            if selected_iso != iso_root and iso_root not in selected_iso.parents:
                errors.append(f"Host {label} artifact installer ISO must be under {iso_root}.")
            elif selected_iso.suffix.lower() != ".iso":
                errors.append(f"Host {label} artifact installer ISO must be a .iso file.")
            elif not selected_iso.is_file() and not selected_iso.is_dir():
                errors.append(f"Host {label} artifact installer ISO is missing: {selected_iso}.")
        for key, base, description in [
            ("image_generated_path", ESXI_PXE_IMAGE_HTTP_ROOT, "image generated path"),
            ("pxelinux_config_path", ESXI_TFTP_ROOT / "pxelinux.cfg", "PXELINUX config path"),
            ("uefi_tftp_boot_cfg_path", ESXI_TFTP_ROOT, "UEFI TFTP boot.cfg path"),
            ("http_boot_cfg_path", ESXI_PXE_HTTP_BASE, "HTTP boot.cfg path"),
        ]:
            value = str(artifact.get(key) or "")
            if not value:
                errors.append(f"Host {label} artifact {description} is required.")
                continue
            resolved = Path(value).resolve()
            resolved_base = base.resolve()
            if resolved != resolved_base and resolved_base not in resolved.parents:
                errors.append(f"Host {label} artifact {description} must stay under {base}.")
    return errors


def _remove_cdromboot(options: str) -> list[str]:
    return [item for item in options.split() if item != "cdromBoot"]


def _normalize_esxi_boot_path(value: str) -> str:
    return value.strip().lstrip("/")


def _bootif_from_mac_key(mac_key: str) -> str:
    key = (mac_key or "").strip().lower()
    if re.fullmatch(r"01(-[0-9a-f]{2}){6}", key):
        return f"BOOTIF={key}"
    return ""


def _render_esxi_boot_cfg(source_text: str, *, prefix_url: str, kickstart_url: str = "", bootif: str = "", fallback_netdevice: str = "") -> str:
    lines = source_text.replace("\r\n", "\n").replace("\r", "\n").splitlines()
    rendered: list[str] = []
    saw_prefix = False
    saw_kernelopt = False
    kernel_index = -1
    bootif_option = bootif.strip()
    fallback_netdevice = fallback_netdevice.strip()
    for raw_line in lines:
        stripped = raw_line.strip()
        if stripped.startswith("#") or "=" not in stripped:
            rendered.append(raw_line)
            continue
        key, value = stripped.split("=", 1)
        lower_key = key.lower()
        if lower_key == "prefix":
            rendered.append(f"prefix={prefix_url}")
            saw_prefix = True
        elif lower_key in {"kernel", "modules"}:
            separator = "---" if lower_key == "modules" else None
            if separator:
                values = [_normalize_esxi_boot_path(item) for item in value.split(separator)]
                rendered.append(f"{key}={separator.join(values)}")
            else:
                rendered.append(f"{key}={_normalize_esxi_boot_path(value)}")
            if lower_key == "kernel":
                kernel_index = len(rendered) - 1
        elif lower_key == "kernelopt":
            options = _remove_cdromboot(value)
            if kickstart_url and not any(item.startswith("ks=") for item in options):
                options.append(f"ks={kickstart_url}")
            if bootif_option and not any(item.startswith("BOOTIF=") for item in options):
                options.append(bootif_option)
            if fallback_netdevice and not bootif_option and not any(item.startswith(("BOOTIF=", "netdevice=", "ksdevice=")) for item in options):
                options.append(f"netdevice={fallback_netdevice}")
            rendered.append(f"kernelopt={' '.join(options)}".rstrip())
            saw_kernelopt = True
        else:
            rendered.append(raw_line)
    if not saw_prefix:
        insert_at = 0
        rendered.insert(insert_at, f"prefix={prefix_url}")
        if kernel_index >= insert_at:
            kernel_index += 1
    if not saw_kernelopt:
        options = []
        if kickstart_url:
            options.append(f"ks={kickstart_url}")
        if bootif_option:
            options.append(bootif_option)
        elif fallback_netdevice:
            options.append(f"netdevice={fallback_netdevice}")
        line = f"kernelopt={' '.join(options)}".rstrip()
        if kernel_index >= 0:
            rendered.insert(kernel_index + 1, line)
        else:
            rendered.append(line)
    return "\n".join(rendered).rstrip() + "\n"


def _safe_relative_path(path: Path, base: Path) -> str:
    return path.resolve().relative_to(base.resolve()).as_posix()


def _find_under(root: Path, names: list[str]) -> Path | None:
    wanted = {name.lower() for name in names}
    for candidate in root.rglob("*"):
        if candidate.is_file() and candidate.name.lower() in wanted:
            return candidate
    return None


def _find_esxi_uefi_bootloader(root: Path) -> Path | None:
    for directory in root.rglob("*"):
        if not directory.is_dir():
            continue
        relative = directory.relative_to(root)
        if [part.lower() for part in relative.parts] != ["efi", "boot"]:
            continue
        for candidate in directory.iterdir():
            if candidate.is_file() and candidate.name.lower() == "bootx64.efi":
                return candidate
    return None


def _copy_tree_contents(source: Path, destination: Path) -> None:
    destination.mkdir(parents=True, exist_ok=True)
    for child in source.iterdir():
        target = destination / child.name
        if child.is_dir():
            shutil.copytree(child, target, dirs_exist_ok=True)
        elif child.is_file():
            shutil.copy2(child, target)


def _copy_installer_iso_contents(source: Path, destination: Path) -> None:
    if source.is_dir():
        _copy_tree_contents(source, destination)
        return
    mount = shutil.which("mount")
    umount = shutil.which("umount")
    if mount is None or umount is None:
        raise RuntimeError("mount and umount are required to extract ESXi installer ISOs.")
    with tempfile.TemporaryDirectory(prefix="labfoundry-esxi-iso-") as temp_dir:
        mount_point = Path(temp_dir)
        mounted = _run([mount, "-o", "loop,ro", str(source), str(mount_point)])
        print(mounted.stdout, end="")
        print(mounted.stderr, end="", file=sys.stderr)
        if mounted.returncode != 0:
            raise RuntimeError(f"failed to mount ESXi installer ISO {source}")
        try:
            _copy_tree_contents(mount_point, destination)
        finally:
            unmounted = _run([umount, str(mount_point)])
            print(unmounted.stdout, end="")
            print(unmounted.stderr, end="", file=sys.stderr)
            if unmounted.returncode != 0:
                raise RuntimeError(f"failed to unmount ESXi installer ISO {source}")


def _render_pxelinux_config(*, kernel_path: str, boot_cfg_path: str) -> str:
    return "\n".join(
        [
            "DEFAULT install",
            "NOHALT 1",
            "LABEL install",
            f"  KERNEL {kernel_path}",
            f"  APPEND -c {boot_cfg_path}",
            "  IPAPPEND 2",
            "",
        ]
    )


def _default_esxi_ipxe_script() -> str:
    return "\n".join(
        [
            "#!ipxe",
            "echo LabFoundry now generates ESXi PXE boot artifacts during global appliance apply.",
            "echo Legacy custom iPXE script storage is preserved for settings compatibility only.",
            "shell",
            "",
        ]
    )


def _esxi_ipxe_script_text(boot: dict) -> str:
    text = str(boot.get("ipxe_script") or "").strip()
    if not text:
        text = _default_esxi_ipxe_script().strip()
    if not text.startswith("#!ipxe"):
        text = "#!ipxe\n" + text
    return text.rstrip() + "\n"


def _write_text(path: Path, text: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")
    path.chmod(mode)


def _copy_file(path: Path, target: Path, mode: int = 0o644) -> None:
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(path, target)
    target.chmod(mode)


def _remove_legacy_esxi_pxe_artifacts(generated_files: list[str], generated_tftp_files: list[str]) -> None:
    generated = {Path(path).resolve() for path in [*generated_files, *generated_tftp_files]}
    for path in (
        ESXI_TFTP_ROOT / "bootx64.efi",
        ESXI_TFTP_ROOT / "esxi.ipxe",
        ESXI_TFTP_ROOT / "boot.ipxe",
        ESXI_PXE_HTTP_BASE / "boot.ipxe",
    ):
        if path.resolve() not in generated:
            path.unlink(missing_ok=True)


def _managed_pxe_artifact_name(name: str) -> bool:
    return name == "default" or bool(re.fullmatch(r"01(?:-[0-9a-f]{2}){6}", name))


def _remove_stale_esxi_pxe_host_artifacts(generated_files: list[str], generated_tftp_files: list[str]) -> None:
    generated = {Path(path).resolve() for path in [*generated_files, *generated_tftp_files]}
    for path in (ESXI_TFTP_ROOT / "boot.cfg", ESXI_PXE_HTTP_BASE / "boot.cfg"):
        if path.resolve() not in generated:
            path.unlink(missing_ok=True)

    pxelinux_dir = ESXI_TFTP_ROOT / "pxelinux.cfg"
    if pxelinux_dir.is_dir():
        for path in pxelinux_dir.iterdir():
            if path.is_file() and _managed_pxe_artifact_name(path.name) and path.resolve() not in generated:
                path.unlink(missing_ok=True)

    for root in (ESXI_TFTP_ROOT, ESXI_PXE_HTTP_BASE):
        if not root.is_dir():
            continue
        for child in root.iterdir():
            if not child.is_dir() or not _managed_pxe_artifact_name(child.name):
                continue
            boot_cfg = child / "boot.cfg"
            if boot_cfg.resolve() not in generated:
                boot_cfg.unlink(missing_ok=True)
            try:
                child.rmdir()
            except OSError:
                pass


