#!/bin/sh
set -eu

log() {
  printf '%s\n' "$*"
  logger -t labfoundry-data-disks "$*" 2>/dev/null || true
}

root_disk() {
  root_source="$(findmnt -n -o SOURCE / 2>/dev/null || true)"
  if [ -z "$root_source" ]; then
    return 0
  fi
  parent="$(lsblk -no PKNAME "$root_source" 2>/dev/null | head -n 1 || true)"
  if [ -n "$parent" ]; then
    printf '/dev/%s\n' "$parent"
    return 0
  fi
  printf '%s\n' "$root_source"
}

has_partitions() {
  disk="$1"
  count="$(lsblk -nr -o TYPE "$disk" 2>/dev/null | awk '$1 == "part" { count++ } END { print count + 0 }')"
  [ "$count" -gt 0 ]
}

has_filesystem() {
  disk="$1"
  [ -n "$(blkid -s TYPE -o value "$disk" 2>/dev/null || true)" ]
}

blank_data_disks() {
  os_disk="$(root_disk)"
  lsblk -dn -o NAME,TYPE | awk '$2 == "disk" { print "/dev/" $1 }' | sort | while read -r disk; do
    if [ "$disk" = "$os_disk" ]; then
      continue
    fi
    if has_partitions "$disk"; then
      continue
    fi
    if has_filesystem "$disk"; then
      continue
    fi
    printf '%s\n' "$disk"
  done
}

next_blank_disk() {
  used_file="$1"
  for disk in $(blank_data_disks); do
    if grep -qxF "$disk" "$used_file" 2>/dev/null; then
      continue
    fi
    printf '%s\n' "$disk"
    return 0
  done
  return 1
}

ensure_fstab_entry() {
  uuid="$1"
  mountpoint="$2"
  tmp="$(mktemp)"
  if [ -f /etc/fstab ]; then
    awk -v mountpoint="$mountpoint" '$2 != mountpoint { print }' /etc/fstab >"$tmp"
  fi
  printf 'UUID=%s %s ext4 defaults,nofail,x-systemd.device-timeout=30s 0 2\n' "$uuid" "$mountpoint" >>"$tmp"
  cat "$tmp" >/etc/fstab
  rm -f "$tmp"
}

ensure_mount() {
  label="$1"
  mountpoint="$2"
  owner="$3"
  group="$4"
  mode="$5"
  used_file="$6"

  device="$(blkid -L "$label" 2>/dev/null || true)"
  if [ -z "$device" ]; then
    disk="$(next_blank_disk "$used_file" || true)"
    if [ -z "$disk" ]; then
      log "No blank data disk available for $label at $mountpoint; leaving directory mountpoint unmounted."
      install -d -o "$owner" -g "$group" -m "$mode" "$mountpoint"
      return 0
    fi
    log "Formatting $disk as $label for $mountpoint"
    mkfs.ext4 -F -L "$label" "$disk" >/dev/null
    printf '%s\n' "$disk" >>"$used_file"
    device="$(blkid -L "$label")"
  fi

  uuid="$(blkid -s UUID -o value "$device")"
  install -d -o "$owner" -g "$group" -m "$mode" "$mountpoint"
  ensure_fstab_entry "$uuid" "$mountpoint"
  if ! findmnt -rn "$mountpoint" >/dev/null 2>&1; then
    mount "$mountpoint"
  fi
  chown "$owner:$group" "$mountpoint"
  chmod "$mode" "$mountpoint"
  log "Mounted $label on $mountpoint from $device"
}

main() {
  for command in findmnt lsblk blkid mkfs.ext4 mount awk sort; do
    if ! command -v "$command" >/dev/null 2>&1; then
      log "$command is required to prepare LabFoundry data disks."
      exit 1
    fi
  done

  used_file="$(mktemp)"
  trap 'rm -f "$used_file"' EXIT

  ensure_mount LABFOUNDRY_DEPOT /mnt/labfoundry-vcf-offline-depot labfoundry labfoundry 0755 "$used_file"
  ensure_mount LABFOUNDRY_BKUP /mnt/labfoundry-vcf-backups root root 0755 "$used_file"
}

main "$@"
